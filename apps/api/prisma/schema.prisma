  closedMonthsClosed          ClosedMonth[]                     @relation("ClosedMonthClosedBy")
  closedMonthsReopened        ClosedMonth[]                     @relation("ClosedMonthReopenedBy")
  conversationsCreated        Conversation[]                    @relation("ConversationCreatedBy")
  conversationParticipations  ConversationParticipant[]
  messagesSent                Message[]                         @relation("MessageSender")
  messageReactions            MessageReaction[]
  messageAttachmentsUploaded  MessageAttachment[]               @relation("MessageAttachmentUploadedBy")
  helpFeedback                HelpFeedback[]
  integrationPreferences      UserIntegrationPreference[]
  presence                    UserPresence?
  notificationPreference      NotificationPreference?
  delegationsGiven            UserDelegation[]                  @relation("UserDelegationDelegator")
  delegationsReceived         UserDelegation[]                  @relation("UserDelegationDelegate")
  workItemFollows             WorkItemFollow[]                  @relation("WorkItemFollowUser")
  myDayAssistantLogs          MyDayAssistantLog[]               @relation("MyDayAssistantUser")

  relationshipLinksCreated RelationshipLink[]     @relation("RelationshipCreatedBy")
  impactAnalysesCreated    ImpactAnalysis[]       @relation("ImpactAnalysisCreatedBy")
  impactAnalysesApproved   ImpactAnalysis[]       @relation("ImpactAnalysisApprovedBy")
  impactAnalysisItems      ImpactAnalysisItem[]   @relation("ImpactItemResponsible")
  relationshipAuditLogs    RelationshipAuditLog[] @relation("RelationAuditPerformedBy")

  workflowDefinitionsCreated  WorkflowDefinition[] @relation("WorkflowDefCreatedBy")
  workflowDefinitionsUpdated  WorkflowDefinition[] @relation("WorkflowDefUpdatedBy")
  workflowVersionsCreated     WorkflowVersion[]    @relation("WorkflowVerCreatedBy")
  workflowVersionsPublished   WorkflowVersion[]    @relation("WorkflowVerPublishedBy")
  workflowApprovalsRequested  WorkflowApproval[]   @relation("WorkflowApprovRequester")
  workflowApprovalsApproved   WorkflowApproval[]   @relation("WorkflowApprovApprover")
  workflowTasksResponsible    WorkflowTask[]       @relation("WorkflowTaskResponsible")
  workflowTasksSubstitute     WorkflowTask[]       @relation("WorkflowTaskSubstitute")
  workflowTemplatesCreated    WorkflowTemplate[]   @relation("WorkflowTempCreatedBy")
  workflowDeadLettersResolved WorkflowDeadLetter[] @relation("WorkflowDLResolvedBy")

  @@index([companyId])
  @@index([branchId])
  @@index([accessProfileId])
  @@index([role])
  @@index([status])
}

model Permission {
  id          String              @id @default(uuid())
  key         String              @unique // ex.: "indicators:create"
  description String
  module      String
  action      String
  users       UserPermission[]
  profiles    ProfilePermission[]
}

model UserPermission {
  userId       String
  permissionId String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  grantedAt    DateTime   @default(now())

  @@id([userId, permissionId])
}

model AccessProfile {
  id          String            @id @default(uuid())
  companyId   String?
  company     Company?          @relation(fields: [companyId], references: [id])
  code        String
  name        String
  description String?
  role        UserRoleEnum?
  status      AdminRecordStatus @default(ACTIVE)
  system      Boolean           @default(false)
  createdById String?
  updatedById String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  deletedAt   DateTime?

  users       User[]
  permissions ProfilePermission[]

  @@unique([companyId, code])
  @@index([companyId, status])
}

model ProfilePermission {
  profileId    String
  permissionId String
  profile      AccessProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  permission   Permission    @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  grantedAt    DateTime      @default(now())

  @@id([profileId, permissionId])
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  userAgent String?
  ip        String?

  @@index([userId])
}

// =====================================================
// Mapa estrategico
// =====================================================

model StrategicMap {
  id                 String    @id @default(uuid())
  companyId          String
  company            Company   @relation(fields: [companyId], references: [id])
  name               String
  description        String?
  startsAt           DateTime
  endsAt             DateTime
  active             Boolean   @default(true)
  publishedVersionId String?
  createdById        String?
  createdBy          User?     @relation("StrategicMapCreatedBy", fields: [createdById], references: [id])
  updatedById        String?
  updatedBy          User?     @relation("StrategicMapUpdatedBy", fields: [updatedById], references: [id])
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  deletedAt          DateTime?

  perspectives Perspective[]
  objectives   StrategicObjective[]
  versions     StrategicMapVersion[]

  @@index([companyId])
  @@index([publishedVersionId])
}

model Perspective {
  id          String          @id @default(uuid())
  mapId       String
  map         StrategicMap    @relation(fields: [mapId], references: [id], onDelete: Cascade)
  kind        PerspectiveKind
  name        String
  description String?
  color       String?
  icon        String?
  position    Int             @default(0)
  positionX   Float           @default(0)
  positionY   Float           @default(0)
  width       Float           @default(1320)
  height      Float           @default(230)
  active      Boolean         @default(true)
  createdById String?
  createdBy   User?           @relation("PerspectiveCreatedBy", fields: [createdById], references: [id])
  updatedById String?
  updatedBy   User?           @relation("PerspectiveUpdatedBy", fields: [updatedById], references: [id])
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  deletedAt   DateTime?

  objectives StrategicObjective[]

  @@index([mapId])
  @@index([active])
}

model StrategicObjective {
  id            String       @id @default(uuid())
  mapId         String
  map           StrategicMap @relation(fields: [mapId], references: [id], onDelete: Cascade)
  perspectiveId String
  perspective   Perspective  @relation(fields: [perspectiveId], references: [id])

  name              String
  description       String?
  responsible       String?
  responsibleUserId String?
  responsibleUser   User?           @relation("StrategicObjectiveResponsible", fields: [responsibleUserId], references: [id])
  ownerNodeId       String?
  ownerNode         OrgNode?        @relation("StrategicObjectiveOwnerNode", fields: [ownerNodeId], references: [id])
  weight            Float           @default(1)
  status            ObjectiveStatus @default(PLANNED)
  priority          Int             @default(3)
  position          Int             @default(0)
  positionX         Float           @default(0)
  positionY         Float           @default(0)
  width             Float           @default(260)
  height            Float           @default(150)
  active            Boolean         @default(true)
  createdById       String?
  createdBy         User?           @relation("StrategicObjectiveCreatedBy", fields: [createdById], references: [id])
  updatedById       String?
  updatedBy         User?           @relation("StrategicObjectiveUpdatedBy", fields: [updatedById], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  indicators     Indicator[]                   @relation("IndicatorStrategicObjective")
  indicatorLinks StrategicObjectiveIndicator[]
  orgNodeLinks   StrategicObjectiveOrgNode[]
  actionPlans    ActionPlan[]                  @relation("ActionStrategicObjective")
  okrs           OKRObjective[]
  outRelations   ObjectiveRelation[]           @relation("ObjFrom")
  inRelations    ObjectiveRelation[]           @relation("ObjTo")

  @@index([mapId])
  @@index([perspectiveId])
  @@index([responsibleUserId])
  @@index([ownerNodeId])
  @@index([active])
}

model ObjectiveRelation {
  id          String             @id @default(uuid())
  fromId      String
  toId        String
  from        StrategicObjective @relation("ObjFrom", fields: [fromId], references: [id], onDelete: Cascade)
  to          StrategicObjective @relation("ObjTo", fields: [toId], references: [id], onDelete: Cascade)
  weight      Float              @default(1)
  kind        String             @default("impacta")
  label       String?
  description String?
  active      Boolean            @default(true)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  deletedAt   DateTime?

  @@unique([fromId, toId])
  @@index([active])
}

model StrategicObjectiveIndicator {
  id          String             @id @default(uuid())
  objectiveId String
  objective   StrategicObjective @relation(fields: [objectiveId], references: [id], onDelete: Cascade)
  indicatorId String
  indicator   Indicator          @relation(fields: [indicatorId], references: [id], onDelete: Cascade)
  createdById String?
  createdAt   DateTime           @default(now())
  deletedAt   DateTime?

  @@unique([objectiveId, indicatorId])
  @@index([indicatorId])
}

model StrategicObjectiveOrgNode {
  id          String             @id @default(uuid())
  objectiveId String
  objective   StrategicObjective @relation(fields: [objectiveId], references: [id], onDelete: Cascade)
  orgNodeId   String
  orgNode     OrgNode            @relation(fields: [orgNodeId], references: [id], onDelete: Cascade)
  kind        String             @default("responsavel")
  createdById String?
  createdAt   DateTime           @default(now())
  deletedAt   DateTime?

  @@unique([objectiveId, orgNodeId, kind])
  @@index([orgNodeId])
}

model StrategicMapVersion {
  id          String       @id @default(uuid())
  mapId       String
  map         StrategicMap @relation(fields: [mapId], references: [id], onDelete: Cascade)
  version     Int
  title       String
  description String?
  status      String       @default("DRAFT")
  snapshot    Json
  createdById String?
  createdBy   User?        @relation("StrategicVersionCreatedBy", fields: [createdById], references: [id])
  createdAt   DateTime     @default(now())
  publishedAt DateTime?

  @@unique([mapId, version])
  @@index([mapId, status])
}

// =====================================================
// OKRs
// =====================================================

model OKRCycle {
  id        String   @id @default(uuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  name      String
  startsAt  DateTime
  endsAt    DateTime
  active    Boolean  @default(true)

  objectives OKRObjective[]

  @@index([companyId])
}

model OKRObjective {
  id             String              @id @default(uuid())
  cycleId        String
  cycle          OKRCycle            @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  strategicObjId String?
  strategicObj   StrategicObjective? @relation(fields: [strategicObjId], references: [id])
  parentId       String?
  parent         OKRObjective?       @relation("OKRObjectiveChildren", fields: [parentId], references: [id])
  children       OKRObjective[]      @relation("OKRObjectiveChildren")
  name           String
  description    String?
  ownerName      String?
  team           String?
  // Vinculo real de area (OrgNode) e dono (User) — alem do texto livre legado.
  ownerNodeId    String?
  ownerNode      OrgNode?            @relation("OKRObjectiveOwnerNode", fields: [ownerNodeId], references: [id])
  ownerUserId    String?
  ownerUser      User?               @relation("OKRObjectiveOwnerUser", fields: [ownerUserId], references: [id])
  weight         Float               @default(1)
  confidence     Float               @default(0.5) // 0..1
  status         ObjectiveStatus     @default(PLANNED)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  deletedAt      DateTime?

  keyResults KeyResult[]
  checkins   OKRCheckin[]

  @@index([cycleId])
  @@index([parentId])
  @@index([ownerNodeId])
  @@index([ownerUserId])
}

model KeyResult {
  id           String        @id @default(uuid())
  objectiveId  String
  objective    OKRObjective  @relation(fields: [objectiveId], references: [id], onDelete: Cascade)
  metric       String
  unit         IndicatorUnit @default(QUANTITY)
  startValue   Float
  currentValue Float
  targetValue  Float
  direction    Direction     @default(HIGHER_BETTER)
  weight       Float         @default(1)
  responsible  String?
  // KR pode ser alimentado automaticamente por um indicador (puxa o ultimo realizado).
  indicatorId  String?
  indicator    Indicator?    @relation("KeyResultIndicator", fields: [indicatorId], references: [id])
  updatedAt    DateTime      @updatedAt
  createdAt    DateTime      @default(now())

  @@index([objectiveId])
  @@index([indicatorId])
}

model OKRCheckin {
  id          String       @id @default(uuid())
  objectiveId String
  objective   OKRObjective @relation(fields: [objectiveId], references: [id], onDelete: Cascade)
  weekRef     String // YYYY-Www
  confidence  Float
  progress    Float // 0..1
  note        String?
  createdAt   DateTime     @default(now())

  @@index([objectiveId])
}

// =====================================================
// Indicadores / KPIs
// =====================================================

model Indicator {
  id                   String              @id @default(uuid())
  companyId            String
  company              Company             @relation(fields: [companyId], references: [id])
  ownerNodeId          String
  ownerNode            OrgNode             @relation("IndicatorOwnerNode", fields: [ownerNodeId], references: [id])
  guidelineNodeId      String?
  guidelineNode        OrgNode?            @relation("IndicatorGuidelineNode", fields: [guidelineNodeId], references: [id])
  responsibleUserId    String?
  responsibleUser      User?               @relation("IndicatorResponsible", fields: [responsibleUserId], references: [id])
  feederUserId         String?
  feederUser           User?               @relation("IndicatorFeeder", fields: [feederUserId], references: [id])
  strategicObjectiveId String?
  strategicObjective   StrategicObjective? @relation("IndicatorStrategicObjective", fields: [strategicObjectiveId], references: [id])

  name             String
  code             String?
  description      String?
  type             IndicatorType   @default(OPERATIONAL)
  category         String?
  unit             IndicatorUnit   @default(PERCENT)
  unitLabel        String?
  periodicity      Periodicity     @default(MONTHLY)
  direction        Direction       @default(HIGHER_BETTER)
  formula          String?
  source           String?
  feedKind         FeedKind        @default(MANUAL)
  status           IndicatorStatus @default(ACTIVE)
  weight           Float           @default(1)
  yellowToleranceP Float           @default(10)

  // Rastreio de origem para integracao/migracao de sistemas legados
  // externalId  = chave primaria no sistema de origem.
  // externalSource = identificador da origem.
  externalId     String?
  externalSource String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  targets                 IndicatorTarget[]
  results                 IndicatorResult[]
  deviations              Deviation[]
  traceabilityEvents      TraceabilityEvent[]
  meetings                Meeting[]                     @relation("MeetingIndicator")
  actions                 ActionPlan[]                  @relation("ActionIndicator")
  treatmentCases          TreatmentCase[]
  childRelations          IndicatorTreeRelation[]       @relation("RelChild")
  parentRelations         IndicatorTreeRelation[]       @relation("RelParent")
  strategicObjectiveLinks StrategicObjectiveIndicator[]
  projects                Project[]                     @relation("ProjectIndicator")
  risks                   RiskRegister[]                @relation("RiskIndicator")
  nonConformities         NonConformity[]               @relation("NcIndicator")
  documents               Document[]                    @relation("DocIndicator")
  processes               Process[]                     @relation("ProcessIndicator")
  formTemplates           FormTemplate[]                @relation("FormTemplateIndicator")
  formSubmissions         FormSubmission[]              @relation("FormSubmissionIndicator")
  keyResults              KeyResult[]                   @relation("KeyResultIndicator")
  monthlyMeetingIndicators MonthlyMeetingIndicator[]    @relation("MonthlySnapshotIndicator")

  @@unique([companyId, code])
  @@unique([companyId, externalSource, externalId])
  @@index([companyId])
  @@index([ownerNodeId])
  @@index([guidelineNodeId])
  @@index([type])
  @@index([status])
  @@index([externalSource, externalId])
}

model IndicatorTarget {
  id          String    @id @default(uuid())
  indicatorId String
  indicator   Indicator @relation(fields: [indicatorId], references: [id], onDelete: Cascade)
  periodRef   String // YYYY-MM, YYYY, etc.
  target      Float
  lowerBound  Float?
  upperBound  Float?
  weight      Float     @default(1)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([indicatorId, periodRef])
  @@index([indicatorId])
}

model IndicatorResult {
  id               String          @id @default(uuid())
  indicatorId      String
  indicator        Indicator       @relation(fields: [indicatorId], references: [id], onDelete: Cascade)
  periodRef        String
  periodDate       DateTime // primeiro dia do periodo, p/ ordenar
  value            Float
  status           ResultStatus    @default(FILLED)
  light            TrafficLight    @default(GRAY)
  attainment       Float?
  deviationAbs     Float?
  deviationPct     Float?
  note             String?
  evidenceUrl      String?
  createdById      String?
  createdBy        User?           @relation("ResultCreatedBy", fields: [createdById], references: [id])
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  treatmentCases   TreatmentCase[]
  actionsGenerated ActionPlan[]    @relation("ActionIndicatorResult")

  @@unique([indicatorId, periodRef])
  @@index([indicatorId, periodDate])
  @@index([light])
}

model IndicatorTreeRelation {
  id       String                @id @default(uuid())
  parentId String
  childId  String
  parent   Indicator             @relation("RelParent", fields: [parentId], references: [id], onDelete: Cascade)
  child    Indicator             @relation("RelChild", fields: [childId], references: [id], onDelete: Cascade)
  kind     IndicatorRelationKind @default(POSITIVE)
  weight   Float                 @default(1)

  @@unique([parentId, childId])
}

model ClosedMonth {
  id           String    @id @default(uuid())
  companyId    String
  company      Company   @relation(fields: [companyId], references: [id])
  periodRef    String // ex: 2026-01
  reason       String?
  closedAt     DateTime  @default(now())
  closedById   String?
  closedBy     User?     @relation("ClosedMonthClosedBy", fields: [closedById], references: [id])
  reopenedAt   DateTime?
  reopenedById String?
  reopenedBy   User?     @relation("ClosedMonthReopenedBy", fields: [reopenedById], references: [id])
  deletedAt    DateTime?

  @@unique([companyId, periodRef])
  @@index([companyId])
}

// =====================================================
// Desvios / FCA / CAPA
// =====================================================

model Deviation {
  id                String            @id @default(uuid())
  companyId         String
  company           Company           @relation(fields: [companyId], references: [id])
  indicatorId       String
  indicator         Indicator         @relation(fields: [indicatorId], references: [id])
  periodRef         String
  number            Int // sequencial por empresa
  title             String
  severity          DeviationSeverity @default(MODERATE)
  status            DeviationStatus   @default(OPEN)
  method            AnalysisMethod    @default(FCA)
  fact              String?
  rootCause         String?
  impact            String?
  responsibleUserId String?
  responsibleUser   User?             @relation("DeviationResponsible", fields: [responsibleUserId], references: [id])
  dueDate           DateTime?
  openedAt          DateTime          @default(now())
  closedAt          DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  deletedAt         DateTime?

  causes          DeviationCause[]
  analyses        DeviationAnalysis[]
  actions         ActionPlan[]        @relation("ActionFromDeviation")
  meetings        Meeting[]           @relation("MeetingDeviation")
  treatmentCases  TreatmentCase[]
  nonConformities NonConformity[]     @relation("NcDeviation")

  @@unique([companyId, number])
  @@index([companyId])
  @@index([indicatorId])
}

model DeviationCause {
  id          String    @id @default(uuid())
  deviationId String
  deviation   Deviation @relation(fields: [deviationId], references: [id], onDelete: Cascade)
  category    String? // 6M ex.: Metodo, Maquina, MO, Material, Medida, Meio
  description String
  weight      Float     @default(1)
  createdAt   DateTime  @default(now())
}

model DeviationAnalysis {
  id             String          @id @default(uuid())
  deviationId    String
  deviation      Deviation       @relation(fields: [deviationId], references: [id], onDelete: Cascade)
  method         AnalysisMethod
  content        String // texto livre ou JSON serializado
  createdAt      DateTime        @default(now())
  actions        ActionPlan[]    @relation("ActionFromAnalysis")
  meetings       Meeting[]       @relation("MeetingAnalysis")
  treatmentCases TreatmentCase[]
}

// =====================================================
// Planos de acao
// =====================================================

model ActionPlan {
  id                   String              @id @default(uuid())
  companyId            String
  company              Company             @relation(fields: [companyId], references: [id])
  branchId             String?
  branch               Branch?             @relation(fields: [branchId], references: [id])
  ownerNodeId          String?
  ownerNode            OrgNode?            @relation("ActionOwnerNode", fields: [ownerNodeId], references: [id])
  responsibleUserId    String?
  responsibleUser      User?               @relation("ActionResponsible", fields: [responsibleUserId], references: [id])
  createdById          String?
  createdBy            User?               @relation("ActionCreatedBy", fields: [createdById], references: [id])
  strategicObjectiveId String?
  strategicObjective   StrategicObjective? @relation("ActionStrategicObjective", fields: [strategicObjectiveId], references: [id])
  indicatorId          String?
  indicator            Indicator?          @relation("ActionIndicator", fields: [indicatorId], references: [id])
  indicatorResultId    String?
  indicatorResult      IndicatorResult?    @relation("ActionIndicatorResult", fields: [indicatorResultId], references: [id])
  meetingId            String?
  meeting              Meeting?            @relation("ActionFromMeeting", fields: [meetingId], references: [id])
  analysisId           String?
  analysis             DeviationAnalysis?  @relation("ActionFromAnalysis", fields: [analysisId], references: [id])
  treatmentId          String?
  treatment            TreatmentCase?      @relation(fields: [treatmentId], references: [id])

  title                      String
  description                String?
  problemDescription         String?
  origin                     ActionOrigin              @default(MANUAL)
  originRefId                String?
  analysisTool               ActionAnalysisTool?
  rootCause                  String?
  priority                   ActionPriority            @default(MEDIUM)
  criticality                ActionPriority            @default(MEDIUM)
  status                     ActionStatus              @default(NOT_STARTED)
  startDate                  DateTime?
  dueDate                    DateTime?
  completedAt                DateTime?
  progress                   Float                     @default(0) // 0..100
  estimatedCost              Float?
  actualCost                 Float?
  responsibleEmail           String?
  evidenceRequired           Boolean                   @default(false)
  expectedResult             String?
  achievedResult             String?
  effectivenessStatus        ActionEffectivenessStatus @default(NOT_STARTED)
  effectivenessChecklist     Json?
  effectivenessSummary       String?
  effectivenessEvidence      String?
  effectivenessValidatedById String?
  effectivenessValidatedAt   DateTime?
  reopenedAt                 DateTime?
  cancelReason               String?

  deviationId String?
  deviation   Deviation? @relation("ActionFromDeviation", fields: [deviationId], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tasks            ActionTask[]
  participants     ActionParticipant[]
  evidences        ActionEvidence[]
  comments         ActionComment[]
  history          ActionHistory[]
  analysisSessions ActionAnalysisSession[]
  aiSuggestions    ActionAiSuggestion[]
  risks            RiskRegister[]          @relation("RiskMitigationAction")
  nonConformities  NonConformity[]         @relation("NcCorrectiveAction")

  @@index([companyId])
  @@index([branchId])
  @@index([status])
  @@index([dueDate])
  @@index([strategicObjectiveId])
  @@index([indicatorId])
  @@index([indicatorResultId])
  @@index([meetingId])
  @@index([treatmentId])
  @@index([effectivenessStatus])
}

model ActionTask {
  id             String           @id @default(uuid())
  actionId       String
  action         ActionPlan       @relation(fields: [actionId], references: [id], onDelete: Cascade)
  title          String
  done           Boolean          @default(false)
  completionNote String?
  dueDate        DateTime?
  startDate      DateTime?
  endDate        DateTime?
  assignedToId   String?
  assignedTo     User?            @relation("ActionTaskAssignee", fields: [assignedToId], references: [id])
  position       Int              @default(0)
  evidences      ActionEvidence[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([actionId])
  @@index([assignedToId])
}

model GeneralApprovalRequest {
  id           String    @id @default(uuid())
  companyId    String
  type         String
  entityType   String
  entityId     String
  title        String
  description  String?
  requesterId  String?
  approverId   String?
  status       String    @default("PENDING")
  reason       String?
  decisionNote String?
  decidedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([companyId, status])
  @@index([entityType, entityId])
  @@index([requesterId])
  @@index([approverId])
}

model ActionParticipant {
  id        String     @id @default(uuid())
  actionId  String
  action    ActionPlan @relation(fields: [actionId], references: [id], onDelete: Cascade)
  userId    String?
  name      String?
  email     String?
  role      String?
  createdAt DateTime   @default(now())

  @@index([actionId])
  @@index([userId])
}

model ActionEvidence {
  id           String      @id @default(uuid())
  actionId     String
  action       ActionPlan  @relation(fields: [actionId], references: [id], onDelete: Cascade)
  taskId       String?
  task         ActionTask? @relation(fields: [taskId], references: [id], onDelete: SetNull)
  title        String
  description  String?
  url          String?
  fileName     String?
  fileType     String?
  mimeType     String?
  sizeBytes    Int?
  data         Bytes?
  uploadedById String?
  createdAt    DateTime    @default(now())
  deletedAt    DateTime?

  @@index([actionId])
  @@index([taskId])
}

model ActionComment {
  id         String     @id @default(uuid())
  actionId   String
  action     ActionPlan @relation(fields: [actionId], references: [id], onDelete: Cascade)
  authorId   String?
  authorName String?
  comment    String
  createdAt  DateTime   @default(now())
  deletedAt  DateTime?

  @@index([actionId, createdAt])
}

model ActionHistory {
  id          String     @id @default(uuid())
  actionId    String
  action      ActionPlan @relation(fields: [actionId], references: [id], onDelete: Cascade)
  userId      String?
  eventType   String
  field       String?
  beforeValue String?
  afterValue  String?
  note        String?
  createdAt   DateTime   @default(now())

  @@index([actionId, createdAt])
}

model ActionAnalysisSession {
  id                String             @id @default(uuid())
  actionId          String
  action            ActionPlan         @relation(fields: [actionId], references: [id], onDelete: Cascade)
  method            ActionAnalysisTool
  status            ActionToolStatus   @default(DRAFT)
  problem           String?
  rootCause         String?
  responsibleUserId String?
  data              Json?
  aiSummary         String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  fiveWhys       ActionFiveWhy[]
  ishikawaCauses ActionIshikawaCause[]
  maspSteps      ActionMaspStep[]
  pdcaSteps      ActionPdcaStep[]
  fiveW2H        ActionFiveW2H?

  @@unique([actionId, method])
  @@index([actionId])
}

model ActionFiveWhy {
  id          String                @id @default(uuid())
  sessionId   String
  session     ActionAnalysisSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  position    Int
  question    String
  answer      String?
  evidence    String?
  aiPrompt    String?
  isRootCause Boolean               @default(false)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  @@unique([sessionId, position])
}

model ActionIshikawaCause {
  id                String                @id @default(uuid())
  sessionId         String
  session           ActionAnalysisSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  category          String
  title             String?
  description       String
  priority          ActionPriority        @default(MEDIUM)
  impact            Int                   @default(3)
  probability       Int                   @default(3)
  status            String                @default("DRAFT")
  evidence          String?
  responsibleUserId String?
  dueDate           DateTime?
  positionX         Float?
  positionY         Float?
  orderIndex        Int                   @default(0)
  tags              Json?
  isAiSuggested     Boolean               @default(false)
  convertedToTaskId String?
  likelyRootCause   Boolean               @default(false)
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  @@index([sessionId])
  @@index([responsibleUserId])
  @@index([convertedToTaskId])
}

model ActionMaspStep {
  id                String                @id @default(uuid())
  sessionId         String
  session           ActionAnalysisSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  step              Int
  title             String
  description       String?
  responsibleUserId String?
  dueDate           DateTime?
  evidence          String?
  comments          String?
  status            ActionStepStatus      @default(PENDING)
  validated         Boolean               @default(false)
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  @@unique([sessionId, step])
}

model ActionPdcaStep {
  id                String                @id @default(uuid())
  sessionId         String
  session           ActionAnalysisSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  phase             String
  description       String?
  responsibleUserId String?
  dueDate           DateTime?
  evidence          String?
  comments          String?
  status            ActionStepStatus      @default(PENDING)
  validated         Boolean               @default(false)
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  @@unique([sessionId, phase])
}

model ActionFiveW2H {
  id            String                @id @default(uuid())
  sessionId     String                @unique
  session       ActionAnalysisSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  what          String?
  why           String?
  where         String?
  when          DateTime?
  who           String?
  how           String?
  howMuch       Float?
  reviewNotes   String?
  completeScore Int                   @default(0)
  updatedAt     DateTime              @updatedAt
}

model ActionAiSuggestion {
  id             String                   @id @default(uuid())
  actionId       String
  action         ActionPlan               @relation(fields: [actionId], references: [id], onDelete: Cascade)
  sessionId      String?
  suggestionType String
  title          String
  content        String
  context        Json?
  status         ActionAiSuggestionStatus @default(PENDING)
  createdAt      DateTime                 @default(now())
  decidedAt      DateTime?
  decidedById    String?

  @@index([actionId, createdAt])
  @@index([status])
}

// =====================================================
// Projetos e cronograma
// =====================================================

model Project {
  id          String        @id @default(uuid())
  companyId   String
  company     Company       @relation(fields: [companyId], references: [id])
  indicatorId String?
  indicator   Indicator?    @relation("ProjectIndicator", fields: [indicatorId], references: [id])
  name        String
  description String?
  status      ProjectStatus @default(PLANNED)
  startsAt    DateTime?
  endsAt      DateTime?
  responsible String?
  budget      Float?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?

  milestones ProjectMilestone[]
  tasks      ProjectTask[]
  risks      RiskRegister[]     @relation("RiskProject")

  @@index([companyId])
  @@index([indicatorId])
}

model ProjectMilestone {
  id        String   @id @default(uuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name      String
  dueDate   DateTime
  done      Boolean  @default(false)
}

model ProjectTask {
  id           String        @id @default(uuid())
  projectId    String
  project      Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name         String
  startDate    DateTime?
  endDate      DateTime?
  progress     Float         @default(0)
  responsible  String?
  dependencyId String?
  dependency   ProjectTask?  @relation("TaskDep", fields: [dependencyId], references: [id])
  dependents   ProjectTask[] @relation("TaskDep")
  position     Int           @default(0)
}

model RiskRegister {
  id                 String      @id @default(uuid())
  companyId          String
  company            Company     @relation(fields: [companyId], references: [id])
  orgNodeId          String?
  orgNode            OrgNode?    @relation("RiskOwnerNode", fields: [orgNodeId], references: [id])
  indicatorId        String?
  indicator          Indicator?  @relation("RiskIndicator", fields: [indicatorId], references: [id])
  projectId          String?
  project            Project?    @relation("RiskProject", fields: [projectId], references: [id])
  mitigationActionId String?
  mitigationAction   ActionPlan? @relation("RiskMitigationAction", fields: [mitigationActionId], references: [id])
  responsibleUserId  String?
  responsibleUser    User?       @relation("RiskResponsible", fields: [responsibleUserId], references: [id])
  createdById        String?
  createdBy          User?       @relation("RiskCreatedBy", fields: [createdById], references: [id])

  title           String
  description     String?
  category        RiskCategory @default(OPERATIONAL)
  status          RiskStatus   @default(IDENTIFIED)
  probability     Int          @default(3)
  impact          Int          @default(3)
  mitigationPlan  String?
  contingencyPlan String?
  dueDate         DateTime?
  identifiedAt    DateTime     @default(now())
  closedAt        DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  deletedAt       DateTime?

  @@index([companyId])
  @@index([companyId, status])
  @@index([category])
  @@index([orgNodeId])
  @@index([indicatorId])
  @@index([projectId])
  @@index([mitigationActionId])
  @@index([responsibleUserId])
  @@index([dueDate])
}

// =====================================================
// Nao conformidades (CAPA)
// =====================================================

enum NonConformityStatus {
  OPEN // registrada
  TRIAGE // triagem / classificacao
  ANALYSIS // analise de causa raiz
  ACTION // acao corretiva em andamento
  VERIFICATION // verificacao de eficacia
  CLOSED // encerrada
  CANCELLED
}

enum NonConformitySource {
  INDICATOR
  AUDIT
  PROCESS
  CUSTOMER
  SUPPLIER
  PROJECT
  CHECKLIST
  INSPECTION
  DOCUMENT
  MANUAL
  OTHER
}

enum NonConformitySeverity {
  MINOR
  MAJOR
  CRITICAL
}

model NonConformity {
  id                 String      @id @default(uuid())
  companyId          String
  company            Company     @relation(fields: [companyId], references: [id])
  number             Int // sequencial por empresa
  orgNodeId          String?
  orgNode            OrgNode?    @relation("NcOwnerNode", fields: [orgNodeId], references: [id])
  indicatorId        String?
  indicator          Indicator?  @relation("NcIndicator", fields: [indicatorId], references: [id])
  deviationId        String?
  deviation          Deviation?  @relation("NcDeviation", fields: [deviationId], references: [id])
  correctiveActionId String?
  correctiveAction   ActionPlan? @relation("NcCorrectiveAction", fields: [correctiveActionId], references: [id])
  responsibleUserId  String?
  responsibleUser    User?       @relation("NcResponsible", fields: [responsibleUserId], references: [id])
  createdById        String?
  createdBy          User?       @relation("NcCreatedBy", fields: [createdById], references: [id])

  title              String
  description        String?
  source             NonConformitySource   @default(INDICATOR)
  severity           NonConformitySeverity @default(MAJOR)
  status             NonConformityStatus   @default(OPEN)
  immediateAction    String? // contencao / disposicao imediata
  rootCause          String?
  correctivePlan     String?
  effectivenessCheck String? // verificacao de eficacia
  effectivenessOk    Boolean?
  dueDate            DateTime?
  identifiedAt       DateTime              @default(now())
  closedAt           DateTime?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  deletedAt          DateTime?

  auditFindings AuditFinding[] @relation("FindingNc")

  @@unique([companyId, number])
  @@index([companyId])
  @@index([companyId, status])
  @@index([source])
  @@index([orgNodeId])
  @@index([indicatorId])
  @@index([deviationId])
  @@index([correctiveActionId])
  @@index([responsibleUserId])
  @@index([dueDate])
}

// =====================================================
// Gestao documental
// =====================================================

enum DocumentType {
  POLICY
  PROCEDURE
  INSTRUCTION
  MANUAL
  FORM
  TEMPLATE
  RECORD
  INTERNAL_STANDARD
  GUIDELINE
  REGULATION
  FLOWCHART
  PLAN
  REPORT
  CHECKLIST
  TECHNICAL_SPECIFICATION
  EXTERNAL
  OTHER
}

enum DocumentStatus {
  DRAFT // rascunho
  IN_DEVELOPMENT // em elaboracao
  WAITING_REVIEW // aguardando revisao
  REVIEW // legado: em revisao
  IN_REVIEW // em revisao
  ADJUSTMENTS_REQUESTED // ajustes solicitados
  REVIEWED // revisado
  WAITING_APPROVAL // aguardando aprovacao
  IN_APPROVAL // em aprovacao
  REJECTED // reprovado
  APPROVED // aprovado
  SCHEDULED_PUBLICATION // agendado para publicacao
  PUBLISHED // publicado / vigente
  NEAR_EXPIRATION // proximo do vencimento
  EXPIRED // vencido
  PERIODIC_REVIEW // em revisao periodica
  REPLACED // substituido
  OBSOLETE // obsoleto
  ARCHIVED // arquivado
  CANCELLED // cancelado
}

enum DocumentFileKind {
  DOCX
  PDF
  TEMPLATE
  ATTACHMENT
  EVIDENCE
  IMAGE
  TEMPORARY
}

enum DocumentApprovalDecision {
  PENDING
  APPROVED
  REJECTED
  ADJUSTMENTS_REQUESTED
  DELEGATED
}

model Document {
  id             String     @id @default(uuid())
  companyId      String
  company        Company    @relation(fields: [companyId], references: [id])
  number         Int // sequencial por empresa
  code           String? // codigo do documento (ex.: POL-001)
  orgNodeId      String?
  orgNode        OrgNode?   @relation("DocOrgNode", fields: [orgNodeId], references: [id])
  indicatorId    String?
  indicator      Indicator? @relation("DocIndicator", fields: [indicatorId], references: [id])
  ownerUserId    String?
  owner          User?      @relation("DocOwner", fields: [ownerUserId], references: [id])
  approverUserId String?
  approver       User?      @relation("DocApprover", fields: [approverUserId], references: [id])
  createdById    String?
  createdBy      User?      @relation("DocCreatedBy", fields: [createdById], references: [id])

  title                String
  description          String?
  type                 DocumentType   @default(PROCEDURE)
  status               DocumentStatus @default(DRAFT)
  version              Int            @default(1)
  content              String? // corpo do documento (markdown) p/ documentos nativos
  externalUrl          String? // referencia para arquivo externo (drive/erp)
  changeNote           String?
  validFrom            DateTime?
  validUntil           DateTime? // vencimento / proxima revisao
  reviewIntervalMonths Int?
  approvedAt           DateTime?
  publishedAt          DateTime?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  deletedAt            DateTime?

  versions            DocumentVersion[]
  files               DocumentFile[]
  statusHistory       DocumentStatusHistory[]
  workflows           DocumentWorkflow[]
  workflowSteps       DocumentWorkflowStep[]
  approvals           DocumentApproval[]
  reviewRequests      DocumentReviewRequest[]
  editRequests        DocumentEditRequest[]
  comments            DocumentComment[]
  relations           DocumentRelation[]
  permissions         DocumentPermission[]
  distributions       DocumentDistribution[]
  readConfirmations   DocumentReadConfirmation[]
  downloadLogs        DocumentDownloadLog[]
  viewLogs            DocumentViewLog[]
  shareLinks          DocumentShareLink[]
  notifications       DocumentNotification[]
  auditLogs           DocumentAuditLog[]
  externalMetadata    DocumentExternalMetadata?
  editorSessions      DocumentEditorSession[]
  autosaveCheckpoints DocumentAutosaveCheckpoint[]
  tagRelations        DocumentTagRelation[]

  @@unique([companyId, number])
  @@index([companyId])
  @@index([companyId, status])
  @@index([type])
  @@index([orgNodeId])
  @@index([indicatorId])
  @@index([ownerUserId])
  @@index([validUntil])
}

model DocumentTypeConfig {
  id                     String       @id @default(uuid())
  companyId              String
  name                   String
  sigla                  String
  description            String?
  category               DocumentType @default(PROCEDURE)
  prefix                 String
  codePattern            String       @default("{{PREFIX}}-{{SEQ}}")
  sequenceScope          String       @default("TYPE")
  digits                 Int          @default(3)
  nextNumber             Int          @default(1)
  resetYearly            Boolean      @default(false)
  currentYear            Int?
  defaultTemplateId      String?
  defaultValidityDays    Int?
  alertDays              Int          @default(30)
  requiresPeriodicReview Boolean      @default(true)
  editable               Boolean      @default(true)
  allowManualCode        Boolean      @default(false)
  createOnlyByRequest    Boolean      @default(false)
  approvalFlow           Json?
  customFields           Json?
  active                 Boolean      @default(true)
  createdById            String?
  updatedById            String?
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt
  deletedAt              DateTime?

  @@unique([companyId, sigla])
  @@index([companyId, active])
  @@index([companyId, prefix])
  @@map("document_types")
}

model DocumentCodeRule {
  id            String    @id @default(uuid())
  companyId     String
  typeConfigId  String?
  name          String
  prefix        String
  pattern       String    @default("{{PREFIX}}-{{SEQ}}")
  sequenceScope String    @default("TYPE")
  digits        Int       @default(3)
  nextNumber    Int       @default(1)
  resetYearly   Boolean   @default(false)
  currentYear   Int?
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  @@unique([companyId, name])
  @@index([companyId, active])
  @@index([typeConfigId])
  @@map("document_code_rules")
}

model DocumentTemplate {
  id           String    @id @default(uuid())
  companyId    String
  typeConfigId String?
  name         String
  description  String?
  version      Int       @default(1)
  isDefault    Boolean   @default(false)
  active       Boolean   @default(true)
  storageKey   String?
  fileName     String?
  mimeType     String?
  sizeBytes    Int?
  hashSha256   String?
  content      String?
  placeholders Json?
  createdById  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  @@index([companyId, active])
  @@index([typeConfigId, isDefault])
  @@map("document_templates")
}

model DocumentVersion {
  id              String         @id @default(uuid())
  companyId       String
  documentId      String
  document        Document       @relation(fields: [documentId], references: [id], onDelete: Cascade)
  revisionNumber  Int
  versionLabel    String
  status          DocumentStatus @default(DRAFT)
  changeReason    String?
  changeSummary   String?
  docxFileId      String?
  pdfFileId       String?
  publicationDate DateTime?
  expirationDate  DateTime?
  createdById     String?
  publishedById   String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  deletedAt       DateTime?

  @@unique([documentId, revisionNumber])
  @@index([companyId, status])
  @@index([documentId, createdAt])
  @@map("document_versions")
}

model DocumentFile {
  id              String           @id @default(uuid())
  companyId       String
  documentId      String?
  document        Document?        @relation(fields: [documentId], references: [id], onDelete: Cascade)
  versionId       String?
  templateId      String?
  kind            DocumentFileKind
  storageProvider String           @default("LOCAL")
  storageKey      String
  fileName        String
  mimeType        String?
  sizeBytes       Int?
  hashSha256      String?
  contentText     String?
  protected       Boolean          @default(false)
  createdById     String?
  createdAt       DateTime         @default(now())
  deletedAt       DateTime?

  @@index([companyId, kind])
  @@index([documentId, kind])
  @@index([versionId])
  @@index([storageKey])
  @@map("document_files")
}

model DocumentStatusHistory {
  id         String   @id @default(uuid())
  companyId  String
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  versionId  String?
  userId     String?
  statusFrom String?
  statusTo   String
  comment    String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([companyId, createdAt])
  @@index([documentId, createdAt])
  @@map("document_status_history")
}

model DocumentWorkflow {
  id           String    @id @default(uuid())
  companyId    String
  documentId   String?
  document     Document? @relation(fields: [documentId], references: [id], onDelete: Cascade)
  typeConfigId String?
  name         String
  mode         String    @default("SEQUENTIAL")
  active       Boolean   @default(true)
  steps        Json?
  createdById  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  @@index([companyId, active])
  @@index([documentId])
  @@map("document_workflows")
}

model DocumentWorkflowStep {
  id         String    @id @default(uuid())
  companyId  String
  workflowId String?
  documentId String
  document   Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)
  versionId  String?
  stepOrder  Int       @default(1)
  role       String?
  userId     String?
  dueAt      DateTime?
  decision   String    @default("PENDING")
  comment    String?
  decidedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([companyId, decision])
  @@index([documentId, stepOrder])
  @@map("document_workflow_steps")
}

model DocumentApproval {
  id             String                   @id @default(uuid())
  companyId      String
  documentId     String
  document       Document                 @relation(fields: [documentId], references: [id], onDelete: Cascade)
  versionId      String?
  approverUserId String?
  approverRole   String?
  approvalOrder  Int                      @default(1)
  decision       DocumentApprovalDecision @default(PENDING)
  statusFrom     String?
  statusTo       String?
  comment        String?
  ip             String?
  sessionId      String?
  evidenceFileId String?
  decidedAt      DateTime?
  createdAt      DateTime                 @default(now())

  @@index([companyId, decision])
  @@index([documentId, approvalOrder])
  @@index([approverUserId, decision])
  @@map("document_approvals")
}

model DocumentReviewRequest {
  id             String    @id @default(uuid())
  companyId      String
  documentId     String
  document       Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)
  versionId      String?
  reviewerUserId String?
  authorUserId   String?
  status         String    @default("OPEN")
  comment        String
  dueAt          DateTime?
  answeredAt     DateTime?
  answer         String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([companyId, status])
  @@index([documentId, createdAt])
  @@index([reviewerUserId, status])
  @@map("document_review_requests")
}

model DocumentEditRequest {
  id              String   @id @default(uuid())
  companyId       String
  company         Company  @relation("DocumentEditRequestCompany", fields: [companyId], references: [id])
  documentId      String
  document        Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  versionId       String?
  requesterUserId String
  requester       User     @relation("DocumentEditRequester", fields: [requesterUserId], references: [id])
  operatorUserId  String?
  operator        User?    @relation("DocumentEditOperator", fields: [operatorUserId], references: [id])
  decidedById     String?
  decidedBy       User?    @relation("DocumentEditDecider", fields: [decidedById], references: [id])
  status          String   @default("REQUESTED") // REQUESTED | APPROVED | REJECTED | IN_PROGRESS | COMPLETED | CANCELLED
  reason          String?
  decisionNote    String?
  approvedAt      DateTime?
  rejectedAt      DateTime?
  completedAt     DateTime?
  expiresAt       DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([companyId, status])
  @@index([documentId, status])
  @@index([requesterUserId, status])
  @@index([operatorUserId, status])
  @@map("document_edit_requests")
}

model DocumentComment {
  id         String    @id @default(uuid())
  companyId  String
  documentId String
  document   Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)
  versionId  String?
  parentId   String?
  userId     String?
  body       String
  resolvedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([companyId, createdAt])
  @@index([documentId, createdAt])
  @@map("document_comments")
}

model DocumentCommentMention {
  id        String   @id @default(uuid())
  commentId String
  userId    String
  createdAt DateTime @default(now())

  @@unique([commentId, userId])
  @@map("document_comment_mentions")
}

model DocumentRelation {
  id                String   @id @default(uuid())
  companyId         String
  documentId        String
  document          Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  relatedEntityType String
  relatedEntityId   String
  relationKind      String   @default("RELATED")
  createdById       String?
  createdAt         DateTime @default(now())

  @@unique([documentId, relatedEntityType, relatedEntityId, relationKind])
  @@index([companyId, relatedEntityType, relatedEntityId])
  @@map("document_relations")
}

model DocumentPermission {
  id           String    @id @default(uuid())
  companyId    String
  documentId   String?
  document     Document? @relation(fields: [documentId], references: [id], onDelete: Cascade)
  typeConfigId String?
  userId       String?
  orgNodeId    String?
  groupId      String?
  permission   String
  allowed      Boolean   @default(true)
  createdAt    DateTime  @default(now())

  @@index([companyId, permission])
  @@index([documentId])
  @@index([userId])
  @@map("document_permissions")
}

model DocumentAccessGroup {
  id          String    @id @default(uuid())
  companyId   String
  name        String
  description String?
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  @@unique([companyId, name])
  @@map("document_access_groups")
}

model DocumentAccessGroupUser {
  id        String   @id @default(uuid())
  groupId   String
  userId    String
  createdAt DateTime @default(now())

  @@unique([groupId, userId])
  @@map("document_access_group_users")
}

model DocumentDistribution {
  id                  String    @id @default(uuid())
  companyId           String
  documentId          String
  document            Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)
  versionId           String?
  userId              String?
  orgNodeId           String?
  groupId             String?
  dueAt               DateTime?
  requireConfirmation Boolean   @default(true)
  requireQuiz         Boolean   @default(false)
  trainingRef         String?
  sentAt              DateTime  @default(now())
  createdById         String?

  @@index([companyId, dueAt])
  @@index([documentId])
  @@index([userId])
