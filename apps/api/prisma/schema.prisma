// Gestao de Premio - Fase 5: Integracao com a Folha
// Lote de saida (rubrica/verba) + retorno conciliavel. Sem acoplamento a um
// unico canal: gera arquivo (CSV/XLSX), interface ou API; retorno por importacao.
// =====================================================

enum PrizePayrollBatchStatus {
  DRAFT
  GENERATED
  SENT
  RETURNED
  RECONCILED
  CANCELLED
}

enum PrizePayrollItemStatus {
  PENDING
  SENT
