// =====================================================
// Organizacao & Tenant
// =====================================================

model Company {
  id        String   @id @default(uuid())
  name      String
  tradeName String?
  cnpj      String?  @unique
  logoUrl   String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  branches            Branch[]
  users               User[]
  orgNodes            OrgNode[]
  strategicMaps       StrategicMap[]
  indicators          Indicator[]
  okrCycles           OKRCycle[]
  deviations          Deviation[]
  actions             ActionPlan[]
  projects            Project[]
  meetings            Meeting[]
  imports             ImportJob[]
  auditLogs           AuditLog[]
  notifications       Notification[]
  appSettings         AppSetting[]
  accessProfiles      AccessProfile[]
  parameterCategories ParameterCategory[]
  parameterItems      ParameterItem[]
  traceabilityEvents  TraceabilityEvent[]
  statusHistories     StatusHistory[]
  relationshipMaps    RelationshipMap[]
  treatmentCases      TreatmentCase[]
  orgJobs             OrgJob[]
  orgEmployees        OrgEmployee[]
  orgJobCareerPaths   OrgJobCareerPath[]
  orgJobApprovalRequests OrgJobApprovalRequest[]
  emailLogs           EmailLog[]
  calendarInvites     CalendarInvite[]
  workPeriods         WorkPeriod[]
  closedMonths        ClosedMonth[]
}

model WorkPeriod {
  id          String           @id @default(uuid())
  companyId   String
  company     Company          @relation(fields: [companyId], references: [id])
  year        Int
  name        String
  startsAt    DateTime
  endsAt      DateTime
  status      WorkPeriodStatus @default(OPEN)
  isCurrent   Boolean          @default(false)
  closedAt    DateTime?
  closedById  String?
  createdById String?
  updatedById String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  deletedAt   DateTime?

  @@unique([companyId, year])
  @@index([companyId, isCurrent])
  @@index([companyId, status])
}

model Branch {
  id        String   @id @default(uuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  name      String
  code      String?
  city      String?
  state     String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  orgNodes OrgNode[]
  users    User[]
  actions  ActionPlan[]

  @@index([companyId])
}

model OrgNode {
  id                  String        @id @default(uuid())
  companyId           String
  company             Company       @relation(fields: [companyId], references: [id])
  branchId            String?
  branch              Branch?       @relation(fields: [branchId], references: [id])
  parentId            String?
  parent              OrgNode?      @relation("OrgNodeChildren", fields: [parentId], references: [id])
  children            OrgNode[]     @relation("OrgNodeChildren")

  name                String
  code                String?
  type                OrgNodeType
  description         String?
  color               String?
  icon                String?
  active              Boolean       @default(true)
  position            Int           @default(0)

  // Rastreio de origem para integracao/migracao de sistemas legados
  // externalId  = chave primaria no sistema de origem (ex.: BSC "18448")
  // externalSource = identificador da origem (ex.: "BSC 1.43")
  externalId          String?
  externalSource      String?

  responsibleUserId   String?
  responsibleUser     User?         @relation("OrgNodeResponsible", fields: [responsibleUserId], references: [id])

  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  deletedAt           DateTime?

  indicatorsOwned     Indicator[]   @relation("IndicatorOwnerNode")
  guidelineIndicators  Indicator[]   @relation("IndicatorGuidelineNode")
  defaultForUsers     User[]        @relation("UserDefaultNode")
  actions             ActionPlan[]  @relation("ActionOwnerNode")
  strategicObjectives StrategicObjective[] @relation("StrategicObjectiveOwnerNode")
  strategicObjectiveLinks StrategicObjectiveOrgNode[]
  orgEmployees        OrgEmployee[]

  @@unique([companyId, externalSource, externalId])
  @@index([companyId])
  @@index([parentId])
  @@index([branchId])
  @@index([externalSource, externalId])
}

// =====================================================
// Usuarios, Roles e Permissoes
// =====================================================

model User {
  id            String        @id @default(uuid())
  companyId     String
  company       Company       @relation(fields: [companyId], references: [id])
  email         String        @unique
  passwordHash  String
  name          String
  jobTitle      String?
  phone         String?
  avatarUrl     String?
  role          UserRoleEnum  @default(COLLABORATOR)
  status        UserAccessStatus @default(ACTIVE)
  active        Boolean       @default(true)
  lastLoginAt   DateTime?
  passwordResetRequired Boolean @default(false)
  invitedAt     DateTime?
  blockedAt     DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  deletedAt     DateTime?

  branchId      String?
  branch        Branch?       @relation(fields: [branchId], references: [id])
  accessProfileId String?
  accessProfile AccessProfile? @relation(fields: [accessProfileId], references: [id])
  defaultNodeId String?
  defaultNode   OrgNode?      @relation("UserDefaultNode", fields: [defaultNodeId], references: [id])

  responsibleNodes     OrgNode[]            @relation("OrgNodeResponsible")
  indicatorsResponsible Indicator[]         @relation("IndicatorResponsible")
  indicatorsFeeder      Indicator[]         @relation("IndicatorFeeder")
  resultsCreated        IndicatorResult[]   @relation("ResultCreatedBy")
  deviationsResponsible Deviation[]         @relation("DeviationResponsible")
  actionsResponsible    ActionPlan[]        @relation("ActionResponsible")
  actionsCreated        ActionPlan[]        @relation("ActionCreatedBy")
  actionTasksAssigned   ActionTask[]        @relation("ActionTaskAssignee")
  careerApprovalsRequested OrgJobApprovalRequest[] @relation("CareerApprovalRequester")
  careerApprovalsToReview  OrgJobApprovalRequest[] @relation("CareerApprovalApprover")
  meetingParticipations MeetingParticipant[]
  comments              Comment[]
  notifications         Notification[]
  refreshTokens         RefreshToken[]
  auditLogs             AuditLog[]
  permissions           UserPermission[]
  traceabilityEvents    TraceabilityEvent[]  @relation("TraceabilityEventUser")
  statusHistories       StatusHistory[]      @relation("StatusHistoryUser")
  mapLayouts            MapLayout[]          @relation("MapLayoutUpdatedBy")
  treatmentsCreated     TreatmentCase[]      @relation("TreatmentCreatedBy")
  meetingsResponsible   Meeting[]            @relation("MeetingResponsible")
  strategicMapsCreated  StrategicMap[]       @relation("StrategicMapCreatedBy")
  strategicMapsUpdated  StrategicMap[]       @relation("StrategicMapUpdatedBy")
  perspectivesCreated   Perspective[]        @relation("PerspectiveCreatedBy")
  perspectivesUpdated   Perspective[]        @relation("PerspectiveUpdatedBy")
  objectivesResponsible StrategicObjective[] @relation("StrategicObjectiveResponsible")
  objectivesCreated     StrategicObjective[] @relation("StrategicObjectiveCreatedBy")
  objectivesUpdated     StrategicObjective[] @relation("StrategicObjectiveUpdatedBy")
  strategyVersions      StrategicMapVersion[] @relation("StrategicVersionCreatedBy")
  closedMonthsClosed    ClosedMonth[]        @relation("ClosedMonthClosedBy")
  closedMonthsReopened  ClosedMonth[]        @relation("ClosedMonthReopenedBy")

  @@index([companyId])
  @@index([branchId])
  @@index([accessProfileId])
  @@index([role])
  @@index([status])
}

model Permission {
  id          String           @id @default(uuid())
  key         String           @unique // ex.: "indicators:create"
  description String
  module      String
  action      String
  users       UserPermission[]
  profiles    ProfilePermission[]
}

model UserPermission {
  userId       String
  permissionId String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  grantedAt    DateTime   @default(now())

  @@id([userId, permissionId])
}

model AccessProfile {
  id          String            @id @default(uuid())
  companyId   String?
  company     Company?          @relation(fields: [companyId], references: [id])
  code        String
  name        String
  description String?
  role        UserRoleEnum?
  status      AdminRecordStatus @default(ACTIVE)
  system      Boolean           @default(false)
  createdById String?
  updatedById String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  deletedAt   DateTime?

  users       User[]
  permissions ProfilePermission[]

  @@unique([companyId, code])
  @@index([companyId, status])
}

model ProfilePermission {
  profileId    String
  permissionId String
  profile      AccessProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  permission   Permission    @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  grantedAt    DateTime      @default(now())

  @@id([profileId, permissionId])
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())
  userAgent String?
  ip        String?

  @@index([userId])
}

// =====================================================
// Mapa estrategico / BSC
// =====================================================

model StrategicMap {
  id          String              @id @default(uuid())
  companyId   String
  company     Company             @relation(fields: [companyId], references: [id])
  name        String
  description String?
  startsAt    DateTime
  endsAt      DateTime
  active      Boolean             @default(true)
  publishedVersionId String?
  createdById String?
  createdBy   User?               @relation("StrategicMapCreatedBy", fields: [createdById], references: [id])
  updatedById String?
  updatedBy   User?               @relation("StrategicMapUpdatedBy", fields: [updatedById], references: [id])
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  deletedAt   DateTime?

  perspectives Perspective[]
  objectives   StrategicObjective[]
  versions     StrategicMapVersion[]

  @@index([companyId])
  @@index([publishedVersionId])
}

model Perspective {
  id          String           @id @default(uuid())
  mapId       String
  map         StrategicMap     @relation(fields: [mapId], references: [id], onDelete: Cascade)
  kind        PerspectiveKind
  name        String
  description String?
  color       String?
  icon        String?
  position    Int              @default(0)
  positionX   Float            @default(0)
  positionY   Float            @default(0)
  width       Float            @default(1320)
  height      Float            @default(230)
  active      Boolean          @default(true)
  createdById String?
  createdBy   User?            @relation("PerspectiveCreatedBy", fields: [createdById], references: [id])
  updatedById String?
  updatedBy   User?            @relation("PerspectiveUpdatedBy", fields: [updatedById], references: [id])
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  deletedAt   DateTime?

  objectives  StrategicObjective[]

  @@index([mapId])
  @@index([active])
}

model StrategicObjective {
  id            String              @id @default(uuid())
  mapId         String
  map           StrategicMap        @relation(fields: [mapId], references: [id], onDelete: Cascade)
  perspectiveId String
  perspective   Perspective         @relation(fields: [perspectiveId], references: [id])

  name          String
  description   String?
  responsible   String?
  responsibleUserId String?
  responsibleUser   User?               @relation("StrategicObjectiveResponsible", fields: [responsibleUserId], references: [id])
  ownerNodeId    String?
  ownerNode      OrgNode?               @relation("StrategicObjectiveOwnerNode", fields: [ownerNodeId], references: [id])
  weight        Float               @default(1)
  status        ObjectiveStatus     @default(PLANNED)
  priority      Int                 @default(3)
  position      Int                 @default(0)
  positionX     Float               @default(0)
  positionY     Float               @default(0)
  width         Float               @default(260)
  height        Float               @default(150)
  active        Boolean             @default(true)
  createdById   String?
  createdBy     User?               @relation("StrategicObjectiveCreatedBy", fields: [createdById], references: [id])
  updatedById   String?
  updatedBy     User?               @relation("StrategicObjectiveUpdatedBy", fields: [updatedById], references: [id])

  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  deletedAt     DateTime?

  indicators    Indicator[]         @relation("IndicatorStrategicObjective")
  indicatorLinks StrategicObjectiveIndicator[]
  orgNodeLinks   StrategicObjectiveOrgNode[]
  actionPlans    ActionPlan[]       @relation("ActionStrategicObjective")
  okrs          OKRObjective[]
  outRelations  ObjectiveRelation[] @relation("ObjFrom")
  inRelations   ObjectiveRelation[] @relation("ObjTo")

  @@index([mapId])
  @@index([perspectiveId])
  @@index([responsibleUserId])
  @@index([ownerNodeId])
  @@index([active])
}

model ObjectiveRelation {
  id     String              @id @default(uuid())
  fromId String
  toId   String
  from   StrategicObjective  @relation("ObjFrom", fields: [fromId], references: [id], onDelete: Cascade)
  to     StrategicObjective  @relation("ObjTo", fields: [toId], references: [id], onDelete: Cascade)
  weight Float               @default(1)
  kind   String              @default("impacta")
  label  String?
  description String?
  active Boolean             @default(true)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  deletedAt DateTime?

  @@unique([fromId, toId])
  @@index([active])
}

model StrategicObjectiveIndicator {
  id          String              @id @default(uuid())
  objectiveId String
  objective   StrategicObjective  @relation(fields: [objectiveId], references: [id], onDelete: Cascade)
  indicatorId String
  indicator   Indicator           @relation(fields: [indicatorId], references: [id], onDelete: Cascade)
  createdById String?
  createdAt   DateTime            @default(now())
  deletedAt   DateTime?

  @@unique([objectiveId, indicatorId])
  @@index([indicatorId])
}

model StrategicObjectiveOrgNode {
  id          String              @id @default(uuid())
  objectiveId String
  objective   StrategicObjective  @relation(fields: [objectiveId], references: [id], onDelete: Cascade)
  orgNodeId   String
  orgNode     OrgNode             @relation(fields: [orgNodeId], references: [id], onDelete: Cascade)
  kind        String              @default("responsavel")
  createdById String?
  createdAt   DateTime            @default(now())
  deletedAt   DateTime?

  @@unique([objectiveId, orgNodeId, kind])
  @@index([orgNodeId])
}

model StrategicMapVersion {
  id          String              @id @default(uuid())
  mapId       String
  map         StrategicMap        @relation(fields: [mapId], references: [id], onDelete: Cascade)
  version     Int
  title       String
  description String?
  status      String              @default("DRAFT")
  snapshot    Json
  createdById String?
  createdBy   User?               @relation("StrategicVersionCreatedBy", fields: [createdById], references: [id])
  createdAt   DateTime            @default(now())
  publishedAt DateTime?

  @@unique([mapId, version])
  @@index([mapId, status])
}

// =====================================================
// OKRs
// =====================================================

model OKRCycle {
  id        String   @id @default(uuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  name      String
  startsAt  DateTime
  endsAt    DateTime
  active    Boolean  @default(true)

  objectives OKRObjective[]

  @@index([companyId])
}

model OKRObjective {
  id               String       @id @default(uuid())
  cycleId          String
  cycle            OKRCycle     @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  strategicObjId   String?
  strategicObj     StrategicObjective? @relation(fields: [strategicObjId], references: [id])
  parentId         String?
  parent           OKRObjective?  @relation("OKRObjectiveChildren", fields: [parentId], references: [id])
  children         OKRObjective[] @relation("OKRObjectiveChildren")
  name             String
  description      String?
  ownerName        String?
  team             String?
  weight           Float        @default(1)
  confidence       Float        @default(0.5) // 0..1
  status           ObjectiveStatus @default(PLANNED)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  deletedAt        DateTime?

  keyResults       KeyResult[]
  checkins         OKRCheckin[]

  @@index([cycleId])
  @@index([parentId])
}

model KeyResult {
  id           String       @id @default(uuid())
  objectiveId  String
  objective    OKRObjective @relation(fields: [objectiveId], references: [id], onDelete: Cascade)
  metric       String
  unit         IndicatorUnit @default(QUANTITY)
  startValue   Float
  currentValue Float
  targetValue  Float
  direction    Direction    @default(HIGHER_BETTER)
  weight       Float        @default(1)
  responsible  String?
  updatedAt    DateTime     @updatedAt
  createdAt    DateTime     @default(now())

  @@index([objectiveId])
}

model OKRCheckin {
  id          String       @id @default(uuid())
  objectiveId String
  objective   OKRObjective @relation(fields: [objectiveId], references: [id], onDelete: Cascade)
  weekRef     String       // YYYY-Www
  confidence  Float
  progress    Float        // 0..1
  note        String?
  createdAt   DateTime     @default(now())

  @@index([objectiveId])
}

// =====================================================
// Indicadores / KPIs
// =====================================================

model Indicator {
  id                  String              @id @default(uuid())
  companyId           String
  company             Company             @relation(fields: [companyId], references: [id])
  ownerNodeId         String
  ownerNode           OrgNode             @relation("IndicatorOwnerNode", fields: [ownerNodeId], references: [id])
  guidelineNodeId     String?
  guidelineNode       OrgNode?            @relation("IndicatorGuidelineNode", fields: [guidelineNodeId], references: [id])
  responsibleUserId   String?
  responsibleUser     User?               @relation("IndicatorResponsible", fields: [responsibleUserId], references: [id])
  feederUserId        String?
  feederUser          User?               @relation("IndicatorFeeder", fields: [feederUserId], references: [id])
  strategicObjectiveId String?
  strategicObjective  StrategicObjective? @relation("IndicatorStrategicObjective", fields: [strategicObjectiveId], references: [id])

  name                String
  code                String?
  description         String?
  type                IndicatorType       @default(OPERATIONAL)
  category            String?
  unit                IndicatorUnit       @default(PERCENT)
  unitLabel           String?
  periodicity         Periodicity         @default(MONTHLY)
  direction           Direction           @default(HIGHER_BETTER)
  formula             String?
  source              String?
  feedKind            FeedKind            @default(MANUAL)
  status              IndicatorStatus     @default(ACTIVE)
  weight              Float               @default(1)
  yellowToleranceP    Float               @default(10)

  // Rastreio de origem para integracao/migracao de sistemas legados
  // externalId  = chave primaria no sistema de origem (ex.: BSC "18915")
  // externalSource = identificador da origem (ex.: "BSC 1.43")
  externalId          String?
  externalSource      String?

  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  deletedAt           DateTime?

  targets             IndicatorTarget[]
  results             IndicatorResult[]
  deviations          Deviation[]
  traceabilityEvents  TraceabilityEvent[]
  meetings            Meeting[]          @relation("MeetingIndicator")
  actions             ActionPlan[]       @relation("ActionIndicator")
  treatmentCases      TreatmentCase[]
  childRelations      IndicatorTreeRelation[] @relation("RelChild")
  parentRelations     IndicatorTreeRelation[] @relation("RelParent")
  strategicObjectiveLinks StrategicObjectiveIndicator[]
  projects            Project[]              @relation("ProjectIndicator")

  @@index([companyId])
  @@index([ownerNodeId])
  @@index([guidelineNodeId])
  @@index([type])
  @@index([status])
  @@unique([companyId, code])
  @@unique([companyId, externalSource, externalId])
  @@index([externalSource, externalId])
}

model IndicatorTarget {
  id          String     @id @default(uuid())
  indicatorId String
  indicator   Indicator  @relation(fields: [indicatorId], references: [id], onDelete: Cascade)
  periodRef   String     // YYYY-MM, YYYY, etc.
  target      Float
  lowerBound  Float?
  upperBound  Float?
  weight      Float      @default(1)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@unique([indicatorId, periodRef])
  @@index([indicatorId])
}

model IndicatorResult {
  id              String        @id @default(uuid())
  indicatorId     String
  indicator       Indicator     @relation(fields: [indicatorId], references: [id], onDelete: Cascade)
  periodRef       String
  periodDate      DateTime      // primeiro dia do periodo, p/ ordenar
  value           Float
  status          ResultStatus  @default(FILLED)
  light           TrafficLight  @default(GRAY)
  attainment      Float?
  deviationAbs    Float?
  deviationPct    Float?
  note            String?
  evidenceUrl     String?
  createdById     String?
  createdBy       User?         @relation("ResultCreatedBy", fields: [createdById], references: [id])
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  treatmentCases  TreatmentCase[]
  actionsGenerated ActionPlan[] @relation("ActionIndicatorResult")

  @@unique([indicatorId, periodRef])
  @@index([indicatorId, periodDate])
  @@index([light])
}

model IndicatorTreeRelation {
  id        String                @id @default(uuid())
  parentId  String
  childId   String
  parent    Indicator             @relation("RelParent", fields: [parentId], references: [id], onDelete: Cascade)
  child     Indicator             @relation("RelChild", fields: [childId], references: [id], onDelete: Cascade)
  kind      IndicatorRelationKind @default(POSITIVE)
  weight    Float                 @default(1)

  @@unique([parentId, childId])
}

model ClosedMonth {
  id          String   @id @default(uuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  periodRef   String   // ex: 2026-01
  reason      String?
  closedAt    DateTime @default(now())
  closedById  String?
  closedBy    User?    @relation("ClosedMonthClosedBy", fields: [closedById], references: [id])
  reopenedAt  DateTime?
  reopenedById String?
  reopenedBy  User?    @relation("ClosedMonthReopenedBy", fields: [reopenedById], references: [id])
  deletedAt   DateTime?

  @@unique([companyId, periodRef])
  @@index([companyId])
}

// =====================================================
// Desvios / FCA / CAPA
// =====================================================

model Deviation {
  id                String              @id @default(uuid())
  companyId         String
  company           Company             @relation(fields: [companyId], references: [id])
  indicatorId       String
  indicator         Indicator           @relation(fields: [indicatorId], references: [id])
  periodRef         String
  number            Int                 // sequencial por empresa
  title             String
  severity          DeviationSeverity   @default(MODERATE)
  status            DeviationStatus     @default(OPEN)
  method            AnalysisMethod      @default(FCA)
  fact              String?
  rootCause         String?
  impact            String?
  responsibleUserId String?
  responsibleUser   User?               @relation("DeviationResponsible", fields: [responsibleUserId], references: [id])
  dueDate           DateTime?
  openedAt          DateTime            @default(now())
  closedAt          DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  deletedAt         DateTime?

  causes    DeviationCause[]
  analyses  DeviationAnalysis[]
  actions   ActionPlan[]        @relation("ActionFromDeviation")
  meetings  Meeting[]           @relation("MeetingDeviation")
  treatmentCases TreatmentCase[]

  @@index([companyId])
  @@index([indicatorId])
  @@unique([companyId, number])
}

model DeviationCause {
  id          String    @id @default(uuid())
  deviationId String
  deviation   Deviation @relation(fields: [deviationId], references: [id], onDelete: Cascade)
  category    String?   // 6M ex.: Metodo, Maquina, MO, Material, Medida, Meio
  description String
  weight      Float     @default(1)
  createdAt   DateTime  @default(now())
}

model DeviationAnalysis {
  id          String         @id @default(uuid())
  deviationId String
  deviation   Deviation      @relation(fields: [deviationId], references: [id], onDelete: Cascade)
  method      AnalysisMethod
  content     String         // texto livre ou JSON serializado
  createdAt   DateTime       @default(now())
  actions     ActionPlan[]    @relation("ActionFromAnalysis")
  meetings    Meeting[]       @relation("MeetingAnalysis")
  treatmentCases TreatmentCase[]
}

// =====================================================
// Planos de acao
// =====================================================

model ActionPlan {
  id                String         @id @default(uuid())
  companyId         String
  company           Company        @relation(fields: [companyId], references: [id])
  branchId          String?
  branch            Branch?        @relation(fields: [branchId], references: [id])
  ownerNodeId       String?
  ownerNode         OrgNode?       @relation("ActionOwnerNode", fields: [ownerNodeId], references: [id])
  responsibleUserId String?
  responsibleUser   User?          @relation("ActionResponsible", fields: [responsibleUserId], references: [id])
  createdById       String?
  createdBy         User?          @relation("ActionCreatedBy", fields: [createdById], references: [id])
  strategicObjectiveId String?
  strategicObjective StrategicObjective? @relation("ActionStrategicObjective", fields: [strategicObjectiveId], references: [id])
  indicatorId       String?
  indicator         Indicator?     @relation("ActionIndicator", fields: [indicatorId], references: [id])
  indicatorResultId String?
  indicatorResult   IndicatorResult? @relation("ActionIndicatorResult", fields: [indicatorResultId], references: [id])
  meetingId         String?
  meeting           Meeting?       @relation("ActionFromMeeting", fields: [meetingId], references: [id])
  analysisId        String?
  analysis          DeviationAnalysis? @relation("ActionFromAnalysis", fields: [analysisId], references: [id])
  treatmentId       String?
  treatment         TreatmentCase? @relation(fields: [treatmentId], references: [id])

  title          String
  description    String?
  problemDescription String?
  origin         ActionOrigin   @default(MANUAL)
  originRefId    String?
  analysisTool   ActionAnalysisTool?
  rootCause      String?
  priority       ActionPriority @default(MEDIUM)
  criticality    ActionPriority @default(MEDIUM)
  status         ActionStatus   @default(NOT_STARTED)
  startDate      DateTime?
  dueDate        DateTime?
  completedAt    DateTime?
  progress       Float          @default(0) // 0..100
  estimatedCost  Float?
  actualCost     Float?
  responsibleEmail String?
  evidenceRequired Boolean      @default(false)
  expectedResult   String?
  achievedResult   String?
  effectivenessStatus ActionEffectivenessStatus @default(NOT_STARTED)
  effectivenessChecklist Json?
  effectivenessSummary   String?
  effectivenessEvidence  String?
  effectivenessValidatedById String?
  effectivenessValidatedAt DateTime?
  reopenedAt      DateTime?
  cancelReason    String?

  deviationId    String?
  deviation      Deviation?     @relation("ActionFromDeviation", fields: [deviationId], references: [id])

  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  deletedAt      DateTime?

  tasks          ActionTask[]
  participants   ActionParticipant[]
  evidences      ActionEvidence[]
  comments       ActionComment[]
  history        ActionHistory[]
  analysisSessions ActionAnalysisSession[]
  aiSuggestions  ActionAiSuggestion[]

  @@index([companyId])
  @@index([branchId])
  @@index([status])
  @@index([dueDate])
  @@index([strategicObjectiveId])
  @@index([indicatorId])
  @@index([indicatorResultId])
  @@index([meetingId])
  @@index([treatmentId])
  @@index([effectivenessStatus])
}

model ActionTask {
  id           String      @id @default(uuid())
  actionId     String
  action       ActionPlan  @relation(fields: [actionId], references: [id], onDelete: Cascade)
  title        String
  done         Boolean     @default(false)
  completionNote String?
  dueDate      DateTime?
  startDate    DateTime?
  endDate      DateTime?
  assignedToId String?
  assignedTo   User?       @relation("ActionTaskAssignee", fields: [assignedToId], references: [id])
  position     Int         @default(0)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([actionId])
  @@index([assignedToId])
}

model GeneralApprovalRequest {
  id           String   @id @default(uuid())
  companyId    String
  type         String
  entityType   String
  entityId     String
  title        String
  description  String?
  requesterId  String?
  approverId   String?
  status       String   @default("PENDING")
  reason       String?
  decisionNote String?
  decidedAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([companyId, status])
  @@index([entityType, entityId])
  @@index([requesterId])
  @@index([approverId])
}

model ActionParticipant {
  id        String     @id @default(uuid())
  actionId  String
  action    ActionPlan @relation(fields: [actionId], references: [id], onDelete: Cascade)
  userId    String?
  name      String?
  email     String?
  role      String?
  createdAt DateTime   @default(now())

  @@index([actionId])
  @@index([userId])
}

model ActionEvidence {
  id          String     @id @default(uuid())
  actionId    String
  action      ActionPlan @relation(fields: [actionId], references: [id], onDelete: Cascade)
  title       String
  description String?
  url         String?
  fileName    String?
  fileType    String?
  uploadedById String?
  createdAt   DateTime   @default(now())
  deletedAt   DateTime?

  @@index([actionId])
}

model ActionComment {
  id        String     @id @default(uuid())
  actionId  String
  action    ActionPlan @relation(fields: [actionId], references: [id], onDelete: Cascade)
  authorId  String?
  authorName String?
  comment   String
  createdAt DateTime   @default(now())
  deletedAt DateTime?

  @@index([actionId, createdAt])
}

model ActionHistory {
  id          String     @id @default(uuid())
  actionId    String
  action      ActionPlan @relation(fields: [actionId], references: [id], onDelete: Cascade)
  userId      String?
  eventType   String
  field       String?
  beforeValue String?
  afterValue  String?
  note        String?
  createdAt   DateTime   @default(now())

  @@index([actionId, createdAt])
}

model ActionAnalysisSession {
  id          String             @id @default(uuid())
  actionId    String
  action      ActionPlan         @relation(fields: [actionId], references: [id], onDelete: Cascade)
  method      ActionAnalysisTool
  status      ActionToolStatus   @default(DRAFT)
  problem     String?
  rootCause   String?
  responsibleUserId String?
  data        Json?
  aiSummary   String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  fiveWhys       ActionFiveWhy[]
  ishikawaCauses ActionIshikawaCause[]
  maspSteps      ActionMaspStep[]
  pdcaSteps      ActionPdcaStep[]
  fiveW2H        ActionFiveW2H?

  @@unique([actionId, method])
  @@index([actionId])
}

model ActionFiveWhy {
  id          String                @id @default(uuid())
  sessionId   String
  session     ActionAnalysisSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  position    Int
  question    String
  answer      String?
  evidence    String?
  aiPrompt    String?
  isRootCause Boolean               @default(false)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  @@unique([sessionId, position])
}

model ActionIshikawaCause {
  id          String                @id @default(uuid())
  sessionId   String
  session     ActionAnalysisSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  category    String
  description String
  impact      Int                   @default(3)
  probability Int                   @default(3)
  evidence    String?
  likelyRootCause Boolean           @default(false)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  @@index([sessionId])
}

model ActionMaspStep {
  id          String                @id @default(uuid())
  sessionId   String
  session     ActionAnalysisSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  step        Int
  title       String
  description String?
  responsibleUserId String?
  dueDate     DateTime?
  evidence    String?
  comments    String?
  status      ActionStepStatus      @default(PENDING)
  validated   Boolean               @default(false)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  @@unique([sessionId, step])
}

model ActionPdcaStep {
  id          String                @id @default(uuid())
  sessionId   String
  session     ActionAnalysisSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  phase       String
  description String?
  responsibleUserId String?
  dueDate     DateTime?
  evidence    String?
  comments    String?
  status      ActionStepStatus      @default(PENDING)
  validated   Boolean               @default(false)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  @@unique([sessionId, phase])
}

model ActionFiveW2H {
  id          String                @id @default(uuid())
  sessionId   String                @unique
  session     ActionAnalysisSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  what        String?
  why         String?
  where       String?
  when        DateTime?
  who         String?
  how         String?
  howMuch     Float?
  reviewNotes String?
  completeScore Int                 @default(0)
  updatedAt   DateTime              @updatedAt
}

model ActionAiSuggestion {
  id          String                   @id @default(uuid())
  actionId    String
  action      ActionPlan               @relation(fields: [actionId], references: [id], onDelete: Cascade)
  sessionId   String?
  suggestionType String
  title       String
  content     String
  context     Json?
  status      ActionAiSuggestionStatus @default(PENDING)
  createdAt   DateTime                 @default(now())
  decidedAt   DateTime?
  decidedById String?

  @@index([actionId, createdAt])
  @@index([status])
}

// =====================================================
// Projetos e cronograma
// =====================================================

model Project {
  id          String         @id @default(uuid())
  companyId   String
  company     Company        @relation(fields: [companyId], references: [id])
  indicatorId String?
  indicator   Indicator?     @relation("ProjectIndicator", fields: [indicatorId], references: [id])
  name        String
  description String?
  status      ProjectStatus  @default(PLANNED)
  startsAt    DateTime?
  endsAt      DateTime?
  responsible String?
  budget      Float?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  deletedAt   DateTime?

  milestones  ProjectMilestone[]
  tasks       ProjectTask[]

  @@index([companyId])
  @@index([indicatorId])
}

model ProjectMilestone {
  id        String   @id @default(uuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name      String
  dueDate   DateTime
  done      Boolean  @default(false)
}

model ProjectTask {
  id            String       @id @default(uuid())
  projectId     String
  project       Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name          String
  startDate     DateTime?
  endDate       DateTime?
  progress      Float        @default(0)
  responsible   String?
  dependencyId  String?
  dependency    ProjectTask? @relation("TaskDep", fields: [dependencyId], references: [id])
  dependents    ProjectTask[] @relation("TaskDep")
  position      Int          @default(0)
}

// =====================================================
// Reunioes
// =====================================================

model Meeting {
  id          String       @id @default(uuid())
  companyId   String
  company     Company      @relation(fields: [companyId], references: [id])
  indicatorId String?
  indicator   Indicator?   @relation("MeetingIndicator", fields: [indicatorId], references: [id])
  deviationId String?
  deviation   Deviation?   @relation("MeetingDeviation", fields: [deviationId], references: [id])
  analysisId  String?
  analysis    DeviationAnalysis? @relation("MeetingAnalysis", fields: [analysisId], references: [id])
  treatmentId String?
  treatment   TreatmentCase? @relation("MeetingTreatment", fields: [treatmentId], references: [id])
  responsibleUserId String?
  responsibleUser   User?    @relation("MeetingResponsible", fields: [responsibleUserId], references: [id])
  title       String
  kind        MeetingKind
  format      MeetingFormat @default(ONLINE)
  status      MeetingStatus @default(SCHEDULED)
  startsAt    DateTime
  endsAt      DateTime?
  location    String?
  objective   String?
  notes       String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deletedAt   DateTime?

  participants  MeetingParticipant[]
  guests         MeetingGuest[]
  agendaItems   MeetingAgendaItem[]
  decisions     MeetingDecision[]
  actions       ActionPlan[]       @relation("ActionFromMeeting")
  emailLogs     EmailLog[]
  calendarInvites CalendarInvite[]
  primaryForTreatments TreatmentCase[] @relation("TreatmentPrimaryMeeting")

  @@index([companyId])
  @@index([startsAt])
  @@index([indicatorId])
  @@index([deviationId])
  @@index([treatmentId])
}

model MeetingParticipant {
  id        String   @id @default(uuid())
  meetingId String
  meeting   Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  role      MeetingParticipantRole @default(PARTICIPANT)
  notes     String?
  attended  Boolean  @default(false)

  @@unique([meetingId, userId])
}

model MeetingGuest {
  id        String   @id @default(uuid())
  meetingId String
  meeting   Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  name      String
  email     String
  jobTitle  String?
  area      String?
  role      MeetingParticipantRole @default(GUEST)
  confirmed Boolean  @default(false)
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([meetingId])
  @@unique([meetingId, email])
}

model MeetingAgendaItem {
  id        String   @id @default(uuid())
  meetingId String
  meeting   Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  topic     String
  notes     String?
  position  Int      @default(0)
}

model MeetingDecision {
  id        String   @id @default(uuid())
  meetingId String
  meeting   Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  decision  String
  owner     String?
  dueDate   DateTime?
}

// =====================================================
// Suporte: anexos, comentarios, notificacoes
// =====================================================

model Attachment {
  id         String   @id @default(uuid())
  refTable   String   // ex.: "Deviation", "ActionPlan", "IndicatorResult"
  refId      String
  fileName   String
  fileUrl    String
  mimeType   String?
  sizeBytes  Int?
  createdAt  DateTime @default(now())
  createdBy  String?

  @@index([refTable, refId])
}

model Comment {
  id        String   @id @default(uuid())
  refTable  String
  refId     String
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  body      String
  createdAt DateTime @default(now())

  @@index([refTable, refId])
}

model Notification {
  id        String           @id @default(uuid())
  companyId String
  company   Company          @relation(fields: [companyId], references: [id])
  userId    String
  user      User             @relation(fields: [userId], references: [id])
  kind      NotificationKind
  title     String
  body      String?
  link      String?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([userId, readAt])
}

// =====================================================
// Rastreabilidade e mapa corporativo
// =====================================================

model TraceabilityEvent {
  id            String          @id @default(uuid())
  companyId     String
  company       Company         @relation(fields: [companyId], references: [id])
  indicatorId   String?
  indicator     Indicator?      @relation(fields: [indicatorId], references: [id])
  userId        String?
  user          User?           @relation("TraceabilityEventUser", fields: [userId], references: [id])

  eventType     TraceEventType
  entityType    TraceEntityType
  entityId      String
  relatedType   TraceEntityType?
  relatedId     String?
  title         String
  description   String?
  statusFrom    String?
  statusTo      String?
  metadata      Json?
  occurredAt    DateTime        @default(now())
  createdAt     DateTime        @default(now())

  @@index([companyId, occurredAt])
  @@index([indicatorId, occurredAt])
  @@index([entityType, entityId])
  @@index([relatedType, relatedId])
}

model StatusHistory {
  id            String          @id @default(uuid())
  companyId     String
  company       Company         @relation(fields: [companyId], references: [id])
  userId        String?
  user          User?           @relation("StatusHistoryUser", fields: [userId], references: [id])
  entityType    TraceEntityType
  entityId      String
  statusFrom    String?
  statusTo      String
  reason        String?
  metadata      Json?
  createdAt     DateTime        @default(now())

  @@index([companyId, createdAt])
  @@index([entityType, entityId])
}

model RelationshipMap {
  id          String      @id @default(uuid())
  companyId   String
  company     Company     @relation(fields: [companyId], references: [id])
  name        String
  description String?
  mode        MapMode     @default(TRACEABILITY)
  active      Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  deletedAt   DateTime?

  nodes       MapNode[]
  edges       MapEdge[]
  layouts     MapLayout[]

  @@index([companyId])
}

model MapNode {
  id             String          @id @default(uuid())
  mapId          String
  map            RelationshipMap @relation(fields: [mapId], references: [id], onDelete: Cascade)
  type           MapNodeType
  refTable       String?
  refId          String?
  label          String
  status         String?
  responsible    String?
  dueDate        DateTime?
  positionX      Float           @default(0)
  positionY      Float           @default(0)
  collapsed      Boolean         @default(false)
  data           Json?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  outgoingEdges  MapEdge[]       @relation("MapEdgeSource")
  incomingEdges  MapEdge[]       @relation("MapEdgeTarget")

  @@index([mapId])
  @@index([refTable, refId])
}

model MapEdge {
  id           String          @id @default(uuid())
  mapId        String
  map          RelationshipMap @relation(fields: [mapId], references: [id], onDelete: Cascade)
  sourceNodeId String
  sourceNode   MapNode         @relation("MapEdgeSource", fields: [sourceNodeId], references: [id], onDelete: Cascade)
  targetNodeId String
  targetNode   MapNode         @relation("MapEdgeTarget", fields: [targetNodeId], references: [id], onDelete: Cascade)
  kind         String          @default("relates_to")
  label        String?
  data         Json?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@unique([mapId, sourceNodeId, targetNodeId, kind])
  @@index([mapId])
}

model MapLayout {
  id          String          @id @default(uuid())
  mapId       String
  map         RelationshipMap @relation(fields: [mapId], references: [id], onDelete: Cascade)
  mode        MapMode         @default(TRACEABILITY)
  viewport    Json?
  nodesJson   Json?
  updatedById String?
  updatedBy   User?           @relation("MapLayoutUpdatedBy", fields: [updatedById], references: [id])
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@unique([mapId, mode])
}

model TreatmentCase {
  id              String          @id @default(uuid())
  companyId       String
  company         Company         @relation(fields: [companyId], references: [id])
  indicatorId     String
  indicator       Indicator       @relation(fields: [indicatorId], references: [id])
  resultId        String?
  result          IndicatorResult? @relation(fields: [resultId], references: [id])
  deviationId     String?
  deviation       Deviation?      @relation(fields: [deviationId], references: [id])
  analysisId      String?
  analysis        DeviationAnalysis? @relation(fields: [analysisId], references: [id])
  meetingId       String?
  meeting         Meeting?        @relation("TreatmentPrimaryMeeting", fields: [meetingId], references: [id])
  createdById     String?
  createdBy       User?           @relation("TreatmentCreatedBy", fields: [createdById], references: [id])

  periodRef       String
  title           String
  problem         String?
  status          TreatmentStatus @default(AWAITING_CAUSE_ANALYSIS)
  ignoredAt       DateTime?
  ignoreReason    String?
  resolvedAt      DateTime?
  concludedAt     DateTime?
  reopenedAt      DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  meetings        Meeting[]       @relation("MeetingTreatment")
  actions         ActionPlan[]

  @@unique([indicatorId, periodRef])
  @@index([companyId, status])
  @@index([indicatorId])
}

model EmailLog {
  id              String              @id @default(uuid())
  companyId       String
  company         Company             @relation(fields: [companyId], references: [id])
  meetingId       String?
  meeting         Meeting?            @relation(fields: [meetingId], references: [id])
  recipientName   String?
  recipientEmail  String
  subject         String
  body            String
  status          EmailDeliveryStatus @default(PENDING)
  errorMessage    String?
  attempts        Int                 @default(0)
  sentAt          DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([companyId, createdAt])
  @@index([meetingId])
  @@index([recipientEmail])
}

model CalendarInvite {
  id          String   @id @default(uuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  meetingId   String
  meeting     Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  uid         String   @unique
  icsContent  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([companyId])
  @@index([meetingId])
}

// =====================================================
// Importacao de dados
// =====================================================

model ImportJob {
  id         String           @id @default(uuid())
  companyId  String
  company    Company          @relation(fields: [companyId], references: [id])
  target     ImportTargetKind
  fileName   String
  totalRows  Int              @default(0)
  okRows     Int              @default(0)
  errorRows  Int              @default(0)
  startedAt  DateTime         @default(now())
  finishedAt DateTime?

  errors     ImportError[]

  @@index([companyId])
}

model ImportError {
  id       String     @id @default(uuid())
  jobId    String
  job      ImportJob  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  rowIndex Int
  message  String
  status   ImportRowStatus @default(ERROR)
  payload  String?
}

// =====================================================
// Auditoria & Configuracoes
// =====================================================

model AuditLog {
  id        String   @id @default(uuid())
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String   // "CREATE", "UPDATE", "DELETE", "LOGIN" ...
  module    String?
  entity    String
  entityId  String?
  recordLabel String?
  payload   String?  // JSON serializado do diff
  beforeValue String?
  afterValue  String?
  result    String?  @default("SUCCESS")
  sessionId String?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([companyId, createdAt])
  @@index([userId, createdAt])
  @@index([module, action])
  @@index([entity, entityId])
}

model AppSetting {
  id        String   @id @default(uuid())
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])
  key       String
  value     String
  description String?
  valueType String?  @default("text")
  group     String?  @default("Sistema")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, key])
}

model ParameterCategory {
  id          String            @id @default(uuid())
  companyId   String?
  company     Company?          @relation(fields: [companyId], references: [id])
  code        String
  name        String
  description String?
  module      String?
  status      AdminRecordStatus @default(ACTIVE)
  system      Boolean           @default(false)
  sortOrder   Int               @default(0)
  createdById String?
  updatedById String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  deletedAt   DateTime?

  items       ParameterItem[]

  @@unique([companyId, code])
  @@index([companyId, status])
  @@index([module])
}

model ParameterItem {
  id          String            @id @default(uuid())
  companyId   String?
  company     Company?          @relation(fields: [companyId], references: [id])
  categoryId  String
  category    ParameterCategory @relation(fields: [categoryId], references: [id])
  parentId    String?
  parent      ParameterItem?    @relation("ParameterItemChildren", fields: [parentId], references: [id])
  children    ParameterItem[]   @relation("ParameterItemChildren")
  code        String
  name        String
  description String?
  status      AdminRecordStatus @default(ACTIVE)
  sortOrder   Int               @default(0)
  metadata    Json?
  createdById String?
  updatedById String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  deletedAt   DateTime?

  @@unique([categoryId, code])
  @@index([companyId, status])
  @@index([categoryId, status])
  @@index([parentId])
}

model OrgJob {
  id          String   @id @default(uuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  name        String
  description String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  employees   OrgEmployee[] @relation("EmployeeCurrentJob")
  pretendedBy OrgEmployee[] @relation("EmployeePretendedJob")
  fromPaths   OrgJobCareerPath[] @relation("JobFrom")
  toPaths     OrgJobCareerPath[] @relation("JobTo")
  approvalRequestsAsCurrent OrgJobApprovalRequest[] @relation("CareerApprovalCurrentJob")
  approvalRequestsAsTarget  OrgJobApprovalRequest[] @relation("CareerApprovalTargetJob")

  @@index([companyId])
}

model OrgEmployee {
  id              String      @id @default(uuid())
  companyId       String
  company         Company     @relation(fields: [companyId], references: [id])
  orgNodeId       String?
  orgNode         OrgNode?    @relation(fields: [orgNodeId], references: [id])
  registrationId  String?
  name            String
  jobId           String
  job             OrgJob      @relation("EmployeeCurrentJob", fields: [jobId], references: [id])
  jobPretendedId  String?
  jobPretended    OrgJob?     @relation("EmployeePretendedJob", fields: [jobPretendedId], references: [id])
  band            String      @default("B")
  bandPretended   String      @default("B")
  shift           String      @default("D")
  isBudgeted      Boolean     @default(true)
  status          String      @default("ACTIVE")
  approvalStatus  String      @default("PENDENTE")
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  approvalRequests OrgJobApprovalRequest[]

  @@index([companyId])
  @@index([orgNodeId])
  @@index([jobPretendedId])
}

model OrgJobApprovalRequest {
  id              String           @id @default(uuid())
  companyId       String
  company         Company          @relation(fields: [companyId], references: [id])
  employeeId      String
  employee        OrgEmployee      @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  requesterId     String
  requester       User             @relation("CareerApprovalRequester", fields: [requesterId], references: [id])
  approverId      String
  approver        User             @relation("CareerApprovalApprover", fields: [approverId], references: [id])
  currentJobId    String
  currentJob      OrgJob           @relation("CareerApprovalCurrentJob", fields: [currentJobId], references: [id])
  targetJobId     String
  targetJob       OrgJob           @relation("CareerApprovalTargetJob", fields: [targetJobId], references: [id])
  currentBand     String
  targetBand      String
  status          String           @default("PENDING") // PENDING | APPROVED | REJECTED | CANCELLED
  reason          String?
  decisionNote    String?
  decidedAt       DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([companyId])
  @@index([employeeId])
  @@index([approverId])
  @@index([requesterId])
  @@index([status])
}

model OrgJobCareerPath {
  id             String   @id @default(uuid())
  companyId      String
  company        Company  @relation(fields: [companyId], references: [id])
  fromJobId      String
  toJobId        String
  fromJob        OrgJob   @relation("JobFrom", fields: [fromJobId], references: [id], onDelete: Cascade)
  toJob          OrgJob   @relation("JobTo", fields: [toJobId], references: [id], onDelete: Cascade)
  sourceHandle   String?  @default("right")
  targetHandle   String?  @default("left")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([fromJobId, toJobId])
  @@index([companyId])
}

// =====================================================
// Anexos e comentarios de resultados lancados
// Armazenados no proprio banco (Neon) - limite de 5 MB por arquivo aplicado na API.
// Chaveados por (indicatorId, periodRef) para nao depender do id do resultado.
// =====================================================

model IndicatorResultAttachment {
  id          String   @id @default(uuid())
  companyId   String
  indicatorId String
  periodRef   String
  fileName    String
  mimeType    String?
  sizeBytes   Int?
  data        Bytes
  createdById String?
  createdAt   DateTime @default(now())

  @@index([companyId])
  @@index([indicatorId, periodRef])
}

model IndicatorResultComment {
  id          String   @id @default(uuid())
  companyId   String
  indicatorId String
  periodRef   String
  body        String
  authorId    String?
  authorName  String?
  createdAt   DateTime @default(now())

  @@index([companyId])
  @@index([indicatorId, periodRef])
}

// ===========================================================================
// Administração do Banco de Dados (Configurações > Banco de Dados)
// Tabelas administrativas dedicadas. Sem relação Prisma com User para manter
// o módulo desacoplado e o log imutável mesmo se o usuário for removido;
// identidade do ator é denormalizada (userId/userEmail/userRole).
// ===========================================================================

model DbAdminAuditLog {
  id            String   @id @default(uuid())
  userId        String?
  userEmail     String?
  userRole      String?
  submenu       String   // overview | tables | records | query | structure | indexes | import-export | backup | audit | diagnostics | settings
  action        String   // ACCESS | DENIED | SELECT | INSERT | UPDATE | DELETE | DDL | EXPORT | IMPORT | BACKUP | RESTORE | TRUNCATE | DROP ...
  mode          String?  // safe | advanced
  targetTable   String?
  targetRecordId String?
  sqlText       String?  // comando executado (redigido quando não permitido)
  beforeValue   String?  // JSON
  afterValue    String?  // JSON
  rowsAffected  Int?
  result        String   @default("SUCCESS") // SUCCESS | ERROR | DENIED
  message       String?
  transactionId String?
  backupId      String?
  origin        String?
  ip            String?
  userAgent     String?
  createdAt     DateTime @default(now())

  @@index([createdAt])
  @@index([userId, createdAt])
  @@index([submenu, action])
  @@index([targetTable])
  @@index([result])
}

model DbAdminBackup {
  id               String   @id @default(uuid())
  userId           String?
  userEmail        String?
  type             String   // PRE_OP | TABLE_EXPORT | MANUAL_LOGICAL
  reason           String?
  relatedOperation String?
  targetTables     String   // JSON array de nomes de tabela
  format           String   @default("json") // json | sql
  filePath         String
  sizeBytes        Int      @default(0)
  rowCount         Int      @default(0)
  checksum         String?
  important        Boolean  @default(false)
  status           String   @default("AVAILABLE") // AVAILABLE | RESTORED | DELETED | CORRUPTED
  integrityVerified Boolean @default(false)
  createdAt        DateTime @default(now())

  @@index([createdAt])
  @@index([type])
  @@index([status])
}

model DbAdminSavedQuery {
  id         String   @id @default(uuid())
  userId     String?
  name       String
  sql        String
  isFavorite Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  lastRunAt  DateTime?

  @@index([userId])
  @@index([isFavorite])
}

model DbAdminQueryHistory {
  id         String   @id @default(uuid())
  userId     String?
  sql        String
  mode       String   @default("safe") // safe | advanced
  durationMs Int?
  rowCount   Int?
  success    Boolean  @default(true)
  message    String?
  createdAt  DateTime @default(now())

  @@index([userId, createdAt])
  @@index([createdAt])
}
