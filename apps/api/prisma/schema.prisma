model User {
  id                    String           @id @default(uuid())
  companyId             String
  company               Company          @relation(fields: [companyId], references: [id])
  email                 String           @unique
  passwordHash          String
  name                  String
  jobTitle              String?
  phone                 String?
  avatarUrl             String?
  bio                   String?
  customStatus          String?
  role                  UserRoleEnum     @default(COLLABORATOR)
  status                UserAccessStatus @default(ACTIVE)
  active                Boolean          @default(true)
  lastLoginAt           DateTime?
  passwordResetRequired Boolean          @default(false)
  invitedAt             DateTime?
  blockedAt             DateTime?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  deletedAt             DateTime?

  branchId        String?
