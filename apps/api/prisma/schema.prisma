// =====================================================
// Organizacao & Tenant
// =====================================================

model Company {
  id                String        @id @default(uuid())
  name              String
  tradeName         String?
  cnpj              String?       @unique
  logoUrl           String?
  active            Boolean       @default(true)
  status            CompanyStatus @default(ACTIVE)
  email             String?
  phone             String?
  addressLine       String?
  city              String?
  state             String?
  segment           String?
  maxUsers          Int?
  notes             String?
  // Quando true (padrão), a restrição de visibilidade POR ÁREA é aplicada aos
  // usuários não-administradores. SUPER_ADMIN/COMPANY_ADMIN sempre veem a empresa toda.
  areaAccessEnabled Boolean       @default(true)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  deletedAt         DateTime?

  branches                    Branch[]
  users                       User[]
  orgNodes                    OrgNode[]
  strategicMaps               StrategicMap[]
  indicators                  Indicator[]
  okrCycles                   OKRCycle[]
  deviations                  Deviation[]
  actions                     ActionPlan[]
  projects                    Project[]
  risks                       RiskRegister[]
  nonConformities             NonConformity[]
  documents                   Document[]
  documentEditRequests        DocumentEditRequest[]             @relation("DocumentEditRequestCompany")
  audits                      Audit[]
  processes                   Process[]
  fsPrograms                  FoodSafetyProgram[]               @relation("FsProgramCompany")
  fsProcesses                 FoodSafetyProcess[]               @relation("FsProcessCompany")
  fsProcessSteps              FoodSafetyProcessStep[]           @relation("FsStepCompany")
  fsRiskMatrices              FoodSafetyRiskMatrix[]            @relation("FsRiskMatrixCompany")
  fsHazards                   FoodSafetyHazard[]                @relation("FsHazardCompany")
  fsControlPlans              FoodSafetyControlPlan[]           @relation("FsControlPlanCompany")
  fsMonitoringRecords         FoodSafetyMonitoringRecord[]      @relation("FsMonitoringCompany")
  fsStandards                 FoodSafetyStandard[]              @relation("FsStandardCompany")
  fsStandardVersions          FoodSafetyStandardVersion[]       @relation("FsStdVersionCompany")
  fsRequirements              FoodSafetyRequirement[]           @relation("FsRequirementCompany")
  fsRequirementAssessments    FoodSafetyRequirementAssessment[] @relation("FsReqAssessmentCompany")
  fsSuppliers                 FoodSafetySupplier[]              @relation("FsSupplierCompany")
  fsMaterials                 FoodSafetyMaterial[]              @relation("FsMaterialCompany")
  fsLots                      FoodSafetyLot[]                   @relation("FsLotCompany")
  fsTraceLinks                FoodSafetyTraceLink[]             @relation("FsTraceLinkCompany")
  fsRecalls                   FoodSafetyRecall[]                @relation("FsRecallCompany")
  fsRecallItems               FoodSafetyRecallItem[]            @relation("FsRecallItemCompany")
  formTemplates               FormTemplate[]
  formSubmissions             FormSubmission[]
  meetings                    Meeting[]
  imports                     ImportJob[]
  auditLogs                   AuditLog[]
  notifications               Notification[]
  appSettings                 AppSetting[]
  accessProfiles              AccessProfile[]
  parameterCategories         ParameterCategory[]
  parameterItems              ParameterItem[]
  traceabilityEvents          TraceabilityEvent[]
  statusHistories             StatusHistory[]
  relationshipMaps            RelationshipMap[]
  treatmentCases              TreatmentCase[]
  orgJobs                     OrgJob[]
  orgEmployees                OrgEmployee[]
  orgJobCareerPaths           OrgJobCareerPath[]
  orgJobApprovalRequests      OrgJobApprovalRequest[]
  compensationJobCatalogs     CompensationJobCatalog[]
  compensationJobVersions     CompensationJobCatalogVersion[]
  compensationDescriptions    CompensationJobDescription[]
  compensationSalaryTables    CompensationSalaryTable[]
  compensationSalaryRanges    CompensationSalaryRange[]
  compensationPositions       CompensationPosition[]
  compensationAllocations     CompensationAllocationHistory[]
  compensationSalarySnapshots CompensationSalarySnapshot[]
  compensationMovements       CompensationMovementRequest[]
  compensationBudgets         CompensationBudget[]
  compensationCycles          CompensationCycle[]
  compensationSalarySurveys   CompensationSalarySurvey[]
  compensationSimulations     CompensationSimulation[]
  emailLogs                   EmailLog[]
  calendarInvites             CalendarInvite[]
  workPeriods                 WorkPeriod[]
  closedMonths                ClosedMonth[]
  conversations               Conversation[]
  userDelegations             UserDelegation[]                  @relation("UserDelegationCompany")
  workItemFollows             WorkItemFollow[]                  @relation("WorkItemFollowCompany")
  myDayAssistantLogs          MyDayAssistantLog[]               @relation("MyDayAssistantCompany")

  relationshipLinks     RelationshipLink[]     @relation("RelationshipCompany")
  impactAnalyses        ImpactAnalysis[]       @relation("ImpactAnalysisCompany")
  impactAnalysisItems   ImpactAnalysisItem[]   @relation("ImpactItemCompany")
  relationshipAuditLogs RelationshipAuditLog[] @relation("RelationAuditCompany")

  workflowDefinitions          WorkflowDefinition[]         @relation("WorkflowDefCompany")
  workflowVersions             WorkflowVersion[]            @relation("WorkflowVerCompany")
  workflowNodes                WorkflowNode[]               @relation("WorkflowNodeCompany")
  workflowEdges                WorkflowEdge[]               @relation("WorkflowEdgeCompany")
  workflowInstances            WorkflowInstance[]           @relation("WorkflowInstCompany")
  workflowNodeExecutions       WorkflowNodeExecution[]      @relation("WorkflowNodeExecCompany")
  workflowEvents               WorkflowEvent[]              @relation("WorkflowEventCompany")
  workflowTimers               WorkflowTimer[]              @relation("WorkflowTimerCompany")
  workflowApprovals            WorkflowApproval[]           @relation("WorkflowApprovCompany")
  workflowTasks                WorkflowTask[]               @relation("WorkflowTaskCompany")
  workflowTemplates            WorkflowTemplate[]           @relation("WorkflowTempCompany")
  workflowExecutionLogs        WorkflowExecutionLog[]       @relation("WorkflowLogCompany")
