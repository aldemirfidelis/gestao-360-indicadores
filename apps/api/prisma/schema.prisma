  id        String                 @id @default(uuid())
  meetingId String
  meeting   Meeting                @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  name      String
  email     String
  jobTitle  String?
  area      String?
  role      MeetingParticipantRole @default(GUEST)
  confirmed Boolean                @default(false)
  notes     String?
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt

  @@unique([meetingId, email])
  @@index([meetingId])
}

model MeetingAgendaItem {
  id        String  @id @default(uuid())
  meetingId String
  meeting   Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  topic     String
  notes     String?
  position  Int     @default(0)
}

model MeetingDecision {
  id        String    @id @default(uuid())
  meetingId String
  meeting   Meeting   @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  decision  String
  owner     String?
  dueDate   DateTime?
}

// =====================================================
// Reuniao Mensal de Resultados (modulo dedicado)
// Tabelas proprias da reuniao; acoes reusam ActionPlan,
// causa raiz reusa Deviation/DeviationAnalysis, ficha reusa Indicator.
// Referencias a usuarios/desvios/acoes/documentos sao IDs simples
// resolvidos no service (sem FK) para nao acoplar os modelos grandes.
// =====================================================

enum MonthlyMeetingStatus {
  PREPARING
  READY
  IN_PROGRESS
  CLOSED
  REOPENED
  CANCELLED
}

enum MonthlyAreaReadiness {
  NOT_STARTED
  IN_PROGRESS
  WITH_ISSUES
  READY_FOR_VALIDATION
  VALIDATED
  RELEASED
}

enum MonthlyEntryKind {
  DECISION
  RISK
  ESCALATION
  PENDING
}

enum MonthlyItemStatus {
  OPEN
  IN_PROGRESS
  DONE
  CANCELLED
}

enum MonthlyFollowUpLevel {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
}

enum MonthlyPresentationStatus {
  PENDING
  PRESENTING
  DISCUSSED
  SKIPPED
}

enum MonthlyStandardizationType {
  POP
  WORK_INSTRUCTION
  RISK_MATRIX
  CHECKLIST
  TRAINING
  VISUAL_MANAGEMENT
  AUDIT
  BEST_PRACTICE
  LEARNING_BANK
}

model MonthlyMeeting {
  id                String               @id @default(uuid())
  companyId         String
  company           Company              @relation(fields: [companyId], references: [id])
  title             String
  periodRef         String // AAAA-MM
  cropSeason        String?
  cycleName         String?
  status            MonthlyMeetingStatus @default(PREPARING)
  format            MeetingFormat        @default(HYBRID)
  startsAt          DateTime
  endsAt            DateTime?
  location          String?
  responsibleUserId String?
  secretaryUserId   String?
  followUpUserId    String?
  objective         String?
  assumptions       String?
  criticalRisks     String?
  boardDirections   String?
  generalNotes      String?
  keyMessage        String?
  nextMonthlyAt     DateTime?
  nextWeeklyAt      DateTime?
  closedAt          DateTime?
  createdById       String?
  updatedById       String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  deletedAt         DateTime?

  areas            MonthlyMeetingArea[]
  agendaItems      MonthlyMeetingAgendaItem[]
  indicators       MonthlyMeetingIndicator[]
  decisions        MonthlyMeetingDecision[]
  followUps        MonthlyMeetingFollowUp[]
  learnings        MonthlyMeetingLearning[]
  standardizations MonthlyMeetingStandardization[]
  participants     MonthlyMeetingParticipant[]
  checklist        MonthlyMeetingChecklistItem[]
  attachments      MonthlyMeetingAttachment[]

  @@index([companyId, periodRef])
  @@index([companyId, status])
}

model MonthlyMeetingArea {
  id              String               @id @default(uuid())
  meetingId       String
  meeting         MonthlyMeeting       @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  orgNodeId       String
  orgNode         OrgNode              @relation("MonthlyAreaOrgNode", fields: [orgNodeId], references: [id])
  position        Int                  @default(0)
  readiness       MonthlyAreaReadiness @default(NOT_STARTED)
  presenterUserId String?
  areaKeyMessage  String?
  validatedById   String?
  validatedAt     DateTime?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  indicators MonthlyMeetingIndicator[]

  @@unique([meetingId, orgNodeId])
  @@index([meetingId])
  @@index([orgNodeId])
}

model MonthlyMeetingIndicator {
  id                 String             @id @default(uuid())
  meetingId          String
  meeting            MonthlyMeeting     @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  meetingAreaId      String
  meetingArea        MonthlyMeetingArea @relation(fields: [meetingAreaId], references: [id], onDelete: Cascade)
  indicatorId        String
  indicator          Indicator          @relation("MonthlySnapshotIndicator", fields: [indicatorId], references: [id])
  // snapshot congelado no fechamento
  target             Float?
  lowerBound         Float?
  upperBound         Float?
  current            Float?
  accumulated        Float?
  attainment         Float?
  deviationPct       Float?
  light              TrafficLight       @default(GRAY)
  trend              String?
  // campos editaveis na preparacao/conducao
  managerComment     String?
  trendNote          String?
  executiveStatus    String?
  showInPresentation Boolean            @default(true)
  isCritical         Boolean            @default(false)
  financialImpact    Float?
  position           Int                @default(0)
  deviationId        String?
  actionPlanId       String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@unique([meetingAreaId, indicatorId])
  @@index([meetingId])
  @@index([indicatorId])
}

model MonthlyMeetingAgendaItem {
  id                 String                    @id @default(uuid())
  meetingId          String
  meeting            MonthlyMeeting            @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  orgNodeId          String?
  topic              String
  position           Int                       @default(0)
  plannedMinutes     Int                       @default(0)
  actualMinutes      Int?
  presentationStatus MonthlyPresentationStatus @default(PENDING)
  startedAt          DateTime?
  endedAt            DateTime?
  presenterUserId    String?
  notes              String?

  @@index([meetingId])
}

model MonthlyMeetingDecision {
  id                 String            @id @default(uuid())
  meetingId          String
  meeting            MonthlyMeeting    @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  orgNodeId          String?
  kind               MonthlyEntryKind  @default(DECISION)
  topic              String?
  description        String
  ownerName          String?
  ownerUserId        String?
  dueDate            DateTime?
  impactIfNotDecided String?
  boardInvolved      String?
  status             MonthlyItemStatus @default(OPEN)
  actionPlanId       String?
  createdById        String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@index([meetingId])
  @@index([meetingId, kind])
}

model MonthlyMeetingFollowUp {
  id           String               @id @default(uuid())
  meetingId    String
  meeting      MonthlyMeeting       @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  level        MonthlyFollowUpLevel @default(WEEKLY)
  title        String
  dueDate      DateTime?
  ownerUserId  String?
  indicatorId  String?
  actionPlanId String?
  status       MonthlyItemStatus    @default(OPEN)
  notes        String?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  @@index([meetingId])
}

model MonthlyMeetingLearning {
  id                String            @id @default(uuid())
  meetingId         String
  meeting           MonthlyMeeting    @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  orgNodeId         String?
  indicatorId       String?
  learning          String
  treatedCause      String?
  effectiveAction   String?
  replicateToNodeId String?
  ownerUserId       String?
  dueDate           DateTime?
  status            MonthlyItemStatus @default(OPEN)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([meetingId])
}

model MonthlyMeetingStandardization {
  id           String                     @id @default(uuid())
  meetingId    String
  meeting      MonthlyMeeting             @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  type         MonthlyStandardizationType @default(POP)
  description  String
  sourceNodeId String?
  indicatorId  String?
  documentId   String?
  ownerUserId  String?
  dueDate      DateTime?
  status       MonthlyItemStatus          @default(OPEN)
  createdAt    DateTime                   @default(now())
  updatedAt    DateTime                   @updatedAt

  @@index([meetingId])
}

model MonthlyMeetingParticipant {
  id        String                 @id @default(uuid())
  meetingId String
  meeting   MonthlyMeeting         @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  userId    String
  role      MeetingParticipantRole @default(PARTICIPANT)
  attended  Boolean                @default(false)

  @@unique([meetingId, userId])
  @@index([meetingId])
}

model MonthlyMeetingChecklistItem {
  id        String         @id @default(uuid())
  meetingId String
  meeting   MonthlyMeeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  orgNodeId String?
  label     String
  done      Boolean        @default(false)
  autoRule  String?
  severity  String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([meetingId])
}

model MonthlyMeetingAttachment {
  id          String         @id @default(uuid())
  meetingId   String
  meeting     MonthlyMeeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  refKind     String?
  fileName    String
  fileUrl     String
  mimeType    String?
  documentId  String?
  createdById String?
  createdAt   DateTime       @default(now())

  @@index([meetingId])
}

// =====================================================
// Comunicacao Organizacional (comunicados, campanhas, midias)
// Config (audience/channels/poll/attachments/history) em Json;
// refs a usuario/area sao IDs simples resolvidos no service (sem FK).
// =====================================================

enum CommPostType {
  SIMPLE
  BANNER
  VIDEO
  POLL
  SURVEY
  CAMPAIGN
}

enum CommPostPriority {
  LOW
  NORMAL
  HIGH
  CRITICAL
  URGENT
}

enum CommPostStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  SCHEDULED
  PUBLISHED
  EXPIRED
  ARCHIVED
  CANCELLED
  REJECTED
}

enum CommReactionType {
  LIKE
  UNDERSTOOD
  IMPORTANT
  QUESTION
}

enum CommCampaignStatus {
  DRAFT
  ACTIVE
  FINISHED
  ARCHIVED
}

enum CommMediaType {
  IMAGE
  BANNER
  VIDEO
  PDF
  DOCUMENT
  ICON
  TEMPLATE
}

enum CommMediaStatus {
  ACTIVE
  EXPIRED
  ARCHIVED
}

model CommunicationPost {
  id                       String                @id @default(uuid())
  companyId                String
  company                  Company               @relation(fields: [companyId], references: [id])
  campaignId               String?
  campaign                 CommunicationCampaign? @relation(fields: [campaignId], references: [id])
  title                    String
  subtitle                 String?
  content                  String
  type                     CommPostType          @default(SIMPLE)
  category                 String                @default("Institucional")
  priority                 CommPostPriority      @default(NORMAL)
  status                   CommPostStatus        @default(DRAFT)
  authorId                 String
  approverId               String?
  approvalComment          String?
  audience                 Json
  channels                 Json
  poll                     Json?
  attachments              Json?
  history                  Json?
  publishAt                DateTime?
  expiresAt                DateTime?
  publishedAt              DateTime?
  archivedAt               DateTime?
  coverImageUrl            String?
  bannerUrl                String?
  videoUrl                 String?
  thumbnailUrl             String?
  actionUrl                String?
  actionLabel              String?
  estimatedMinutes         Int?
  requiresReadConfirmation Boolean               @default(false)
  requiresPollAnswer       Boolean               @default(false)
  requiresVideoCompletion  Boolean               @default(false)
  allowComments            Boolean               @default(true)
  allowReactions           Boolean               @default(true)
  isMandatory              Boolean               @default(false)
  isPinned                 Boolean               @default(false)
  isFeatured               Boolean               @default(false)
  publicLinkEnabled        Boolean               @default(false)
  qrCodeValue              String?
  linkedModule             String?
  linkedEntityId           String?
  version                  Int                   @default(1)
  createdAt                DateTime              @default(now())
  updatedAt                DateTime              @updatedAt
  deletedAt                DateTime?

  reads         CommunicationPostRead[]
  reactions     CommunicationPostReaction[]
  comments      CommunicationPostComment[]
  pollResponses CommunicationPollResponse[]

  @@index([companyId, status])
  @@index([companyId, publishedAt])
  @@index([campaignId])
}

model CommunicationPostRead {
  id          String            @id @default(uuid())
  postId      String
  post        CommunicationPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId      String
  viewedAt    DateTime          @default(now())
  confirmedAt DateTime?
  channel     String?
  device      String?
  ip          String?
  dwellSeconds Int?

  @@unique([postId, userId])
  @@index([userId])
}

model CommunicationPostReaction {
  id        String           @id @default(uuid())
  postId    String
  post      CommunicationPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  type      CommReactionType @default(LIKE)
  createdAt DateTime         @default(now())

  @@unique([postId, userId])
}

model CommunicationPostComment {
  id        String            @id @default(uuid())
  postId    String
  post      CommunicationPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  body      String
  moderated Boolean           @default(false)
  createdAt DateTime          @default(now())

  @@index([postId])
}

model CommunicationPollResponse {
  id        String            @id @default(uuid())
  postId    String
  post      CommunicationPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  answers   Json
  text      String?
  createdAt DateTime          @default(now())

  @@unique([postId, userId])
}

model CommunicationCampaign {
  id             String             @id @default(uuid())
  companyId      String
  company        Company            @relation(fields: [companyId], references: [id])
  name           String
  objective      String?
  category       String?
  status         CommCampaignStatus @default(DRAFT)
  ownerId        String?
  startsAt       DateTime?
  endsAt         DateTime?
  targetAudience Json?
  indicatorIds   Json?
  actionIds      Json?
  createdById    String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  deletedAt      DateTime?

  posts CommunicationPost[]

  @@index([companyId, status])
}

model CommunicationMedia {
  id          String          @id @default(uuid())
  companyId   String
  company     Company         @relation(fields: [companyId], references: [id])
  name        String
  type        CommMediaType   @default(IMAGE)
  category    String?
  tags        Json?
  url         String?
  ownerAreaId String?
  authorId    String?
  version     Int             @default(1)
  status      CommMediaStatus @default(ACTIVE)
  validUntil  DateTime?
  usageCount  Int             @default(0)
  createdAt   DateTime        @default(now())
  deletedAt   DateTime?

  @@index([companyId, status])
}

// =====================================================
// Suporte: anexos, comentarios, notificacoes
// =====================================================

model Attachment {
  id        String   @id @default(uuid())
  refTable  String // ex.: "Deviation", "ActionPlan", "IndicatorResult"
  refId     String
  fileName  String
  fileUrl   String
  mimeType  String?
  sizeBytes Int?
  createdAt DateTime @default(now())
  createdBy String?

  @@index([refTable, refId])
}

model Comment {
  id        String   @id @default(uuid())
  refTable  String
  refId     String
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  body      String
  createdAt DateTime @default(now())

  @@index([refTable, refId])
}

model Notification {
  id        String           @id @default(uuid())
  companyId String
  company   Company          @relation(fields: [companyId], references: [id])
  userId    String
  user      User             @relation(fields: [userId], references: [id])
  kind      NotificationKind
  title     String
  body      String?
  link      String?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([userId, readAt])
}

// =====================================================
// Rastreabilidade e mapa corporativo
// =====================================================

model TraceabilityEvent {
  id          String     @id @default(uuid())
  companyId   String
  company     Company    @relation(fields: [companyId], references: [id])
  indicatorId String?
  indicator   Indicator? @relation(fields: [indicatorId], references: [id])
  userId      String?
  user        User?      @relation("TraceabilityEventUser", fields: [userId], references: [id])

  eventType   TraceEventType
  entityType  TraceEntityType
  entityId    String
  relatedType TraceEntityType?
  relatedId   String?
  title       String
  description String?
  statusFrom  String?
  statusTo    String?
  metadata    Json?
  occurredAt  DateTime         @default(now())
  createdAt   DateTime         @default(now())

  @@index([companyId, occurredAt])
  @@index([indicatorId, occurredAt])
  @@index([entityType, entityId])
  @@index([relatedType, relatedId])
}

model StatusHistory {
  id         String          @id @default(uuid())
  companyId  String
  company    Company         @relation(fields: [companyId], references: [id])
  userId     String?
  user       User?           @relation("StatusHistoryUser", fields: [userId], references: [id])
  entityType TraceEntityType
  entityId   String
  statusFrom String?
  statusTo   String
  reason     String?
  metadata   Json?
  createdAt  DateTime        @default(now())

  @@index([companyId, createdAt])
  @@index([entityType, entityId])
}

model RelationshipMap {
  id          String    @id @default(uuid())
  companyId   String
  company     Company   @relation(fields: [companyId], references: [id])
  name        String
  description String?
  mode        MapMode   @default(TRACEABILITY)
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  nodes   MapNode[]
  edges   MapEdge[]
  layouts MapLayout[]

  @@index([companyId])
}

model MapNode {
  id          String          @id @default(uuid())
  mapId       String
  map         RelationshipMap @relation(fields: [mapId], references: [id], onDelete: Cascade)
  type        MapNodeType
  refTable    String?
  refId       String?
  label       String
  status      String?
  responsible String?
  dueDate     DateTime?
  positionX   Float           @default(0)
  positionY   Float           @default(0)
  collapsed   Boolean         @default(false)
  data        Json?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  outgoingEdges MapEdge[] @relation("MapEdgeSource")
  incomingEdges MapEdge[] @relation("MapEdgeTarget")

  @@index([mapId])
  @@index([refTable, refId])
}

model MapEdge {
  id           String          @id @default(uuid())
  mapId        String
  map          RelationshipMap @relation(fields: [mapId], references: [id], onDelete: Cascade)
  sourceNodeId String
  sourceNode   MapNode         @relation("MapEdgeSource", fields: [sourceNodeId], references: [id], onDelete: Cascade)
  targetNodeId String
  targetNode   MapNode         @relation("MapEdgeTarget", fields: [targetNodeId], references: [id], onDelete: Cascade)
  kind         String          @default("relates_to")
  label        String?
  data         Json?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@unique([mapId, sourceNodeId, targetNodeId, kind])
  @@index([mapId])
}

model MapLayout {
  id          String          @id @default(uuid())
  mapId       String
  map         RelationshipMap @relation(fields: [mapId], references: [id], onDelete: Cascade)
  mode        MapMode         @default(TRACEABILITY)
  viewport    Json?
  nodesJson   Json?
  updatedById String?
  updatedBy   User?           @relation("MapLayoutUpdatedBy", fields: [updatedById], references: [id])
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@unique([mapId, mode])
}

model TreatmentCase {
  id          String             @id @default(uuid())
  companyId   String
  company     Company            @relation(fields: [companyId], references: [id])
  indicatorId String
  indicator   Indicator          @relation(fields: [indicatorId], references: [id])
  resultId    String?
  result      IndicatorResult?   @relation(fields: [resultId], references: [id])
  deviationId String?
  deviation   Deviation?         @relation(fields: [deviationId], references: [id])
  analysisId  String?
  analysis    DeviationAnalysis? @relation(fields: [analysisId], references: [id])
  meetingId   String?
  meeting     Meeting?           @relation("TreatmentPrimaryMeeting", fields: [meetingId], references: [id])
  createdById String?
  createdBy   User?              @relation("TreatmentCreatedBy", fields: [createdById], references: [id])

  periodRef    String
  title        String
  problem      String?
  status       TreatmentStatus @default(AWAITING_CAUSE_ANALYSIS)
  ignoredAt    DateTime?
  ignoreReason String?
  resolvedAt   DateTime?
  concludedAt  DateTime?
  reopenedAt   DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  meetings Meeting[]    @relation("MeetingTreatment")
  actions  ActionPlan[]

  @@unique([indicatorId, periodRef])
  @@index([companyId, status])
  @@index([indicatorId])
}

model EmailLog {
  id             String              @id @default(uuid())
  companyId      String
  company        Company             @relation(fields: [companyId], references: [id])
  meetingId      String?
  meeting        Meeting?            @relation(fields: [meetingId], references: [id])
  recipientName  String?
  recipientEmail String
  subject        String
  body           String
  status         EmailDeliveryStatus @default(PENDING)
  errorMessage   String?
  attempts       Int                 @default(0)
  sentAt         DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([companyId, createdAt])
  @@index([meetingId])
  @@index([recipientEmail])
}

model CalendarInvite {
  id         String   @id @default(uuid())
  companyId  String
  company    Company  @relation(fields: [companyId], references: [id])
  meetingId  String
  meeting    Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  uid        String   @unique
  icsContent String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([companyId])
  @@index([meetingId])
}

// =====================================================
// Importacao de dados
// =====================================================

model ImportJob {
  id         String           @id @default(uuid())
  companyId  String
  company    Company          @relation(fields: [companyId], references: [id])
  target     ImportTargetKind
  fileName   String
  totalRows  Int              @default(0)
  okRows     Int              @default(0)
  errorRows  Int              @default(0)
  startedAt  DateTime         @default(now())
  finishedAt DateTime?

  errors ImportError[]

  @@index([companyId])
}

model ImportError {
  id       String          @id @default(uuid())
  jobId    String
  job      ImportJob       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  rowIndex Int
  message  String
  status   ImportRowStatus @default(ERROR)
  payload  String?
}

// =====================================================
// Auditoria & Configuracoes
// =====================================================

model AuditLog {
  id          String   @id @default(uuid())
  companyId   String?
  company     Company? @relation(fields: [companyId], references: [id])
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  action      String // "CREATE", "UPDATE", "DELETE", "LOGIN" ...
  module      String?
  entity      String
  entityId    String?
  recordLabel String?
  payload     String? // JSON serializado do diff
  beforeValue String?
  afterValue  String?
  result      String?  @default("SUCCESS")
  sessionId   String?
  ip          String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([companyId, createdAt])
  @@index([userId, createdAt])
  @@index([module, action])
  @@index([entity, entityId])
}

model AppSetting {
  id          String   @id @default(uuid())
  companyId   String?
  company     Company? @relation(fields: [companyId], references: [id])
  key         String
  value       String
  description String?
  valueType   String?  @default("text")
  group       String?  @default("Sistema")
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([companyId, key])
}

model ParameterCategory {
  id          String            @id @default(uuid())
  companyId   String?
  company     Company?          @relation(fields: [companyId], references: [id])
  code        String
  name        String
  description String?
  module      String?
  status      AdminRecordStatus @default(ACTIVE)
  system      Boolean           @default(false)
  sortOrder   Int               @default(0)
  createdById String?
  updatedById String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  deletedAt   DateTime?

  items ParameterItem[]

  @@unique([companyId, code])
  @@index([companyId, status])
  @@index([module])
}

model ParameterItem {
