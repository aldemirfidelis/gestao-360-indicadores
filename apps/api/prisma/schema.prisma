// =====================================================
// Gestao 360 Indicadores - Prisma Schema
// =====================================================

generator client {
  provider      = "prisma-client-js"
  // native: para dev local (macOS/Windows/Linux glibc)
  // linux-musl-openssl-3.0.x: para imagens Alpine usadas no Docker/DigitalOcean
  // debian-openssl-3.0.x: para buildpacks DO (caso opte por buildpack)
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // directUrl e usado por prisma migrate e introspeccao, para evitar pgbouncer
  // quando DATABASE_URL aponta para o pooler do Neon
  directUrl = env("DIRECT_URL")
}

// =====================================================
// Enums
// =====================================================

enum UserRoleEnum {
  SUPER_ADMIN
  COMPANY_ADMIN
  DIRECTOR
  MANAGER
  ANALYST
  COLLABORATOR
  VIEWER
}

enum OrgNodeType {
  COMPANY
  BRANCH
  DIRECTORATE
  MANAGEMENT
  COORDINATION
  SECTOR
  AREA
  PROCESS
}

enum IndicatorType {
  STRATEGIC
  TACTICAL
  OPERATIONAL
  PROJECT
  PROCESS
  SAFETY
  QUALITY
  HR
  FINANCE
  PRODUCTION
  MAINTENANCE
  PROCUREMENT
  COMMERCIAL
  CUSTOM
}

enum IndicatorUnit {
  PERCENT
  CURRENCY
  QUANTITY
  HOURS
  DAYS
  TONS
  LITERS
  INDEX
  TEXT
  CUSTOM
}

enum Periodicity {
  DAILY
  WEEKLY
  BIWEEKLY
  MONTHLY
  QUARTERLY
  SEMIANNUAL
  ANNUAL
}

enum Direction {
  HIGHER_BETTER
  LOWER_BETTER
  EQUAL_TARGET
  RANGE
}

enum FeedKind {
  MANUAL
  IMPORT
  API
  DATABASE
  INTEGRATION
}

enum IndicatorStatus {
  ACTIVE
  INACTIVE
  IN_REVIEW
}

enum ResultStatus {
  PENDING
  FILLED
  APPROVED
  REJECTED
  REOPENED
}

enum DeviationSeverity {
  LOW
  MODERATE
  CRITICAL
}

enum DeviationStatus {
  OPEN
  IN_ANALYSIS
  WAITING_ACTION
  IN_PROGRESS
  CLOSED
  CLOSED_LATE
  CANCELLED
}

enum AnalysisMethod {
  FCA
  FIVE_WHYS
  ISHIKAWA
  PARETO
  CAPA
  SIMPLE
}

enum ActionStatus {
  NOT_STARTED
  IN_PROGRESS
  WAITING_THIRD
  PAUSED
  DONE
  DONE_LATE
  CANCELLED
}

enum ActionPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ActionOrigin {
  INDICATOR
  DEVIATION
  OBJECTIVE
  OKR
  MEETING
  PROJECT
  MANUAL
}

enum PerspectiveKind {
  FINANCIAL
  CUSTOMERS
  INTERNAL_PROCESS
  LEARNING_GROWTH
  SAFETY
  PEOPLE
  ESG
  QUALITY
  PRODUCTIVITY
  COSTS
  CUSTOM
}

enum ObjectiveStatus {
  PLANNED
  ON_TRACK
  AT_RISK
  OFF_TRACK
  DONE
  CANCELLED
}

enum TrafficLight {
  GREEN
  YELLOW
  RED
  GRAY
}

enum ProjectStatus {
  PLANNED
  IN_PROGRESS
  ON_HOLD
  DONE
  CANCELLED
}

enum MeetingKind {
  INDICATORS
  BOARD
  SECTOR
  PROJECT
  DEVIATION
}

enum NotificationKind {
  INDICATOR_OFF_TARGET
  PENDING_RESULT
  ACTION_DUE_SOON
  ACTION_OVERDUE
  DEVIATION_CRITICAL
  PROJECT_LATE
  MEETING_UPCOMING
  TARGET_MISSED
  MENTION
}

enum IndicatorRelationKind {
  POSITIVE
  NEGATIVE
  PROBABLE_CAUSE
  CONSEQUENCE
}

enum ImportTargetKind {
  INDICATORS
  ORG_TREE
  TARGETS
  RESULTS
}

enum ImportRowStatus {
  PENDING
  OK
  ERROR
  SKIPPED
}

// =====================================================
// Organizacao & Tenant
// =====================================================

model Company {
  id        String   @id @default(uuid())
  name      String
  tradeName String?
  cnpj      String?  @unique
  logoUrl   String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  branches            Branch[]
  users               User[]
  orgNodes            OrgNode[]
  strategicMaps       StrategicMap[]
  indicators          Indicator[]
  okrCycles           OKRCycle[]
  deviations          Deviation[]
  actions             ActionPlan[]
  projects            Project[]
  meetings            Meeting[]
  imports             ImportJob[]
  auditLogs           AuditLog[]
  notifications       Notification[]
  appSettings         AppSetting[]
}

model Branch {
  id        String   @id @default(uuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  name      String
  code      String?
  city      String?
  state     String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  orgNodes OrgNode[]

  @@index([companyId])
}

model OrgNode {
  id                  String        @id @default(uuid())
  companyId           String
  company             Company       @relation(fields: [companyId], references: [id])
  branchId            String?
  branch              Branch?       @relation(fields: [branchId], references: [id])
  parentId            String?
  parent              OrgNode?      @relation("OrgNodeChildren", fields: [parentId], references: [id])
  children            OrgNode[]     @relation("OrgNodeChildren")

  name                String
  code                String?
  type                OrgNodeType
  description         String?
  color               String?
  icon                String?
  active              Boolean       @default(true)
  position            Int           @default(0)

  responsibleUserId   String?
  responsibleUser     User?         @relation("OrgNodeResponsible", fields: [responsibleUserId], references: [id])

  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  deletedAt           DateTime?

  indicatorsOwned     Indicator[]   @relation("IndicatorOwnerNode")
  defaultForUsers     User[]        @relation("UserDefaultNode")
  actions             ActionPlan[]  @relation("ActionOwnerNode")

  @@index([companyId])
  @@index([parentId])
  @@index([branchId])
}

// =====================================================
// Usuarios, Roles e Permissoes
// =====================================================

model User {
  id            String        @id @default(uuid())
  companyId     String
  company       Company       @relation(fields: [companyId], references: [id])
  email         String        @unique
  passwordHash  String
  name          String
  jobTitle      String?
  phone         String?
  avatarUrl     String?
  role          UserRoleEnum  @default(COLLABORATOR)
  active        Boolean       @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  deletedAt     DateTime?

  defaultNodeId String?
  defaultNode   OrgNode?      @relation("UserDefaultNode", fields: [defaultNodeId], references: [id])

  responsibleNodes     OrgNode[]            @relation("OrgNodeResponsible")
  indicatorsResponsible Indicator[]         @relation("IndicatorResponsible")
  indicatorsFeeder      Indicator[]         @relation("IndicatorFeeder")
  resultsCreated        IndicatorResult[]   @relation("ResultCreatedBy")
  deviationsResponsible Deviation[]         @relation("DeviationResponsible")
  actionsResponsible    ActionPlan[]        @relation("ActionResponsible")
  actionsCreated        ActionPlan[]        @relation("ActionCreatedBy")
  meetingParticipations MeetingParticipant[]
  comments              Comment[]
  notifications         Notification[]
  refreshTokens         RefreshToken[]
  auditLogs             AuditLog[]
  permissions           UserPermission[]

  @@index([companyId])
  @@index([role])
}

model Permission {
  id          String           @id @default(uuid())
  key         String           @unique // ex.: "indicators:create"
  description String
  module      String
  action      String
  users       UserPermission[]
}

model UserPermission {
  userId       String
  permissionId String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  grantedAt    DateTime   @default(now())

  @@id([userId, permissionId])
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())
  userAgent String?
  ip        String?

  @@index([userId])
}

// =====================================================
// Mapa estrategico / BSC
// =====================================================

model StrategicMap {
  id          String              @id @default(uuid())
  companyId   String
  company     Company             @relation(fields: [companyId], references: [id])
  name        String
  description String?
  startsAt    DateTime
  endsAt      DateTime
  active      Boolean             @default(true)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  deletedAt   DateTime?

  perspectives Perspective[]
  objectives   StrategicObjective[]

  @@index([companyId])
}

model Perspective {
  id          String           @id @default(uuid())
  mapId       String
  map         StrategicMap     @relation(fields: [mapId], references: [id], onDelete: Cascade)
  kind        PerspectiveKind
  name        String
  color       String?
  position    Int              @default(0)

  objectives  StrategicObjective[]

  @@index([mapId])
}

model StrategicObjective {
  id            String              @id @default(uuid())
  mapId         String
  map           StrategicMap        @relation(fields: [mapId], references: [id], onDelete: Cascade)
  perspectiveId String
  perspective   Perspective         @relation(fields: [perspectiveId], references: [id])

  name          String
  description   String?
  responsible   String?
  weight        Float               @default(1)
  status        ObjectiveStatus     @default(PLANNED)
  priority      Int                 @default(3)
  position      Int                 @default(0)

  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  deletedAt     DateTime?

  indicators    Indicator[]         @relation("IndicatorStrategicObjective")
  okrs          OKRObjective[]
  outRelations  ObjectiveRelation[] @relation("ObjFrom")
  inRelations   ObjectiveRelation[] @relation("ObjTo")

  @@index([mapId])
  @@index([perspectiveId])
}

model ObjectiveRelation {
  id     String              @id @default(uuid())
  fromId String
  toId   String
  from   StrategicObjective  @relation("ObjFrom", fields: [fromId], references: [id], onDelete: Cascade)
  to     StrategicObjective  @relation("ObjTo", fields: [toId], references: [id], onDelete: Cascade)
  weight Float               @default(1)

  @@unique([fromId, toId])
}

// =====================================================
// OKRs
// =====================================================

model OKRCycle {
  id        String   @id @default(uuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  name      String
  startsAt  DateTime
  endsAt    DateTime
  active    Boolean  @default(true)

  objectives OKRObjective[]

  @@index([companyId])
}

model OKRObjective {
  id               String       @id @default(uuid())
  cycleId          String
  cycle            OKRCycle     @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  strategicObjId   String?
  strategicObj     StrategicObjective? @relation(fields: [strategicObjId], references: [id])
  name             String
  description      String?
  ownerName        String?
  team             String?
  weight           Float        @default(1)
  confidence       Float        @default(0.5) // 0..1
  status           ObjectiveStatus @default(PLANNED)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  deletedAt        DateTime?

  keyResults       KeyResult[]
  checkins         OKRCheckin[]

  @@index([cycleId])
}

model KeyResult {
  id           String       @id @default(uuid())
  objectiveId  String
  objective    OKRObjective @relation(fields: [objectiveId], references: [id], onDelete: Cascade)
  metric       String
  unit         IndicatorUnit @default(QUANTITY)
  startValue   Float
  currentValue Float
  targetValue  Float
  direction    Direction    @default(HIGHER_BETTER)
  weight       Float        @default(1)
  responsible  String?
  updatedAt    DateTime     @updatedAt
  createdAt    DateTime     @default(now())

  @@index([objectiveId])
}

model OKRCheckin {
  id          String       @id @default(uuid())
  objectiveId String
  objective   OKRObjective @relation(fields: [objectiveId], references: [id], onDelete: Cascade)
  weekRef     String       // YYYY-Www
  confidence  Float
  progress    Float        // 0..1
  note        String?
  createdAt   DateTime     @default(now())

  @@index([objectiveId])
}

// =====================================================
// Indicadores / KPIs
// =====================================================

model Indicator {
  id                  String              @id @default(uuid())
  companyId           String
  company             Company             @relation(fields: [companyId], references: [id])
  ownerNodeId         String
  ownerNode           OrgNode             @relation("IndicatorOwnerNode", fields: [ownerNodeId], references: [id])
  responsibleUserId   String?
  responsibleUser     User?               @relation("IndicatorResponsible", fields: [responsibleUserId], references: [id])
  feederUserId        String?
  feederUser          User?               @relation("IndicatorFeeder", fields: [feederUserId], references: [id])
  strategicObjectiveId String?
  strategicObjective  StrategicObjective? @relation("IndicatorStrategicObjective", fields: [strategicObjectiveId], references: [id])

  name                String
  code                String?
  description         String?
  type                IndicatorType       @default(OPERATIONAL)
  category            String?
  unit                IndicatorUnit       @default(PERCENT)
  unitLabel           String?
  periodicity         Periodicity         @default(MONTHLY)
  direction           Direction           @default(HIGHER_BETTER)
  formula             String?
  source              String?
  feedKind            FeedKind            @default(MANUAL)
  status              IndicatorStatus     @default(ACTIVE)
  weight              Float               @default(1)
  yellowToleranceP    Float               @default(10)

  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  deletedAt           DateTime?

  targets             IndicatorTarget[]
  results             IndicatorResult[]
  deviations          Deviation[]
  childRelations      IndicatorTreeRelation[] @relation("RelChild")
  parentRelations     IndicatorTreeRelation[] @relation("RelParent")

  @@index([companyId])
  @@index([ownerNodeId])
  @@index([type])
  @@index([status])
  @@unique([companyId, code])
}

model IndicatorTarget {
  id          String     @id @default(uuid())
  indicatorId String
  indicator   Indicator  @relation(fields: [indicatorId], references: [id], onDelete: Cascade)
  periodRef   String     // YYYY-MM, YYYY, etc.
  target      Float
  lowerBound  Float?
  upperBound  Float?
  weight      Float      @default(1)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@unique([indicatorId, periodRef])
  @@index([indicatorId])
}

model IndicatorResult {
  id              String        @id @default(uuid())
  indicatorId     String
  indicator       Indicator     @relation(fields: [indicatorId], references: [id], onDelete: Cascade)
  periodRef       String
  periodDate      DateTime      // primeiro dia do periodo, p/ ordenar
  value           Float
  status          ResultStatus  @default(FILLED)
  light           TrafficLight  @default(GRAY)
  attainment      Float?
  deviationAbs    Float?
  deviationPct    Float?
  note            String?
  evidenceUrl     String?
  createdById     String?
  createdBy       User?         @relation("ResultCreatedBy", fields: [createdById], references: [id])
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([indicatorId, periodRef])
  @@index([indicatorId, periodDate])
  @@index([light])
}

model IndicatorTreeRelation {
  id        String                @id @default(uuid())
  parentId  String
  childId   String
  parent    Indicator             @relation("RelParent", fields: [parentId], references: [id], onDelete: Cascade)
  child     Indicator             @relation("RelChild", fields: [childId], references: [id], onDelete: Cascade)
  kind      IndicatorRelationKind @default(POSITIVE)
  weight    Float                 @default(1)

  @@unique([parentId, childId])
}

// =====================================================
// Desvios / FCA / CAPA
// =====================================================

model Deviation {
  id                String              @id @default(uuid())
  companyId         String
  company           Company             @relation(fields: [companyId], references: [id])
  indicatorId       String
  indicator         Indicator           @relation(fields: [indicatorId], references: [id])
  periodRef         String
  number            Int                 // sequencial por empresa
  title             String
  severity          DeviationSeverity   @default(MODERATE)
  status            DeviationStatus     @default(OPEN)
  method            AnalysisMethod      @default(FCA)
  fact              String?
  rootCause         String?
  impact            String?
  responsibleUserId String?
  responsibleUser   User?               @relation("DeviationResponsible", fields: [responsibleUserId], references: [id])
  dueDate           DateTime?
  openedAt          DateTime            @default(now())
  closedAt          DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  deletedAt         DateTime?

  causes    DeviationCause[]
  analyses  DeviationAnalysis[]
  actions   ActionPlan[]        @relation("ActionFromDeviation")

  @@index([companyId])
  @@index([indicatorId])
  @@unique([companyId, number])
}

model DeviationCause {
  id          String    @id @default(uuid())
  deviationId String
  deviation   Deviation @relation(fields: [deviationId], references: [id], onDelete: Cascade)
  category    String?   // 6M ex.: Metodo, Maquina, MO, Material, Medida, Meio
  description String
  weight      Float     @default(1)
  createdAt   DateTime  @default(now())
}

model DeviationAnalysis {
  id          String         @id @default(uuid())
  deviationId String
  deviation   Deviation      @relation(fields: [deviationId], references: [id], onDelete: Cascade)
  method      AnalysisMethod
  content     String         // texto livre ou JSON serializado
  createdAt   DateTime       @default(now())
}

// =====================================================
// Planos de acao
// =====================================================

model ActionPlan {
  id                String         @id @default(uuid())
  companyId         String
  company           Company        @relation(fields: [companyId], references: [id])
  ownerNodeId       String?
  ownerNode         OrgNode?       @relation("ActionOwnerNode", fields: [ownerNodeId], references: [id])
  responsibleUserId String?
  responsibleUser   User?          @relation("ActionResponsible", fields: [responsibleUserId], references: [id])
  createdById       String?
  createdBy         User?          @relation("ActionCreatedBy", fields: [createdById], references: [id])

  title          String
  description    String?
  origin         ActionOrigin   @default(MANUAL)
  originRefId    String?
  priority       ActionPriority @default(MEDIUM)
  status         ActionStatus   @default(NOT_STARTED)
  startDate      DateTime?
  dueDate        DateTime?
  completedAt    DateTime?
  progress       Float          @default(0) // 0..100
  estimatedCost  Float?
  actualCost     Float?

  deviationId    String?
  deviation      Deviation?     @relation("ActionFromDeviation", fields: [deviationId], references: [id])

  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  deletedAt      DateTime?

  tasks          ActionTask[]

  @@index([companyId])
  @@index([status])
  @@index([dueDate])
}

model ActionTask {
  id          String      @id @default(uuid())
  actionId    String
  action      ActionPlan  @relation(fields: [actionId], references: [id], onDelete: Cascade)
  title       String
  done        Boolean     @default(false)
  dueDate     DateTime?
  position    Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

// =====================================================
// Projetos e cronograma
// =====================================================

model Project {
  id          String         @id @default(uuid())
  companyId   String
  company     Company        @relation(fields: [companyId], references: [id])
  name        String
  description String?
  status      ProjectStatus  @default(PLANNED)
  startsAt    DateTime?
  endsAt      DateTime?
  responsible String?
  budget      Float?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  deletedAt   DateTime?

  milestones  ProjectMilestone[]
  tasks       ProjectTask[]

  @@index([companyId])
}

model ProjectMilestone {
  id        String   @id @default(uuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name      String
  dueDate   DateTime
  done      Boolean  @default(false)
}

model ProjectTask {
  id            String       @id @default(uuid())
  projectId     String
  project       Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name          String
  startDate     DateTime?
  endDate       DateTime?
  progress      Float        @default(0)
  responsible   String?
  dependencyId  String?
  dependency    ProjectTask? @relation("TaskDep", fields: [dependencyId], references: [id])
  dependents    ProjectTask[] @relation("TaskDep")
  position      Int          @default(0)
}

// =====================================================
// Reunioes
// =====================================================

model Meeting {
  id          String       @id @default(uuid())
  companyId   String
  company     Company      @relation(fields: [companyId], references: [id])
  title       String
  kind        MeetingKind
  startsAt    DateTime
  endsAt      DateTime?
  location    String?
  notes       String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deletedAt   DateTime?

  participants  MeetingParticipant[]
  agendaItems   MeetingAgendaItem[]
  decisions     MeetingDecision[]

  @@index([companyId])
  @@index([startsAt])
}

model MeetingParticipant {
  id        String   @id @default(uuid())
  meetingId String
  meeting   Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  attended  Boolean  @default(false)

  @@unique([meetingId, userId])
}

model MeetingAgendaItem {
  id        String   @id @default(uuid())
  meetingId String
  meeting   Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  topic     String
  notes     String?
  position  Int      @default(0)
}

model MeetingDecision {
  id        String   @id @default(uuid())
  meetingId String
  meeting   Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  decision  String
  owner     String?
  dueDate   DateTime?
}

// =====================================================
// Suporte: anexos, comentarios, notificacoes
// =====================================================

model Attachment {
  id         String   @id @default(uuid())
  refTable   String   // ex.: "Deviation", "ActionPlan", "IndicatorResult"
  refId      String
  fileName   String
  fileUrl    String
  mimeType   String?
  sizeBytes  Int?
  createdAt  DateTime @default(now())
  createdBy  String?

  @@index([refTable, refId])
}

model Comment {
  id        String   @id @default(uuid())
  refTable  String
  refId     String
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  body      String
  createdAt DateTime @default(now())

  @@index([refTable, refId])
}

model Notification {
  id        String           @id @default(uuid())
  companyId String
  company   Company          @relation(fields: [companyId], references: [id])
  userId    String
  user      User             @relation(fields: [userId], references: [id])
  kind      NotificationKind
  title     String
  body      String?
  link      String?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([userId, readAt])
}

// =====================================================
// Importacao de dados
// =====================================================

model ImportJob {
  id         String           @id @default(uuid())
  companyId  String
  company    Company          @relation(fields: [companyId], references: [id])
  target     ImportTargetKind
  fileName   String
  totalRows  Int              @default(0)
  okRows     Int              @default(0)
  errorRows  Int              @default(0)
  startedAt  DateTime         @default(now())
  finishedAt DateTime?

  errors     ImportError[]

  @@index([companyId])
}

model ImportError {
  id       String     @id @default(uuid())
  jobId    String
  job      ImportJob  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  rowIndex Int
  message  String
  status   ImportRowStatus @default(ERROR)
  payload  String?
}

// =====================================================
// Auditoria & Configuracoes
// =====================================================

model AuditLog {
  id        String   @id @default(uuid())
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String   // "CREATE", "UPDATE", "DELETE", "LOGIN" ...
  entity    String
  entityId  String?
  payload   String?  // JSON serializado do diff
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([companyId, createdAt])
  @@index([entity, entityId])
}

model AppSetting {
  id        String   @id @default(uuid())
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])
  key       String
  value     String
  updatedAt DateTime @updatedAt

  @@unique([companyId, key])
}
