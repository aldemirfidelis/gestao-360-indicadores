  organizationalUnitActivities OrganizationalUnitActivity[] @relation("OrgUnitActivityCompany")
  monthlyMeetings              MonthlyMeeting[]
  communicationPosts           CommunicationPost[]
  communicationCampaigns       CommunicationCampaign[]
  communicationMedia           CommunicationMedia[]
}

model WorkPeriod {
  id          String           @id @default(uuid())
  companyId   String
  company     Company          @relation(fields: [companyId], references: [id])
  year        Int
  name        String
  startsAt    DateTime
  endsAt      DateTime
  status      WorkPeriodStatus @default(OPEN)
  isCurrent   Boolean          @default(false)
  closedAt    DateTime?
  closedById  String?
  createdById String?
  updatedById String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  deletedAt   DateTime?

  @@unique([companyId, year])
  @@index([companyId, isCurrent])
  @@index([companyId, status])
}

model Branch {
  id        String    @id @default(uuid())
  companyId String
  company   Company   @relation(fields: [companyId], references: [id])
  name      String
  code      String?
  city      String?
  state     String?
  active    Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  orgNodes OrgNode[]
  users    User[]
  actions  ActionPlan[]

  @@index([companyId])
}

model OrgNode {
  id        String    @id @default(uuid())
  companyId String
  company   Company   @relation(fields: [companyId], references: [id])
  branchId  String?
  branch    Branch?   @relation(fields: [branchId], references: [id])
  parentId  String?
  parent    OrgNode?  @relation("OrgNodeChildren", fields: [parentId], references: [id])
  children  OrgNode[] @relation("OrgNodeChildren")

  name        String
  code        String?
  type        OrgNodeType
  description String?
  color       String?
  icon        String?
  active      Boolean     @default(true)
  position    Int         @default(0)

  // Rastreio de origem para integracao/migracao de sistemas legados
  // externalId  = chave primaria no sistema de origem.
  // externalSource = identificador da origem.
  externalId     String?
  externalSource String?

  responsibleUserId String?
  responsibleUser   User?   @relation("OrgNodeResponsible", fields: [responsibleUserId], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  indicatorsOwned         Indicator[]                  @relation("IndicatorOwnerNode")
  guidelineIndicators     Indicator[]                  @relation("IndicatorGuidelineNode")
  defaultForUsers         User[]                       @relation("UserDefaultNode")
  actions                 ActionPlan[]                 @relation("ActionOwnerNode")
  risks                   RiskRegister[]               @relation("RiskOwnerNode")
  nonConformities         NonConformity[]              @relation("NcOwnerNode")
  documents               Document[]                   @relation("DocOrgNode")
  audits                  Audit[]                      @relation("AuditOrgNode")
  processes               Process[]                    @relation("ProcessOrgNode")
  fsPrograms              FoodSafetyProgram[]          @relation("FsProgramOrgNode")
  fsProcesses             FoodSafetyProcess[]          @relation("FsProcessOrgNode")
  fsSuppliers             FoodSafetySupplier[]         @relation("FsSupplierOrgNode")
  formTemplates           FormTemplate[]               @relation("FormTemplateOrgNode")
  formSubmissions         FormSubmission[]             @relation("FormSubmissionOrgNode")
  strategicObjectives     StrategicObjective[]         @relation("StrategicObjectiveOwnerNode")
  strategicObjectiveLinks StrategicObjectiveOrgNode[]
  orgEmployees            OrgEmployee[]
  activities              OrganizationalUnitActivity[] @relation("OrgNodeActivities")
  okrObjectives           OKRObjective[]               @relation("OKRObjectiveOwnerNode")
  monthlyMeetingAreas     MonthlyMeetingArea[]         @relation("MonthlyAreaOrgNode")

  @@unique([companyId, externalSource, externalId])
  @@index([companyId])
  @@index([parentId])
  @@index([branchId])
  @@index([externalSource, externalId])
}

model OrganizationalUnitActivity {
  id                   String    @id @default(uuid())
  companyId            String    @map("company_id")
  company              Company   @relation("OrgUnitActivityCompany", fields: [companyId], references: [id])
  organizationalUnitId String    @map("organizational_unit_id")
  organizationalUnit   OrgNode   @relation("OrgNodeActivities", fields: [organizationalUnitId], references: [id])
  title                String
  description          String?
  orderIndex           Int       @default(0) @map("order_index")
  isActive             Boolean   @default(true) @map("is_active")
  createdAt            DateTime  @default(now()) @map("created_at")
  createdById          String?   @map("created_by")
  updatedAt            DateTime  @updatedAt @map("updated_at")
  updatedById          String?   @map("updated_by")
  deletedAt            DateTime? @map("deleted_at")

  items OrganizationalUnitActivityItem[]

  @@index([companyId, organizationalUnitId, orderIndex])
  @@index([companyId, isActive])
  @@map("organizational_unit_activities")
}

model OrganizationalUnitActivityItem {
  id          String                     @id @default(uuid())
  activityId  String                     @map("activity_id")
  activity    OrganizationalUnitActivity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  description String
  orderIndex  Int                        @default(0) @map("order_index")
  isActive    Boolean                    @default(true) @map("is_active")
  createdAt   DateTime                   @default(now()) @map("created_at")
  createdById String?                    @map("created_by")
  updatedAt   DateTime                   @updatedAt @map("updated_at")
  updatedById String?                    @map("updated_by")
  deletedAt   DateTime?                  @map("deleted_at")

  @@index([activityId, orderIndex])
  @@index([activityId, isActive])
  @@map("organizational_unit_activity_items")
}

