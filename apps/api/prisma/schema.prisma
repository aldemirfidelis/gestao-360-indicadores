// =====================================================
// Processos e SIPOC
// =====================================================

enum ProcessType {
  CORE // finalistico / primario
  SUPPORT // apoio
  MANAGEMENT // gerencial / estrategico
}

enum ProcessStatus {
  DRAFT // mapeamento em rascunho
  ACTIVE // vigente
  UNDER_REVIEW // em revisao
  ARCHIVED // arquivado
}

model Process {
  id          String     @id @default(uuid())
  companyId   String
  company     Company    @relation(fields: [companyId], references: [id])
  number      Int // sequencial por empresa
  code        String? // codigo do processo (ex.: PR-001)
  orgNodeId   String?
  orgNode     OrgNode?   @relation("ProcessOrgNode", fields: [orgNodeId], references: [id])
  indicatorId String?
  indicator   Indicator? @relation("ProcessIndicator", fields: [indicatorId], references: [id])
  ownerUserId String?
  owner       User?      @relation("ProcessOwner", fields: [ownerUserId], references: [id])
  createdById String?
  createdBy   User?      @relation("ProcessCreatedBy", fields: [createdById], references: [id])

  name        String
  description String?
  objective   String? // objetivo do processo
  type        ProcessType   @default(CORE)
  status      ProcessStatus @default(DRAFT)
  version     String? // versao do mapeamento (ex.: "1.0")
  // SIPOC (texto livre, um por linha)
  suppliers   String? // fornecedores
  inputs      String? // entradas
  outputs     String? // saidas
  customers   String? // clientes
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?

  steps           ProcessStep[]
  formTemplates   FormTemplate[]   @relation("FormTemplateProcess")
  formSubmissions FormSubmission[] @relation("FormSubmissionProcess")

  @@unique([companyId, number])
  @@index([companyId])
  @@index([companyId, status])
  @@index([type])
  @@index([orgNodeId])
  @@index([indicatorId])
  @@index([ownerUserId])
}

model ProcessStep {
  id          String   @id @default(uuid())
  processId   String
  process     Process  @relation(fields: [processId], references: [id], onDelete: Cascade)
  order       Int // ordem da etapa no fluxo
  name        String
  description String?
  responsible String? // papel/area responsavel pela etapa (texto livre)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([processId])
}

