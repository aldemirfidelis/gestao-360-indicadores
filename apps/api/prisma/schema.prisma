// =====================================================
// Gestao de Premio - Fase 6: Espelho do Premio (Demonstrativo)
// Snapshot imutavel por versao. Publicar nao sobrescreve: gera nova versao.
// PDF e renderizado no cliente (jsPDF) a partir do snapshot congelado (data).
// =====================================================

enum PrizePayslipStatus {
  DRAFT
  GENERATED
  PUBLISHED
  SUPERSEDED
}

model PrizePayslip {
  id               String             @id @default(uuid())
