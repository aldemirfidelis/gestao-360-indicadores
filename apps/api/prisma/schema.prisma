// =====================================================
// Auditorias e compliance
// =====================================================

enum AuditType {
  INTERNAL
  EXTERNAL
  PROCESS
  SUPPLIER
  LEGAL
  SAFETY
  QUALITY
  CERTIFICATION
  MAINTENANCE
  RECERTIFICATION
  PRODUCT
  MANAGEMENT_SYSTEM
  DOCUMENTAL
  OPERATIONAL
  INTEGRATED
  COMPLIANCE
  INTERNAL_CONTROLS
  PROJECT
  EXTRAORDINARY
  FOLLOW_UP
  INSPECTION
  DIAGNOSTIC
  REMOTE
  PRESENTIAL
  HYBRID
}

enum AuditStatus {
  DRAFT
  WAITING_APPROVAL
  PLANNED
  SCHEDULED
  PREPARATION
  READY_EXECUTION
  IN_PROGRESS
  WAITING_COMPLEMENT
  LEAD_REVIEW
  WAITING_AUDITED_RESPONSE
  REPORT_ISSUED
  FOLLOW_UP
  COMPLETED
  CLOSED
  SUSPENDED
  CANCELLED
  RESCHEDULED
}

enum AuditFindingType {
  CONFORMITY
  PARTIAL_CONFORMITY
  NONCONFORMITY
  OBSERVATION
  OPPORTUNITY
  STRENGTH
  GOOD_PRACTICE
  RECOMMENDATION
  IDENTIFIED_RISK
  DEVIATION
  MINOR_NONCONFORMITY
  MAJOR_NONCONFORMITY
  CRITICAL_NONCONFORMITY
  DOCUMENT_PENDING
  INSUFFICIENT_EVIDENCE
  NOT_VERIFIED
}

enum AuditFindingStatus {
  DRAFT
  OPEN
  UNDER_REVIEW
  WAITING_AUDITED_RESPONSE
  ACTION_REQUIRED
  IN_TREATMENT
  CONVERTED_TO_NC
  IN_FOLLOW_UP
  CLOSED
  CANCELLED
}

enum AuditModality {
  PRESENTIAL
  REMOTE
  HYBRID
}

enum AuditProgramStatus {
  DRAFT
  WAITING_APPROVAL
  APPROVED
  ACTIVE
  COMPLETED
  CANCELLED
  ARCHIVED
}

enum AuditUniverseItemKind {
  COMPANY
  BRANCH
  AREA
  SECTOR
  PROCESS
  SUBPROCESS
  ACTIVITY
  PROJECT
  CONTRACT
  SUPPLIER
  OPERATIONAL_UNIT
  DOCUMENT
  LEGAL_REQUIREMENT
  STANDARD
  INTERNAL_CONTROL
  RISK
  INDICATOR
  STRATEGIC_OBJECTIVE
  STAKEHOLDER
  CUSTOM
}

enum AuditRiskLevel {
  LOW
  MODERATE
  HIGH
  CRITICAL
}

enum AuditorKind {
  INTERNAL
  EXTERNAL
}

enum AuditorStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  EXPIRED
}

enum AuditChecklistTemplateStatus {
  DRAFT
  IN_REVIEW
  APPROVED
  ARCHIVED
}

enum AuditChecklistResponseKind {
  CONFORMING
  NONCONFORMING
  PARTIALLY_CONFORMING
  NOT_APPLICABLE
  NOT_VERIFIED
  PENDING_EVIDENCE
  OPPORTUNITY
  OBSERVATION
  GOOD_PRACTICE
}

enum AuditEvidenceStatus {
  ACTIVE
  UNDER_REVIEW
  APPROVED
  REJECTED
  ARCHIVED
}

enum AuditApprovalDecision {
  PENDING
  APPROVED
  REJECTED
  ADJUSTMENTS_REQUESTED
}

enum AuditFollowUpStatus {
  OPEN
  IN_PROGRESS
  EFFECTIVE
  INEFFECTIVE
  CLOSED
  CANCELLED
}

enum AuditAiSuggestionStatus {
  PENDING
  ACCEPTED
  REJECTED
  APPLIED
}

model Audit {
  id                String   @id @default(uuid())
  companyId         String
  company           Company  @relation(fields: [companyId], references: [id])
  number            Int // sequencial por empresa
  code              String?
  programId         String?
  typeConfigId      String?
  universeItemId    String?
  orgNodeId         String?
  orgNode           OrgNode? @relation("AuditOrgNode", fields: [orgNodeId], references: [id])
  leadAuditorUserId String?
  leadAuditor       User?    @relation("AuditLead", fields: [leadAuditorUserId], references: [id])
  createdById       String?
  createdBy         User?    @relation("AuditCreatedBy", fields: [createdById], references: [id])

  title            String
  scope            String?
  objective        String?
  criteria         String?
  methodology      String?
  origin           String?
  type             AuditType     @default(INTERNAL)
  modality         AuditModality @default(PRESENTIAL)
  status           AuditStatus   @default(PLANNED)
  plannedDate      DateTime?
  plannedStartAt   DateTime?
  plannedEndAt     DateTime?
  executedAt       DateTime?
  startedAt        DateTime?
  completedAt      DateTime?
  closedAt         DateTime?
  estimatedHours   Float?
  actualHours      Float?
  locations        Json?
  agenda           Json?
  team             Json?
  auditees         Json?
  approvers        Json?
  observers        Json?
  standards        Json?
  requirements     Json?
  documents        Json?
  risks            Json?
  meetingUrl       String?
  version          Int           @default(1)
  score            Float?
  result           String?
  opinion          String?
  summary          String? // relatorio / conclusao
  followUpPlan     String?
  confidentiality  String        @default("INTERNAL")
  cancelledReason  String?
  rescheduleReason String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  deletedAt        DateTime?

  findings            AuditFinding[]
  checklistExecutions AuditChecklistExecution[]
  evidence            AuditEvidence[]
  reports             AuditReport[]
  approvals           AuditApproval[]
  followUps           AuditFollowUp[]
  timelineEvents      AuditTimelineEvent[]
  externalAccesses    AuditExternalAccess[]
  aiSuggestions       AuditAiSuggestion[]

  @@unique([companyId, number])
  @@unique([companyId, code])
  @@index([companyId])
  @@index([companyId, status])
  @@index([programId])
  @@index([typeConfigId])
  @@index([universeItemId])
  @@index([type])
  @@index([orgNodeId])
  @@index([leadAuditorUserId])
  @@index([plannedDate])
}

model AuditFinding {
  id              String         @id @default(uuid())
  companyId       String
  auditId         String
  audit           Audit          @relation(fields: [auditId], references: [id], onDelete: Cascade)
  nonConformityId String?
  nonConformity   NonConformity? @relation("FindingNc", fields: [nonConformityId], references: [id])

  code                 String?
  type                 AuditFindingType       @default(OBSERVATION)
  severity             NonConformitySeverity?
  status               AuditFindingStatus     @default(OPEN)
  requirement          String? // requisito / clausula auditada
  standardId           String?
  requirementId        String?
  orgNodeId            String?
  processId            String?
  supplierId           String?
  checklistExecutionId String?
  checklistItemId      String?
  description          String
  conditionFound       String?
  expectedCriteria     String?
  riskImpact           String?
  classificationId     String?
  responsibleUserId    String?
  auditorUserId        String?
  auditedUserId        String?
  criticality          String?
  recurrence           Boolean                @default(false)
  similarFindingIds    String[]               @default([])
  actionPlanIds        String[]               @default([])
  documentIds          String[]               @default([])
  indicatorIds         String[]               @default([])
  riskIds              String[]               @default([])
  evidence             String?
  recommendation       String?
  dueDate              DateTime?
  approvedAt           DateTime?
  approvedById         String?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  deletedAt            DateTime?

  @@unique([companyId, code])
  @@index([companyId])
  @@index([auditId])
  @@index([nonConformityId])
  @@index([status])
  @@index([type])
  @@index([orgNodeId])
  @@index([responsibleUserId])
  @@index([dueDate])
}

model AuditProgram {
  id             String             @id @default(uuid())
  companyId      String
  code           String
  number         Int
  name           String
  description    String?
  status         AuditProgramStatus @default(DRAFT)
  cycleKind      String?
  branchId       String?
  ownerUserId    String?
  approverUserId String?
  startsAt       DateTime?
  endsAt         DateTime?
  approvedAt     DateTime?
  approvedById   String?
  objectives     Json?
  standards      Json?
  orgNodeIds     String[]           @default([])
  processIds     String[]           @default([])
  supplierIds    String[]           @default([])
  documentIds    String[]           @default([])
  riskIds        String[]           @default([])
  indicatorIds   String[]           @default([])
  estimatedHours Float?
  budget         Float?
  version        Int                @default(1)
  attachments    Json?
  comments       String?
  createdById    String?
  updatedById    String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  deletedAt      DateTime?

  revisions AuditProgramRevision[]

  @@unique([companyId, code])
  @@unique([companyId, number])
  @@index([companyId])
  @@index([companyId, status])
  @@index([ownerUserId])
  @@index([approverUserId])
  @@index([startsAt, endsAt])
}

model AuditProgramRevision {
  id           String       @id @default(uuid())
  companyId    String
  programId    String
  program      AuditProgram @relation(fields: [programId], references: [id], onDelete: Cascade)
  version      Int
  reason       String
  summary      String?
  snapshot     Json?
  createdById  String?
  approvedById String?
  approvedAt   DateTime?
  createdAt    DateTime     @default(now())

  @@unique([programId, version])
  @@index([companyId])
  @@index([programId])
}

model AuditTypeConfig {
  id                      String        @id @default(uuid())
  companyId               String
  name                    String
  code                    String
  prefix                  String
  description             String?
  category                AuditType     @default(INTERNAL)
  defaultModality         AuditModality @default(PRESENTIAL)
  color                   String?
  icon                    String?
  codePattern             String        @default("AUD-{{YEAR}}-{{SEQ}}")
  digits                  Int           @default(4)
  nextNumber              Int           @default(1)
  active                  Boolean       @default(true)
  requiresChecklist       Boolean       @default(false)
  requiresLeadAuditor     Boolean       @default(true)
  allowsRemote            Boolean       @default(true)
  allowsMultipleStandards Boolean       @default(true)
  workflow                Json?
  rules                   Json?
  createdById             String?
  updatedById             String?
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt
  deletedAt               DateTime?

  @@unique([companyId, code])
  @@index([companyId])
  @@index([companyId, active])
  @@index([category])
}

model AuditUniverseItem {
  id                       String                @id @default(uuid())
  companyId                String
  code                     String
  name                     String
  kind                     AuditUniverseItemKind @default(AREA)
  description              String?
  branchId                 String?
  orgNodeId                String?
  processId                String?
  supplierId               String?
  documentId               String?
  riskId                   String?
  indicatorId              String?
  strategicObjectiveId     String?
  ownerUserId              String?
  riskScore                Float                 @default(0)
  riskLevel                AuditRiskLevel        @default(LOW)
  priority                 Int                   @default(0)
  recommendedFrequencyDays Int?
  lastAuditAt              DateTime?
  nextSuggestedAuditAt     DateTime?
  manualOverride           Boolean               @default(false)
  overrideJustification    String?
  riskFactors              Json?
  status                   String                @default("ACTIVE")
  createdById              String?
  updatedById              String?
  createdAt                DateTime              @default(now())
  updatedAt                DateTime              @updatedAt
  deletedAt                DateTime?

  scores AuditRiskScore[]

  @@unique([companyId, code])
  @@index([companyId])
  @@index([companyId, kind])
  @@index([companyId, riskLevel])
  @@index([orgNodeId])
  @@index([processId])
  @@index([supplierId])
  @@index([riskId])
  @@index([indicatorId])
}

model AuditRiskCriterion {
  id              String    @id @default(uuid())
  companyId       String
  name            String
  key             String
  description     String?
  weight          Float     @default(1)
  minScore        Int       @default(1)
  maxScore        Int       @default(5)
  defaultScore    Int       @default(3)
  formulaVariable String?
  active          Boolean   @default(true)
  createdById     String?
  updatedById     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  @@unique([companyId, key])
  @@index([companyId])
  @@index([companyId, active])
}

model AuditRiskScore {
  id                       String            @id @default(uuid())
  companyId                String
  universeItemId           String
  universeItem             AuditUniverseItem @relation(fields: [universeItemId], references: [id], onDelete: Cascade)
  calculatedScore          Float
  level                    AuditRiskLevel
  criteriaValues           Json?
  formulaSnapshot          String?
  recommendedFrequencyDays Int?
  changedById              String?
  justification            String?
  createdAt                DateTime          @default(now())

  @@index([companyId])
  @@index([universeItemId, createdAt])
  @@index([level])
}

model AuditorProfile {
  id                String        @id @default(uuid())
  companyId         String
  userId            String?
  kind              AuditorKind   @default(INTERNAL)
  status            AuditorStatus @default(ACTIVE)
  name              String
  email             String?
  companyName       String?
  phone             String?
  orgNodeIds        String[]      @default([])
  allowedAreaIds    String[]      @default([])
  restrictedAreaIds String[]      @default([])
  specialties       String[]      @default([])
  standards         String[]      @default([])
  competenceLevel   Int           @default(1)
  workloadHours     Float         @default(0)
  conflictPolicy    String        @default("WARN")
  availability      Json?
  notes             String?
  docs              Json?
  createdById       String?
  updatedById       String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  deletedAt         DateTime?

  competencies   AuditorCompetency[]
  certifications AuditorCertification[]
  availabilities AuditorAvailability[]
  conflicts      AuditorConflict[]

  @@unique([companyId, userId])
  @@index([companyId])
  @@index([companyId, status])
  @@index([userId])
}

model AuditorCompetency {
  id                  String         @id @default(uuid())
  companyId           String
  auditorProfileId    String
  auditor             AuditorProfile @relation(fields: [auditorProfileId], references: [id], onDelete: Cascade)
  name                String
  standardCode        String?
  requirement         String?
  level               Int            @default(1)
  validFrom           DateTime?
  validUntil          DateTime?
  evidenceDocumentIds String[]       @default([])
  status              String         @default("VALID")
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  deletedAt           DateTime?

  @@index([companyId])
  @@index([auditorProfileId])
  @@index([standardCode])
  @@index([validUntil])
}

model AuditorCertification {
  id                String         @id @default(uuid())
  companyId         String
  auditorProfileId  String
  auditor           AuditorProfile @relation(fields: [auditorProfileId], references: [id], onDelete: Cascade)
  name              String
  issuer            String?
  certificateNumber String?
  validFrom         DateTime?
  validUntil        DateTime?
  documentIds       String[]       @default([])
  status            String         @default("VALID")
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  deletedAt         DateTime?

  @@index([companyId])
  @@index([auditorProfileId])
  @@index([validUntil])
}

model AuditorAvailability {
  id               String         @id @default(uuid())
  companyId        String
  auditorProfileId String
  auditor          AuditorProfile @relation(fields: [auditorProfileId], references: [id], onDelete: Cascade)
  startsAt         DateTime
  endsAt           DateTime
  status           String         @default("AVAILABLE")
  notes            String?
  createdAt        DateTime       @default(now())

  @@index([companyId])
  @@index([auditorProfileId, startsAt, endsAt])
}

model AuditorConflict {
  id               String         @id @default(uuid())
  companyId        String
  auditorProfileId String
  auditor          AuditorProfile @relation(fields: [auditorProfileId], references: [id], onDelete: Cascade)
  auditId          String?
  orgNodeId        String?
  conflictType     String
  severity         String         @default("WARN")
  description      String?
  justification    String?
  approvedById     String?
  approvedAt       DateTime?
  status           String         @default("OPEN")
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([companyId])
  @@index([auditorProfileId])
  @@index([auditId])
  @@index([orgNodeId])
}

model AuditStandard {
  id             String    @id @default(uuid())
  companyId      String
  code           String
  name           String
  version        String?
  description    String?
  issuer         String?
  effectiveFrom  DateTime?
  effectiveUntil DateTime?
  status         String    @default("ACTIVE")
  documents      Json?
  controls       Json?
  risks          Json?
  createdById    String?
  updatedById    String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  requirements AuditRequirement[]

  @@unique([companyId, code, version])
  @@index([companyId])
  @@index([companyId, status])
}

model AuditRequirement {
  id               String        @id @default(uuid())
  companyId        String
  standardId       String
  standard         AuditStandard @relation(fields: [standardId], references: [id], onDelete: Cascade)
  clause           String
  code             String?
  title            String
  description      String?
  evidenceExpected Json?
  controls         Json?
  risks            Json?
  status           String        @default("ACTIVE")
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  deletedAt        DateTime?

  @@unique([standardId, clause])
  @@index([companyId])
  @@index([standardId])
}

model AuditFindingClassification {
  id             String                 @id @default(uuid())
  companyId      String
  name           String
  code           String
  findingType    AuditFindingType       @default(OBSERVATION)
  severity       NonConformitySeverity?
  color          String?
  level          Int                    @default(1)
  requiresNc     Boolean                @default(false)
  requiresAction Boolean                @default(false)
  active         Boolean                @default(true)
  rules          Json?
  createdById    String?
  updatedById    String?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  deletedAt      DateTime?

  @@unique([companyId, code])
  @@index([companyId])
  @@index([companyId, active])
}

model AuditChecklistTemplate {
  id               String                       @id @default(uuid())
  companyId        String
  code             String
  name             String
  description      String?
  status           AuditChecklistTemplateStatus @default(DRAFT)
  version          Int                          @default(1)
  auditType        AuditType?
  modality         AuditModality?
  standardId       String?
  orgNodeId        String?
  processId        String?
  supplierId       String?
  requiresApproval Boolean                      @default(false)
  approvedAt       DateTime?
  approvedById     String?
  createdById      String?
  updatedById      String?
  createdAt        DateTime                     @default(now())
  updatedAt        DateTime                     @updatedAt
  deletedAt        DateTime?

  sections AuditChecklistSection[]

  @@unique([companyId, code])
  @@index([companyId])
  @@index([companyId, status])
