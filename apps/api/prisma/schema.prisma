// =====================================================
// Anexos e comentarios de resultados lancados
// Armazenados no proprio banco (Postgres) - limite de 5 MB por arquivo aplicado na API.
// Chaveados por (indicatorId, periodRef) para nao depender do id do resultado.
// =====================================================

model IndicatorResultAttachment {
  id          String   @id @default(uuid())
  companyId   String
  indicatorId String
  periodRef   String
  fileName    String
  mimeType    String?
  sizeBytes   Int?
  data        Bytes
  createdById String?
  createdAt   DateTime @default(now())

  @@index([companyId])
  @@index([indicatorId, periodRef])
}

model IndicatorResultComment {
  id          String   @id @default(uuid())
  companyId   String
  indicatorId String
  periodRef   String
  body        String
  authorId    String?
  authorName  String?
  createdAt   DateTime @default(now())

  @@index([companyId])
  @@index([indicatorId, periodRef])
}

// ===========================================================================
// Administração do Banco de Dados (Configurações > Banco de Dados)
// Tabelas administrativas dedicadas. Sem relação Prisma com User para manter
// o módulo desacoplado e o log imutável mesmo se o usuário for removido;
// identidade do ator é denormalizada (userId/userEmail/userRole).
// ===========================================================================

model DbAdminAuditLog {
  id             String   @id @default(uuid())
  userId         String?
  userEmail      String?
  userRole       String?
  submenu        String // overview | tables | records | query | structure | indexes | import-export | backup | audit | diagnostics | settings
  action         String // ACCESS | DENIED | SELECT | INSERT | UPDATE | DELETE | DDL | EXPORT | IMPORT | BACKUP | RESTORE | TRUNCATE | DROP ...
  mode           String? // safe | advanced
  targetTable    String?
  targetRecordId String?
  sqlText        String? // comando executado (redigido quando não permitido)
  beforeValue    String? // JSON
  afterValue     String? // JSON
  rowsAffected   Int?
  result         String   @default("SUCCESS") // SUCCESS | ERROR | DENIED
  message        String?
  transactionId  String?
  backupId       String?
  origin         String?
  ip             String?
  userAgent      String?
  createdAt      DateTime @default(now())

  @@index([createdAt])
  @@index([userId, createdAt])
  @@index([submenu, action])
  @@index([targetTable])
  @@index([result])
}

model DbAdminBackup {
  id                String   @id @default(uuid())
  userId            String?
  userEmail         String?
  type              String // PRE_OP | TABLE_EXPORT | MANUAL_LOGICAL
  reason            String?
  relatedOperation  String?
  targetTables      String // JSON array de nomes de tabela
  format            String   @default("json") // json | sql
  filePath          String
  sizeBytes         Int      @default(0)
  rowCount          Int      @default(0)
  checksum          String?
  important         Boolean  @default(false)
  status            String   @default("AVAILABLE") // AVAILABLE | RESTORED | DELETED | CORRUPTED
  integrityVerified Boolean  @default(false)
  createdAt         DateTime @default(now())

  @@index([createdAt])
  @@index([type])
  @@index([status])
}

model DbAdminSavedQuery {
  id         String    @id @default(uuid())
  userId     String?
  name       String
  sql        String
  isFavorite Boolean   @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  lastRunAt  DateTime?

  @@index([userId])
  @@index([isFavorite])
}

model DbAdminQueryHistory {
  id         String   @id @default(uuid())
  userId     String?
  sql        String
  mode       String   @default("safe") // safe | advanced
  durationMs Int?
  rowCount   Int?
  success    Boolean  @default(true)
  message    String?
  createdAt  DateTime @default(now())

  @@index([userId, createdAt])
  @@index([createdAt])
}

// ===========================================================================
// Central de Administração do Portal (Configurações > Configurações Avançadas)
// Overlay sobre módulos/páginas/menu definidos em código. Reusa o RBAC
// (Permission/AccessProfile), AppSetting (parâmetros) e OrgNode (escopo).
// Listas (roles/escopos/dependências) são JSON serializado em String.
// ===========================================================================

model PortalModule {
  id                      String    @id @default(uuid())
  code                    String    @unique
  name                    String
  description             String?
  category                String?
  icon                    String?
  route                   String?
  menuOrder               Int       @default(0)
  status                  String    @default("ACTIVE") // ACTIVE|INACTIVE|HIDDEN|MAINTENANCE|EXPERIMENTAL|SCHEDULED|BLOCKED|DISCONTINUED|RESTRICTED_ROLE|RESTRICTED_SCOPE
  version                 String?
  criticality             String    @default("medium") // low|medium|high|critical
  dependencies            String    @default("[]")
  allowedRoles            String    @default("[]")
  allowedScopes           String    @default("[]")
  systemRequired          Boolean   @default(false)
  nonBlockable            Boolean   @default(false)
  experimental            Boolean   @default(false)
  unavailableMessage      String?
  scheduledActivationAt   DateTime?
  scheduledDeactivationAt DateTime?
  updatedBy               String?
  updateReason            String?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  @@index([status])
  @@index([category])
}

model PortalPage {
  id                 String   @id @default(uuid())
  moduleCode         String?
  code               String   @unique
  name               String
  title              String?
  route              String?
  description        String?
  status             String   @default("ACTIVE")
  menuOrder          Int      @default(0)
  component          String?
  allowedRoles       String   @default("[]")
  allowedScopes      String   @default("[]")
  unavailableMessage String?
  updatedBy          String?
  updateReason       String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([moduleCode])
  @@index([status])
  @@index([route])
}

model PortalFeature {
  id            String   @id @default(uuid())
  moduleCode    String?
  pageCode      String?
  code          String   @unique
  name          String
  description   String?
  status        String   @default("ACTIVE")
  criticality   String   @default("medium")
  allowedRoles  String   @default("[]")
  allowedScopes String   @default("[]")
  dependencies  String   @default("[]")
  flagKey       String?
  updatedBy     String?
  updateReason  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([moduleCode])
  @@index([pageCode])
  @@index([status])
}

model PortalFeatureFlag {
  id                String    @id @default(uuid())
  key               String    @unique
  name              String
  description       String?
  enabled           Boolean   @default(false)
  rolloutPercentage Int?
  allowedRoles      String    @default("[]")
  allowedUserIds    String    @default("[]")
  allowedScopes     String    @default("[]")
  environment       String?
  experimental      Boolean   @default(false)
  scheduledOnAt     DateTime?
  scheduledOffAt    DateTime?
  updatedBy         String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([enabled])
}

model PortalNavOverride {
  id            String   @id @default(uuid())
  itemKey       String   @unique // href do item ou heading da seção
  kind          String   @default("item") // item|section
  hidden        Boolean  @default(false)
  order         Int?
  labelOverride String?
  iconOverride  String?
  groupOverride String?
  updatedBy     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model PortalScopeRule {
  id         String   @id @default(uuid())
  targetType String // module|page|feature
  targetCode String
  scopeType  String // company|branch|orgnode|user|role
