  quietHoursStart String? // ex.: "22:00"
  quietHoursEnd   String? // ex.: "07:00"
  updatedAt       DateTime @updatedAt
}

// =====================================================
// Multiempresa — Visibilidade e acesso por Área
// (FKs escalares por id; integridade tratada na camada de serviço/AccessService.
//  Áreas/setores = OrgNode. Área principal do usuário = User.defaultNodeId.)
// =====================================================

enum AreaAssignmentType {
  PRIMARY
  SECONDARY
  TEMPORARY
  VIEWER
}

enum VisibilityLevel {
  NONE
  SUMMARY
  FULL
  CREATE
  EDIT
  APPROVE
  DELETE
  ADMIN
}

enum VisibilityEffect {
  ALLOW
  DENY
}

// Vínculo adicional usuário-área (além da área principal em User.defaultNodeId).
model UserAreaAssignment {
  id             String             @id @default(uuid())
  userId         String
  companyId      String
  orgNodeId      String
  assignmentType AreaAssignmentType @default(SECONDARY)
  isPrimary      Boolean            @default(false)
  validFrom      DateTime?
  validUntil     DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@unique([userId, orgNodeId])
  @@index([companyId])
  @@index([userId])
  @@index([orgNodeId])
}

// Matriz de visibilidade: o que a área de origem enxerga da área de destino, por módulo.
model AreaVisibilityRule {
  id              String          @id @default(uuid())
  companyId       String
  sourceAreaId    String
  targetAreaId    String
  moduleKey       String // ex.: "indicators"; "*" = todos os módulos
  visibilityLevel VisibilityLevel @default(SUMMARY)
  canView         Boolean         @default(true)
  canCreate       Boolean         @default(false)
  canEdit         Boolean         @default(false)
  canDelete       Boolean         @default(false)
  canApprove      Boolean         @default(false)
  canExport       Boolean         @default(false)
  createdBy       String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@unique([companyId, sourceAreaId, targetAreaId, moduleKey])
  @@index([companyId])
  @@index([companyId, sourceAreaId])
  @@index([companyId, targetAreaId])
  @@index([moduleKey])
}

// Exceção individual (ALLOW/DENY) sobre uma área/módulo, com validade opcional.
model UserVisibilityException {
  id            String           @id @default(uuid())
  companyId     String
  userId        String
  targetAreaId  String
  moduleKey     String
  permissionKey String?
  effect        VisibilityEffect @default(ALLOW)
  validFrom     DateTime?
  validUntil    DateTime?
  reason        String?
  createdBy     String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([companyId])
  @@index([userId])
  @@index([userId, targetAreaId, moduleKey])
}

// ===================== Integração com APIs externas =====================
// SAP, Apdata, SE Suite e quaisquer outras (REST genérico/webhook), inbound e outbound.
// Credenciais nunca em texto puro: ficam em credentialsEnc (AES-256-GCM). FKs escalares.

enum IntegrationProvider {
  SAP
  APDATA
  SESUITE
  REST_GENERIC
  WEBHOOK
}

enum IntegrationDirection {
  INBOUND
  OUTBOUND
  BOTH
}

enum IntegrationAuthType {
  NONE
  API_KEY
  BEARER
  BASIC
  OAUTH2
}

/// Conector de integração com um sistema externo (saída/entrada), por empresa.
model ExternalIntegration {
  id             String               @id @default(uuid())
  companyId      String
  name           String
  provider       IntegrationProvider  @default(REST_GENERIC)
  direction      IntegrationDirection @default(OUTBOUND)
  authType       IntegrationAuthType  @default(API_KEY)
  baseUrl        String?
  status         String               @default("enabled") // enabled | disabled
  credentialsEnc String? // JSON cifrado (AES-256-GCM). Nunca retornado ao cliente.
  config         Json? // endpoints, headers, mapeamento de campos
  lastRunAt      DateTime?
  lastStatus     String? // SUCCESS | ERROR
  lastError      String?
  lastLatencyMs  Int?
  createdById    String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  deletedAt      DateTime?

  logs ExternalIntegrationLog[]

  @@index([companyId])
}

/// Histórico de execuções (teste/sincronização) de um conector externo.
model ExternalIntegrationLog {
  id            String               @id @default(uuid())
  integrationId String
  integration   ExternalIntegration  @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  companyId     String
  direction     IntegrationDirection
  operation     String // test | push:indicators | push:results | pull:results | ...
  status        String // SUCCESS | ERROR
  httpStatus    Int?
  message       String?
  latencyMs     Int?
  createdAt     DateTime             @default(now())

  @@index([integrationId])
  @@index([companyId])
}

/// Chave de API para sistemas externos chamarem a API pública (inbound), por empresa.
/// Guardamos apenas o hash (sha256); a chave em si é exibida uma única vez na criação.
model InboundApiKey {
  id          String    @id @default(uuid())
  companyId   String
  name        String
  keyHash     String    @unique
  keyPrefix   String // primeiros caracteres p/ exibição (ex.: g360_ab12)
  scopes      String[] // ex.: ["indicators:read","results:write"]
  status      String    @default("active") // active | revoked
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  createdById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([companyId])
}

// =====================================================
// Modulo: Seguranca dos Alimentos (FSMS) — Fase 1 (Fundacao)
// Programas, processos e etapas. Multiempresa + soft-delete, no mesmo padrao
// dos demais modulos. Perigos/APPCC, PPR/PPRO/PCC, requisitos versionados,
// fornecedores e rastreabilidade/recall entram nas fases seguintes.
// =====================================================

enum FoodSafetyProgramStatus {
  ACTIVE
  DRAFT
  ARCHIVED
}

enum FoodSafetyProcessStatus {
  DRAFT
  IN_ANALYSIS
  IN_REVIEW
  PENDING_APPROVAL
  APPROVED
  PUBLISHED
  OBSOLETE
}

enum FoodSafetyStepType {
  RECEIVING
  STORAGE
  PROCESSING
  PACKAGING
  TRANSPORT
  DISTRIBUTION
  OTHER
}

model FoodSafetyProgram {
  id          String                  @id @default(uuid())
  companyId   String
  company     Company                 @relation("FsProgramCompany", fields: [companyId], references: [id])
  orgNodeId   String?
  orgNode     OrgNode?                @relation("FsProgramOrgNode", fields: [orgNodeId], references: [id])
  ownerUserId String?
  owner       User?                   @relation("FsProgramOwner", fields: [ownerUserId], references: [id])
  createdById String?
  createdBy   User?                   @relation("FsProgramCreatedBy", fields: [createdById], references: [id])
  code        String?
  name        String
  description String?
  scope       String?
  visibility  String                  @default("PRIVATE") // PUBLIC | PRIVATE | RESTRICTED
  status      FoodSafetyProgramStatus @default(ACTIVE)
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt
  deletedAt   DateTime?

  processes FoodSafetyProcess[]
  suppliers FoodSafetySupplier[]
  materials FoodSafetyMaterial[]
  lots      FoodSafetyLot[]
  recalls   FoodSafetyRecall[]

  @@unique([companyId, code])
  @@index([companyId])
  @@index([companyId, status])
  @@index([orgNodeId])
  @@index([ownerUserId])
}

model FoodSafetyProcess {
  id                    String                  @id @default(uuid())
  companyId             String
  company               Company                 @relation("FsProcessCompany", fields: [companyId], references: [id])
  programId             String
  program               FoodSafetyProgram       @relation(fields: [programId], references: [id])
  orgNodeId             String?
  orgNode               OrgNode?                @relation("FsProcessOrgNode", fields: [orgNodeId], references: [id])
  ownerUserId           String?
  owner                 User?                   @relation("FsProcessOwner", fields: [ownerUserId], references: [id])
  createdById           String?
  createdBy             User?                   @relation("FsProcessCreatedBy", fields: [createdById], references: [id])
  number                Int
  code                  String?
  name                  String
  description           String?
  objective             String?
  productName           String?
  productionLine        String?
  version               String?
  status                FoodSafetyProcessStatus @default(DRAFT)
  positionX             Float?
  positionY             Float?
  lastReviewAt          DateTime?
  nextReviewAt          DateTime?
  reviewPeriodicityDays Int?
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  deletedAt             DateTime?

  steps   FoodSafetyProcessStep[]
  hazards FoodSafetyHazard[]
  lots    FoodSafetyLot[]         @relation("FsLotProcess")
  traces  FoodSafetyTraceLink[]   @relation("FsTraceProcess")

  @@unique([companyId, number])
  @@index([companyId])
  @@index([companyId, status])
  @@index([programId])
  @@index([orgNodeId])
  @@index([ownerUserId])
}

model FoodSafetyProcessStep {
  id             String             @id @default(uuid())
  companyId      String
  company        Company            @relation("FsStepCompany", fields: [companyId], references: [id])
  processId      String
  process        FoodSafetyProcess  @relation(fields: [processId], references: [id])
  number         Int
  code           String?
  name           String
  description    String?
  type           FoodSafetyStepType @default(OTHER)
  inputs         String?
  outputs        String?
  positionX      Float?
  positionY      Float?
  isControlPoint Boolean            @default(false)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  deletedAt      DateTime?

  hazards FoodSafetyHazard[]
  traces  FoodSafetyTraceLink[] @relation("FsTraceStep")

  @@index([companyId])
  @@index([processId])
}

// ----- Perigos / Analise APPCC (Fase 1, incremento 3) ---------------------

enum FoodSafetyHazardCategory {
  BIOLOGICAL
  CHEMICAL
  PHYSICAL
  ALLERGENIC
  RADIOLOGICAL
  FRAUD
  SABOTAGE
  CROSS_CONTAMINATION
  OTHER
}

enum FoodSafetyRiskLevel {
  LOW
  MODERATE
  HIGH
  CRITICAL
}

enum FoodSafetyControlType {
  NONE
  PRP // Programa de Pre-Requisito
  OPRP // Programa de Pre-Requisito Operacional (PPRO)
  CCP // Ponto Critico de Controle (PCC)
}

enum FoodSafetyHazardStatus {
  OPEN
  ASSESSED
  CONTROLLED
  ARCHIVED
}

// Matriz de risco configuravel por empresa (escalas e faixas dos niveis).
model FoodSafetyRiskMatrix {
  id                String    @id @default(uuid())
  companyId         String
  company           Company   @relation("FsRiskMatrixCompany", fields: [companyId], references: [id])
  name              String    @default("Matriz padrao")
  severityScale     Int       @default(5)
  probabilityScale  Int       @default(5)
  useDetection      Boolean   @default(false)
  detectionScale    Int       @default(5)
  // limites superiores (inclusivos) do indice de risco para cada nivel
  thresholdLow      Int       @default(4)
  thresholdModerate Int       @default(9)
  thresholdHigh     Int       @default(15)
  active            Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  @@index([companyId])
}

// Perigo analisado em um processo/etapa, com avaliacao de risco e classificacao
// do controle (PRP/PPRO/PCC). Monitoramento detalhado e limites entram na Fase 2.
model FoodSafetyHazard {
  id                   String                   @id @default(uuid())
  companyId            String
  company              Company                  @relation("FsHazardCompany", fields: [companyId], references: [id])
  processId            String
  process              FoodSafetyProcess        @relation(fields: [processId], references: [id])
  stepId               String?
  step                 FoodSafetyProcessStep?   @relation(fields: [stepId], references: [id])
  responsibleUserId    String?
  responsible          User?                    @relation("FsHazardResponsible", fields: [responsibleUserId], references: [id])
  number               Int
  code                 String?
  category             FoodSafetyHazardCategory @default(BIOLOGICAL)
  name                 String
  description          String?
  source               String?
  consequence          String?
  justification        String?
  severity             Int?
  probability          Int?
  detection            Int?
  riskIndex            Int?
  riskLevel            FoodSafetyRiskLevel?
  controlType          FoodSafetyControlType    @default(NONE)
  controlJustification String?
  existingControls     String?
  additionalControls   String?
  status               FoodSafetyHazardStatus   @default(OPEN)
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt
  deletedAt            DateTime?

  controlPlans FoodSafetyControlPlan[]

  @@unique([companyId, number])
  @@index([companyId])
  @@index([processId])
  @@index([stepId])
  @@index([category])
  @@index([controlType])
}

// ----- Controle operacional: PPR/PPRO/PCC (Fase 2) ------------------------

enum FoodSafetyControlPlanStatus {
  ACTIVE
  INACTIVE
}

enum FoodSafetyMonitoringResult {
  OK
  ALERT
  OUT
}

// Plano de monitoramento de um controle (PPR/PPRO/PCC) ligado a um perigo:
// parametro, limites criticos/alerta, metodo, frequencia e acoes no desvio.
model FoodSafetyControlPlan {
  id                    String                      @id @default(uuid())
  companyId             String
  company               Company                     @relation("FsControlPlanCompany", fields: [companyId], references: [id])
  hazardId              String
  hazard                FoodSafetyHazard            @relation(fields: [hazardId], references: [id])
  responsibleUserId     String?
  responsible           User?                       @relation("FsControlPlanResponsible", fields: [responsibleUserId], references: [id])
  controlType           FoodSafetyControlType       @default(CCP)
  parameter             String?
  unit                  String?
  criticalLimitText     String?
  criticalMin           Float?
  criticalMax           Float?
  alertMin              Float?
  alertMax              Float?
  method                String?
  instrument            String?
  frequency             String?
  correction            String?
  correctiveAction      String?
  requiresLotBlock      Boolean                     @default(false)
  requiresNonConformity Boolean                     @default(true)
  status                FoodSafetyControlPlanStatus @default(ACTIVE)
  createdAt             DateTime                    @default(now())
  updatedAt             DateTime                    @updatedAt
  deletedAt             DateTime?

  records FoodSafetyMonitoringRecord[]

  @@index([companyId])
  @@index([hazardId])
  @@index([companyId, status])
}

// Registro (execucao) de um monitoramento, com resultado calculado vs limites.
// Em desvio (OUT) pode bloquear lote e gerar nao conformidade (modulo nonconformities).
model FoodSafetyMonitoringRecord {
  id              String                     @id @default(uuid())
  companyId       String
  company         Company                    @relation("FsMonitoringCompany", fields: [companyId], references: [id])
  controlPlanId   String
  controlPlan     FoodSafetyControlPlan      @relation(fields: [controlPlanId], references: [id])
  recordedById    String?
  recordedBy      User?                      @relation("FsMonitoringRecordedBy", fields: [recordedById], references: [id])
  measuredAt      DateTime                   @default(now())
  valueNum        Float?
  valueText       String?
  result          FoodSafetyMonitoringResult @default(OK)
  notes           String?
  evidenceUrl     String?
  lotBlocked      Boolean                    @default(false)
  nonConformityId String?
  createdAt       DateTime                   @default(now())
  updatedAt       DateTime                   @updatedAt
  deletedAt       DateTime?

  @@index([companyId])
  @@index([controlPlanId])
  @@index([result])
}

// ----- Compliance: catalogo normativo versionado + requisitos (Fase 3) ----

enum FoodSafetyStandardVersionStatus {
  DRAFT
  ACTIVE
  SUPERSEDED
}

enum FoodSafetyComplianceResult {
  PENDING
  MET
  PARTIAL
  NOT_MET
  NOT_APPLICABLE
}

enum FoodSafetyRequirementCriticality {
  LOW
  MEDIUM
  HIGH
}

// Norma/regulamento administravel (ISO 22000, BRCGS, SQF, ANVISA, interno, cliente...).
model FoodSafetyStandard {
  id          String    @id @default(uuid())
  companyId   String
  company     Company   @relation("FsStandardCompany", fields: [companyId], references: [id])
  code        String?
  name        String
  origin      String?
  description String?
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  versions FoodSafetyStandardVersion[]

  @@index([companyId])
}

model FoodSafetyStandardVersion {
  id            String                          @id @default(uuid())
  companyId     String
  company       Company                         @relation("FsStdVersionCompany", fields: [companyId], references: [id])
  standardId    String
  standard      FoodSafetyStandard              @relation(fields: [standardId], references: [id])
  versionLabel  String
  effectiveDate DateTime?
  status        FoodSafetyStandardVersionStatus @default(DRAFT)
  notes         String?
  createdAt     DateTime                        @default(now())
  updatedAt     DateTime                        @updatedAt
  deletedAt     DateTime?

  requirements FoodSafetyRequirement[]

  @@index([companyId])
  @@index([standardId])
}

model FoodSafetyRequirement {
  id                String                           @id @default(uuid())
  companyId         String
  company           Company                          @relation("FsRequirementCompany", fields: [companyId], references: [id])
  standardVersionId String
  standardVersion   FoodSafetyStandardVersion        @relation(fields: [standardVersionId], references: [id])
  responsibleUserId String?
  responsible       User?                            @relation("FsRequirementResponsible", fields: [responsibleUserId], references: [id])
  code              String?
  chapter           String?
  item              String?
  subitem           String?
  title             String
  description       String?
  applicability     String?
  evidenceRequired  String?
  criticality       FoodSafetyRequirementCriticality @default(MEDIUM)
  periodicityDays   Int?
  active            Boolean                          @default(true)
  createdAt         DateTime                         @default(now())
  updatedAt         DateTime                         @updatedAt
  deletedAt         DateTime?

  assessments FoodSafetyRequirementAssessment[]

  @@index([companyId])
  @@index([standardVersionId])
}

model FoodSafetyRequirementAssessment {
  id                String                     @id @default(uuid())
  companyId         String
  company           Company                    @relation("FsReqAssessmentCompany", fields: [companyId], references: [id])
  requirementId     String
  requirement       FoodSafetyRequirement      @relation(fields: [requirementId], references: [id])
  responsibleUserId String?
  responsible       User?                      @relation("FsReqAssessmentResponsible", fields: [responsibleUserId], references: [id])
  result            FoodSafetyComplianceResult @default(PENDING)
  evidence          String?
  notes             String?
  assessedAt        DateTime?
  nextAssessmentAt  DateTime?
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt
  deletedAt         DateTime?

  @@index([companyId])
  @@index([requirementId])
  @@index([result])
}

// ----- Cadeia: fornecedores, materiais, lotes, rastreabilidade e recall (Fase 4) ----

enum FoodSafetySupplierStatus {
  PROSPECT
  APPROVED
  CONDITIONAL
  BLOCKED
  INACTIVE
}

enum FoodSafetySupplierCriticality {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum FoodSafetyMaterialCategory {
  RAW_MATERIAL
  INGREDIENT
  PACKAGING
  PROCESS_AID
  FINISHED_PRODUCT
  OTHER
}

enum FoodSafetyMaterialStatus {
  ACTIVE
  UNDER_REVIEW
  BLOCKED
  INACTIVE
}

enum FoodSafetyLotType {
  RECEIVED
  PRODUCED
  SHIPPED
  INTERNAL_TRANSFER
}

enum FoodSafetyLotStatus {
  QUARANTINED
  RELEASED
  BLOCKED
  CONSUMED
  EXPIRED
  RECALLED
}

enum FoodSafetyTraceEventType {
  RECEIPT
  CONSUMPTION
  PRODUCTION
  TRANSFER
  SHIPMENT
  RETURN
  DISPOSAL
}

enum FoodSafetyRecallStatus {
  DRAFT
  SIMULATION
  ACTIVE
  CLOSED
  CANCELLED
}

enum FoodSafetyRecallSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum FoodSafetyRecallItemStatus {
  PENDING
  NOTIFIED
  RETURNED
  DISPOSED
  RELEASED
}

model FoodSafetySupplier {
  id                 String                        @id @default(uuid())
  companyId          String
  company            Company                       @relation("FsSupplierCompany", fields: [companyId], references: [id])
  programId          String?
  program            FoodSafetyProgram?            @relation(fields: [programId], references: [id])
  orgNodeId          String?
  orgNode            OrgNode?                      @relation("FsSupplierOrgNode", fields: [orgNodeId], references: [id])
  responsibleUserId  String?
  responsible        User?                         @relation("FsSupplierResponsible", fields: [responsibleUserId], references: [id])
  code               String?
  name               String
  legalName          String?
  taxId              String?
  contactName        String?
  contactEmail       String?
  contactPhone       String?
  address            String?
  suppliedCategories String?
  criticality        FoodSafetySupplierCriticality @default(MEDIUM)
  status             FoodSafetySupplierStatus      @default(PROSPECT)
  score              Float?
  documentsStatus    String?
  lastAuditAt        DateTime?
  nextReviewAt       DateTime?
  notes              String?
  createdAt          DateTime                      @default(now())
  updatedAt          DateTime                      @updatedAt
  deletedAt          DateTime?

  materials FoodSafetyMaterial[]
  lots      FoodSafetyLot[]

  @@unique([companyId, code])
  @@index([companyId])
  @@index([programId])
  @@index([orgNodeId])
  @@index([status])
  @@index([criticality])
}

model FoodSafetyMaterial {
  id                String                     @id @default(uuid())
  companyId         String
  company           Company                    @relation("FsMaterialCompany", fields: [companyId], references: [id])
  programId         String?
  program           FoodSafetyProgram?         @relation(fields: [programId], references: [id])
  supplierId        String?
  supplier          FoodSafetySupplier?        @relation(fields: [supplierId], references: [id])
  code              String?
  name              String
  category          FoodSafetyMaterialCategory @default(RAW_MATERIAL)
  unit              String?
  specification     String?
  storageCondition  String?
  allergens         String?
  hazards           String?
  requiredDocuments String?
  shelfLifeDays     Int?
  status            FoodSafetyMaterialStatus   @default(ACTIVE)
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt
  deletedAt         DateTime?

  lots FoodSafetyLot[]

  @@unique([companyId, code])
  @@index([companyId])
  @@index([programId])
  @@index([supplierId])
  @@index([category])
  @@index([status])
}

model FoodSafetyLot {
  id              String              @id @default(uuid())
  companyId       String
  company         Company             @relation("FsLotCompany", fields: [companyId], references: [id])
  programId       String?
  program         FoodSafetyProgram?  @relation(fields: [programId], references: [id])
  materialId      String?
  material        FoodSafetyMaterial? @relation(fields: [materialId], references: [id])
  supplierId      String?
  supplier        FoodSafetySupplier? @relation(fields: [supplierId], references: [id])
  processId       String?
  process         FoodSafetyProcess?  @relation("FsLotProcess", fields: [processId], references: [id])
  code            String
  type            FoodSafetyLotType   @default(RECEIVED)
  status          FoodSafetyLotStatus @default(QUARANTINED)
  quantity        Float?
  unit            String?
  receivedAt      DateTime?
  producedAt      DateTime?
  expiresAt       DateTime?
  storageLocation String?
  customerName    String?
  destination     String?
  certificateUrl  String?
  notes           String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  deletedAt       DateTime?

  outgoingTraceLinks FoodSafetyTraceLink[]  @relation("FsTraceFromLot")
  incomingTraceLinks FoodSafetyTraceLink[]  @relation("FsTraceToLot")
  recallRoots        FoodSafetyRecall[]     @relation("FsRecallRootLot")
  recallItems        FoodSafetyRecallItem[]

  @@unique([companyId, code])
  @@index([companyId])
  @@index([programId])
  @@index([materialId])
  @@index([supplierId])
  @@index([processId])
  @@index([status])
  @@index([type])
}

model FoodSafetyTraceLink {
  id         String                   @id @default(uuid())
  companyId  String
  company    Company                  @relation("FsTraceLinkCompany", fields: [companyId], references: [id])
  fromLotId  String?
  fromLot    FoodSafetyLot?           @relation("FsTraceFromLot", fields: [fromLotId], references: [id])
  toLotId    String?
  toLot      FoodSafetyLot?           @relation("FsTraceToLot", fields: [toLotId], references: [id])
  processId  String?
  process    FoodSafetyProcess?       @relation("FsTraceProcess", fields: [processId], references: [id])
  stepId     String?
  step       FoodSafetyProcessStep?   @relation("FsTraceStep", fields: [stepId], references: [id])
  eventType  FoodSafetyTraceEventType @default(PRODUCTION)
  quantity   Float?
  unit       String?
  occurredAt DateTime                 @default(now())
  notes      String?
  createdAt  DateTime                 @default(now())
  updatedAt  DateTime                 @updatedAt
  deletedAt  DateTime?

  @@index([companyId])
  @@index([fromLotId])
  @@index([toLotId])
  @@index([processId])
  @@index([eventType])
}

model FoodSafetyRecall {
  id                String                   @id @default(uuid())
  companyId         String
  company           Company                  @relation("FsRecallCompany", fields: [companyId], references: [id])
  programId         String?
  program           FoodSafetyProgram?       @relation(fields: [programId], references: [id])
  rootLotId         String?
  rootLot           FoodSafetyLot?           @relation("FsRecallRootLot", fields: [rootLotId], references: [id])
  responsibleUserId String?
  responsible       User?                    @relation("FsRecallResponsible", fields: [responsibleUserId], references: [id])
  code              String?
  title             String
  reason            String?
  severity          FoodSafetyRecallSeverity @default(MEDIUM)
  status            FoodSafetyRecallStatus   @default(SIMULATION)
  scopeDescription  String?
  affectedQuantity  Float?
  unit              String?
  initiatedAt       DateTime                 @default(now())
  closedAt          DateTime?
  actions           String?
  notes             String?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  deletedAt         DateTime?

  items FoodSafetyRecallItem[]

  @@unique([companyId, code])
  @@index([companyId])
  @@index([programId])
  @@index([rootLotId])
  @@index([status])
  @@index([severity])
}

model FoodSafetyRecallItem {
  id          String                     @id @default(uuid())
  companyId   String
  company     Company                    @relation("FsRecallItemCompany", fields: [companyId], references: [id])
  recallId    String
  recall      FoodSafetyRecall           @relation(fields: [recallId], references: [id])
  lotId       String
  lot         FoodSafetyLot              @relation(fields: [lotId], references: [id])
  status      FoodSafetyRecallItemStatus @default(PENDING)
  quantity    Float?
  unit        String?
  disposition String?
  notifiedAt  DateTime?
  notes       String?
  createdAt   DateTime                   @default(now())
  updatedAt   DateTime                   @updatedAt
  deletedAt   DateTime?

  @@unique([recallId, lotId])
  @@index([companyId])
  @@index([recallId])
  @@index([lotId])
  @@index([status])
}

// =====================================================
// Visão 360° e Análise de Impacto
// =====================================================

model RelationshipLink {
  id               String    @id @default(uuid())
  companyId        String
  company          Company   @relation("RelationshipCompany", fields: [companyId], references: [id])
  sourceEntityType String // ex.: "INDICATOR", "PROCESS", "DOCUMENT", etc.
  sourceEntityId   String
  targetEntityType String
  targetEntityId   String
  relationshipType String // ex.: "pertence_a", "depende_de", "impacta", "controlado_por"
  direction        String    @default("DIRECT") // "DIRECT" ou "INDIRECT"
  criticality      String    @default("MEDIUM") // "CRITICAL", "HIGH", "MEDIUM", "LOW", "INFO"
  isMandatory      Boolean   @default(false)
  originType       String    @default("MANUAL") // "AUTOMATIC" ou "MANUAL"
  originReference  String?
  notes            String?
  createdById      String?
  createdBy        User?     @relation("RelationshipCreatedBy", fields: [createdById], references: [id])
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  @@index([companyId])
  @@index([sourceEntityType, sourceEntityId])
  @@index([targetEntityType, targetEntityId])
}

model ImpactAnalysis {
  id                   String               @id @default(uuid())
  companyId            String
  company              Company              @relation("ImpactAnalysisCompany", fields: [companyId], references: [id])
  sourceEntityType     String
  sourceEntityId       String
  operationType        String // "CREATE", "UPDATE", "DELETE", "INACTIVE"
  changeSummary        String
  previousValues       String? // JSON stringificado contendo os campos anteriores
  newValues            String? // JSON stringificado contendo os novos valores
  impactLevel          String               @default("MEDIUM") // "CRITICAL", "HIGH", "MEDIUM", "LOW", "INFO"
  affectedRecordsCount Int                  @default(0)
  status               String               @default("PENDING") // "PENDING", "APPROVED", "REJECTED", "COMPLETED"
  justification        String?
  createdById          String?
  createdBy            User?                @relation("ImpactAnalysisCreatedBy", fields: [createdById], references: [id])
  createdAt            DateTime             @default(now())
  approvedById         String?
  approvedBy           User?                @relation("ImpactAnalysisApprovedBy", fields: [approvedById], references: [id])
  approvedAt           DateTime?
  items                ImpactAnalysisItem[]

  @@index([companyId])
  @@index([sourceEntityType, sourceEntityId])
}

model ImpactAnalysisItem {
  id                 String         @id @default(uuid())
  companyId          String
  company            Company        @relation("ImpactItemCompany", fields: [companyId], references: [id])
  impactAnalysisId   String
  impactAnalysis     ImpactAnalysis @relation(fields: [impactAnalysisId], references: [id], onDelete: Cascade)
  affectedEntityType String
  affectedEntityId   String
  relationshipPath   String? // ex.: "Processo A -> Indicador B"
  impactReason       String?
  impactLevel        String         @default("MEDIUM")
  recommendedAction  String?
  requiresReview     Boolean        @default(false)
  requiresTask       Boolean        @default(false)
  responsibleUserId  String?
  responsibleUser    User?          @relation("ImpactItemResponsible", fields: [responsibleUserId], references: [id])
  status             String         @default("PENDING") // "PENDING", "DONE", "CANCELLED"
  dueDate            DateTime?
  createdAt          DateTime       @default(now())

  @@index([companyId])
  @@index([impactAnalysisId])
  @@index([affectedEntityType, affectedEntityId])
}

model RelationshipAuditLog {
  id             String   @id @default(uuid())
  companyId      String
  company        Company  @relation("RelationAuditCompany", fields: [companyId], references: [id])
  entityType     String
  entityId       String
  eventType      String // "LINK_CREATED", "LINK_REMOVED", "IMPACT_APPROVED"
  previousValues String?
  newValues      String?
  performedById  String?
  performedBy    User?    @relation("RelationAuditPerformedBy", fields: [performedById], references: [id])
  performedAt    DateTime @default(now())
  ipAddress      String?
  userAgent      String?
  notes          String?

  @@index([companyId])
  @@index([entityType, entityId])
}

// =====================================================
// Central de Automações e Workflows
// =====================================================

model WorkflowDefinition {
  id              String    @id @default(uuid())
  companyId       String
  company         Company   @relation("WorkflowDefCompany", fields: [companyId], references: [id], onDelete: Cascade)
  name            String
  description     String?
  module          String // e.g. "INDICATORS", "DOCUMENTS", "AUDITS", etc.
  category        String // e.g. "NOTIFICATION", "APPROVAL", "TASK", "INTEGRATION"
  scopeType       String    @default("COMPANY") // "COMPANY", "BRANCH", "UNIT", "GLOBAL"
  scopeId         String?
  status          String    @default("DRAFT") // "DRAFT", "ACTIVE", "INACTIVE", "ARCHIVED"
  activeVersionId String?
  createdById     String?
  createdBy       User?     @relation("WorkflowDefCreatedBy", fields: [createdById], references: [id])
  updatedById     String?
  updatedBy       User?     @relation("WorkflowDefUpdatedBy", fields: [updatedById], references: [id])
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  versions  WorkflowVersion[]  @relation("WorkflowDefVersions")
  instances WorkflowInstance[] @relation("WorkflowDefInstances")

  @@index([companyId])
  @@index([status])
}

model WorkflowVersion {
  id                    String             @id @default(uuid())
  companyId             String
  company               Company            @relation("WorkflowVerCompany", fields: [companyId], references: [id], onDelete: Cascade)
  workflowDefinitionId  String
  workflowDefinition    WorkflowDefinition @relation("WorkflowDefVersions", fields: [workflowDefinitionId], references: [id], onDelete: Cascade)
  versionNumber         Int
  status                String             @default("DRAFT") // "DRAFT", "PUBLISHED", "ARCHIVED"
  canvasData            String // JSON stringified ReactFlow nodes & edges
  configurationSnapshot String // JSON stringified variables configuration
  changeSummary         String?
  createdById           String?
  createdBy             User?              @relation("WorkflowVerCreatedBy", fields: [createdById], references: [id])
  publishedById         String?
  publishedBy           User?              @relation("WorkflowVerPublishedBy", fields: [publishedById], references: [id])
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  publishedAt           DateTime?
  archivedAt            DateTime?

  nodes     WorkflowNode[]     @relation("WorkflowVerNodes")
  edges     WorkflowEdge[]     @relation("WorkflowVerEdges")
  instances WorkflowInstance[] @relation("WorkflowVerInstances")

  @@unique([workflowDefinitionId, versionNumber])
  @@index([companyId])
}

model WorkflowNode {
  id                String          @id @default(uuid())
  companyId         String
  company           Company         @relation("WorkflowNodeCompany", fields: [companyId], references: [id], onDelete: Cascade)
  workflowVersionId String
  workflowVersion   WorkflowVersion @relation("WorkflowVerNodes", fields: [workflowVersionId], references: [id], onDelete: Cascade)
  nodeKey           String // Unique key on the canvas (e.g. "trigger-1", "node-2")
  nodeType          String // "TRIGGER", "CONDITION", "ACTION", "LOGIC", "RESPONSIBLE", "HUMAN_TASK", "APPROVAL", "TIMER", "INTEGRATION", "TERMINAL"
  blockType         String // e.g. "indicator.out_of_target", "action.create"
  name              String
  positionX         Float
  positionY         Float
  configuration     String // JSON stringified config properties
  inputSchema       String?
  outputSchema      String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@unique([workflowVersionId, nodeKey])
  @@index([companyId])
}

model WorkflowEdge {
  id                String          @id @default(uuid())
  companyId         String
  company           Company         @relation("WorkflowEdgeCompany", fields: [companyId], references: [id], onDelete: Cascade)
  workflowVersionId String
  workflowVersion   WorkflowVersion @relation("WorkflowVerEdges", fields: [workflowVersionId], references: [id], onDelete: Cascade)
  sourceNodeKey     String
  targetNodeKey     String
  sourceHandle      String?
  targetHandle      String?
  conditionLabel    String?
  metadata          String? // JSON stringified metadata
  createdAt         DateTime        @default(now())

  @@index([companyId])
  @@index([workflowVersionId])
}

model WorkflowInstance {
  id                   String             @id @default(uuid())
  companyId            String
  company              Company            @relation("WorkflowInstCompany", fields: [companyId], references: [id], onDelete: Cascade)
  workflowDefinitionId String
  workflowDefinition   WorkflowDefinition @relation("WorkflowDefInstances", fields: [workflowDefinitionId], references: [id], onDelete: Cascade)
  workflowVersionId    String
  workflowVersion      WorkflowVersion    @relation("WorkflowVerInstances", fields: [workflowVersionId], references: [id], onDelete: Cascade)
  sourceEventId        String?
  sourceEntityType     String? // e.g. "INDICATOR", "DOCUMENT", "AUDIT"
  sourceEntityId       String?
  status               String             @default("RUNNING") // "RUNNING", "COMPLETED", "FAILED", "CANCELLED"
  currentState         String             @default("{}") // JSON stringified variables snapshot
  priority             String             @default("MEDIUM") // "LOW", "MEDIUM", "HIGH", "CRITICAL"
  startedAt            DateTime           @default(now())
  completedAt          DateTime?
  failedAt             DateTime?
  cancelledAt          DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  nodeExecutions WorkflowNodeExecution[] @relation("WorkflowInstNodes")
  timers         WorkflowTimer[]         @relation("WorkflowInstTimers")
  approvals      WorkflowApproval[]      @relation("WorkflowInstApprovals")
  tasks          WorkflowTask[]          @relation("WorkflowInstTasks")
  logs           WorkflowExecutionLog[]  @relation("WorkflowInstLogs")
  deadLetters    WorkflowDeadLetter[]    @relation("WorkflowInstDeadLetters")

  @@index([companyId])
  @@index([status])
  @@index([sourceEntityType, sourceEntityId])
}

model WorkflowNodeExecution {
  id                 String           @id @default(uuid())
  companyId          String
  company            Company          @relation("WorkflowNodeExecCompany", fields: [companyId], references: [id], onDelete: Cascade)
  workflowInstanceId String
  workflowInstance   WorkflowInstance @relation("WorkflowInstNodes", fields: [workflowInstanceId], references: [id], onDelete: Cascade)
  nodeKey            String
  nodeType           String
  status             String           @default("PENDING") // "PENDING", "RUNNING", "COMPLETED", "FAILED", "SKIPPED"
  attemptNumber      Int              @default(1)
  inputData          String? // JSON string
  outputData         String? // JSON string
  errorMessage       String?
  startedAt          DateTime         @default(now())
  completedAt        DateTime?
  nextRetryAt        DateTime?
  createdAt          DateTime         @default(now())

  logs WorkflowExecutionLog[] @relation("WorkflowNodeExecLogs")

  @@index([companyId])
  @@index([workflowInstanceId, nodeKey])
  @@index([status])
}

model WorkflowEvent {
  id             String    @id @default(uuid())
  companyId      String
  company        Company   @relation("WorkflowEventCompany", fields: [companyId], references: [id], onDelete: Cascade)
  eventType      String // e.g. "indicator.out_of_target"
  entityType     String
  entityId       String
  eventPayload   String // JSON stringified payload
  idempotencyKey String    @unique
  status         String    @default("PENDING") // "PENDING", "PROCESSED", "FAILED"
  occurredAt     DateTime  @default(now())
  processedAt    DateTime?
  attemptCount   Int       @default(0)
  nextRetryAt    DateTime?
  errorMessage   String?
  createdAt      DateTime  @default(now())

  @@index([companyId])
  @@index([status])
}

model WorkflowTimer {
  id                 String           @id @default(uuid())
  companyId          String
  company            Company          @relation("WorkflowTimerCompany", fields: [companyId], references: [id], onDelete: Cascade)
  workflowInstanceId String
  workflowInstance   WorkflowInstance @relation("WorkflowInstTimers", fields: [workflowInstanceId], references: [id], onDelete: Cascade)
  nodeKey            String
  timerType          String // "DELAY", "DURATION", "DATE"
  scheduledAt        DateTime
  executedAt         DateTime?
  status             String           @default("SCHEDULED") // "SCHEDULED", "EXECUTED", "CANCELLED"
  payload            String? // JSON stringified variables snapshot
  createdAt          DateTime         @default(now())

  @@index([companyId])
  @@index([status, scheduledAt])
  @@index([workflowInstanceId])
}

model WorkflowApproval {
  id                 String           @id @default(uuid())
  companyId          String
  company            Company          @relation("WorkflowApprovCompany", fields: [companyId], references: [id], onDelete: Cascade)
  workflowInstanceId String
  workflowInstance   WorkflowInstance @relation("WorkflowInstApprovals", fields: [workflowInstanceId], references: [id], onDelete: Cascade)
  nodeKey            String
  approvalType       String // "SIMPLE", "SEQUENTIAL", "PARALLEL", "MAJORITY", "UNANIMOUS"
  requesterId        String?
  requester          User?            @relation("WorkflowApprovRequester", fields: [requesterId], references: [id])
  approverId         String?
  approver           User?            @relation("WorkflowApprovApprover", fields: [approverId], references: [id])
  approverGroupId    String? // Or sector/role grouping
  status             String           @default("PENDING") // "PENDING", "APPROVED", "REJECTED", "CHANGES_REQUESTED", "DELEGATED", "CANCELLED"
  decision           String? // "APPROVED", "REJECTED", "CHANGES"
  comments           String?
  dueAt              DateTime?
  respondedAt        DateTime?
  createdAt          DateTime         @default(now())

  @@index([companyId])
  @@index([status])
  @@index([workflowInstanceId])
  @@index([approverId])
}

model WorkflowTask {
  id                      String           @id @default(uuid())
  companyId               String
  company                 Company          @relation("WorkflowTaskCompany", fields: [companyId], references: [id], onDelete: Cascade)
  workflowInstanceId      String
  workflowInstance        WorkflowInstance @relation("WorkflowInstTasks", fields: [workflowInstanceId], references: [id], onDelete: Cascade)
  nodeKey                 String
  title                   String
  description             String?
  type                    String           @default("OPERATIONAL")
  priority                String           @default("MEDIUM")
  criticity               String           @default("MEDIUM")
  responsibleId           String?
  responsible             User?            @relation("WorkflowTaskResponsible", fields: [responsibleId], references: [id])
  responsibleSubstituteId String?
  responsibleSubstitute   User?            @relation("WorkflowTaskSubstitute", fields: [responsibleSubstituteId], references: [id])
  status                  String           @default("PENDING") // "PENDING", "IN_PROGRESS", "DONE", "CANCELLED", "OVERDUE"
  dueAt                   DateTime?
  completedAt             DateTime?
  requiredEvidence        Boolean          @default(false)
  escalationLevel         Int              @default(0)
  originType              String?
  originId                String?
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt

  @@index([companyId])
  @@index([status])
  @@index([workflowInstanceId])
  @@index([responsibleId])
}

model WorkflowTemplate {
  id           String   @id @default(uuid())
  companyId    String? // null if global template
  company      Company? @relation("WorkflowTempCompany", fields: [companyId], references: [id], onDelete: Cascade)
  name         String
  description  String?
  module       String
  category     String
  templateData String // JSON string of nodes & edges
  isGlobal     Boolean  @default(false)
  status       String   @default("ACTIVE")
  createdById  String?
  createdBy    User?    @relation("WorkflowTempCreatedBy", fields: [createdById], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([companyId])
  @@index([status])
}

model WorkflowExecutionLog {
  id                 String                 @id @default(uuid())
  companyId          String
  company            Company                @relation("WorkflowLogCompany", fields: [companyId], references: [id], onDelete: Cascade)
  workflowInstanceId String
  workflowInstance   WorkflowInstance       @relation("WorkflowInstLogs", fields: [workflowInstanceId], references: [id], onDelete: Cascade)
  nodeExecutionId    String?
  nodeExecution      WorkflowNodeExecution? @relation("WorkflowNodeExecLogs", fields: [nodeExecutionId], references: [id])
  level              String                 @default("INFO") // "INFO", "WARNING", "ERROR"
  eventType          String
  message            String
  details            String?
  createdAt          DateTime               @default(now())

  @@index([companyId])
  @@index([workflowInstanceId])
}

model WorkflowDeadLetter {
  id                 String           @id @default(uuid())
  companyId          String
  company            Company          @relation("WorkflowDLCompany", fields: [companyId], references: [id], onDelete: Cascade)
  workflowInstanceId String
  workflowInstance   WorkflowInstance @relation("WorkflowInstDeadLetters", fields: [workflowInstanceId], references: [id], onDelete: Cascade)
  nodeExecutionId    String?
  errorType          String
  errorMessage       String
  payload            String // JSON stringified execution state
  attempts           Int              @default(0)
  status             String           @default("UNRESOLVED") // "UNRESOLVED", "RESOLVED", "IGNORED"
  resolvedById       String?
  resolvedBy         User?            @relation("WorkflowDLResolvedBy", fields: [resolvedById], references: [id])
  resolvedAt         DateTime?
  createdAt          DateTime         @default(now())

  @@index([companyId])
  @@index([status])
}

model WorkflowIntegration {
  id                     String   @id @default(uuid())
  companyId              String
  company                Company  @relation("WorkflowIntegCompany", fields: [companyId], references: [id], onDelete: Cascade)
  name                   String
  integrationType        String // "EMAIL", "WEBHOOK", "TEAMS", "SLACK", etc.
  configurationReference String // JSON stringified config (credentials, urls, encrypted secrets)
  status                 String   @default("ACTIVE")
  createdById            String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@index([companyId])
}

// =====================================================
// Central de Trabalho "Meu Dia" (Work Inbox)
// Projecao de leitura/priorizacao que REFERENCIA os registros originais
// (nunca os duplica como fonte oficial). Atualizada por agregacao/eventos.
// =====================================================

enum WorkItemPriorityLevel {
  CRITICAL
  HIGH
  MEDIUM
  LOW
  INFO
}

/// Indice unificado de itens de trabalho. Cada linha aponta para o registro de
/// origem (sourceEntityType + sourceEntityId). Os detalhes vivem nos modulos.
model WorkItemIndex {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation("WorkItemCompany", fields: [companyId], references: [id], onDelete: Cascade)

  // <sourceEntityType>:<sourceEntityId>:<itemType>:<assignedUserId|group|*>
  dedupeKey String @unique

  sourceModule       String
  sourceEntityType   String
  sourceEntityId     String
  sourceEventId      String?
  workflowInstanceId String?
  workflowNodeKey    String?

  itemType       String
  title          String
  summary        String?
  status         String                @default("OPEN") // OPEN | IN_PROGRESS | WAITING | BLOCKED | DONE | ARCHIVED
  priority       WorkItemPriorityLevel @default(MEDIUM)
  priorityScore  Int                   @default(0)
  priorityReason String?
  criticality    String?
  dueAt          DateTime?
  overdueDays    Int                   @default(0)
  slaStatus      String? // ON_TRACK | DUE_SOON | OVERDUE | NONE

  assignedUserId  String?
  assignedGroupId String?
  requesterUserId String?
  managerUserId   String?

  branchId  String? // unidade
  orgNodeId String? // area/setor
  processId String?

  contextData         Json?
  availableActions    Json?
  recommendedAction   String?
  requiresDecision    Boolean @default(false)
  requiresEvidence    Boolean @default(false)
  isBlocking          Boolean @default(false)
  isExternal          Boolean @default(false)
  isDelegated         Boolean @default(false)
  delegatedFromUserId String?

  sourceCreatedAt DateTime?
  sourceUpdatedAt DateTime?
  completedAt     DateTime?
  archivedAt      DateTime?
  refreshedAt     DateTime  @default(now())
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([companyId, assignedUserId, status])
  @@index([companyId, status, dueAt])
  @@index([companyId, priority])
  @@index([companyId, itemType])
  @@index([assignedUserId, status])
  @@index([dueAt])
}

/// Preferencias pessoais da Central "Meu Dia" (pagina inicial, widgets, etc.).
model UserDashboardPreference {
  id                  String   @id @default(uuid())
  companyId           String
  company             Company  @relation("DashboardPrefCompany", fields: [companyId], references: [id], onDelete: Cascade)
  userId              String
  landingPage         String?  @default("/meu-dia")
  defaultView         String?  @default("list")
  visibleWidgets      Json?
  widgetOrder         Json?
  savedFilters        Json?
  defaultCompanyId    String?
  defaultUnitId       String?
  compactMode         Boolean  @default(false)
  aiEnabled           Boolean  @default(true)
  dailySummaryEnabled Boolean  @default(false)
  dailySummaryTime    String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([companyId, userId])
  @@index([userId])
}

/// Substituicao temporaria: permite que outro usuario trate itens do Meu Dia
/// do delegante durante um periodo. Nao altera a fonte oficial dos registros.
model UserDelegation {
  id              String    @id @default(uuid())
  companyId       String
  company         Company   @relation("UserDelegationCompany", fields: [companyId], references: [id], onDelete: Cascade)
  delegatorUserId String
  delegator       User      @relation("UserDelegationDelegator", fields: [delegatorUserId], references: [id], onDelete: Cascade)
  delegateUserId  String
  delegate        User      @relation("UserDelegationDelegate", fields: [delegateUserId], references: [id], onDelete: Cascade)
  startsAt        DateTime
  endsAt          DateTime?
  scope           Json?
  reason          String?
  status          String    @default("ACTIVE")
  createdById     String?
  revokedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([companyId, delegatorUserId, delegateUserId, startsAt])
  @@index([companyId, delegatorUserId, status])
  @@index([companyId, delegateUserId, status])
  @@index([startsAt, endsAt])
}

/// Acompanhamento pessoal de um item da Central. Referencia a origem real
/// (sourceEntityType/sourceEntityId/itemType) para sobreviver a rebuilds.
model WorkItemFollow {
  id               String    @id @default(uuid())
  companyId        String
  company          Company   @relation("WorkItemFollowCompany", fields: [companyId], references: [id], onDelete: Cascade)
  userId           String
  user             User      @relation("WorkItemFollowUser", fields: [userId], references: [id], onDelete: Cascade)
  sourceModule     String
  sourceEntityType String
  sourceEntityId   String
  itemType         String
  titleSnapshot    String?
  pinned           Boolean   @default(false)
  note             String?
  followedAt       DateTime  @default(now())
  pinnedAt         DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@unique([companyId, userId, sourceEntityType, sourceEntityId, itemType])
  @@index([companyId, userId, pinned])
  @@index([sourceEntityType, sourceEntityId])
}

/// Historico/governanca das recomendacoes assistivas do Meu Dia.
/// Guarda apenas metadados da recomendacao gerada, nunca substitui a origem.
model MyDayAssistantLog {
  id                String    @id @default(uuid())
  companyId         String
  company           Company   @relation("MyDayAssistantCompany", fields: [companyId], references: [id], onDelete: Cascade)
  userId            String
  user              User      @relation("MyDayAssistantUser", fields: [userId], references: [id], onDelete: Cascade)
  recommendationKey String
  title             String
  severity          String
  suggestion        String?
  explanation       String?
  contextData       Json?
  hidden            Boolean   @default(false)
  helpful           Boolean?
  feedback          String?
  generatedAt       DateTime  @default(now())
  interactedAt      DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@unique([companyId, userId, recommendationKey])
  @@index([companyId, userId, hidden])
  @@index([generatedAt])
}

// =====================================================
// Gestao de Premio (Remuneracao Variavel) - Fase 1
// Governanca de Anexos, Programas, Competencias e Indicadores.
// Tenancy por companyId (scalar). FKs externas (User/OrgNode) sao colunas
// escalares + constraints aplicadas na migration SQL; relacoes internas do
// modulo usam @relation. Toda regra de negocio fica no backend (servico).
// =====================================================

enum PrizeProgramStatus {
  DRAFT
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum PrizePeriodicity {
  MONTHLY
  WEEKLY
  DAILY
  QUARTERLY
  SEMIANNUAL
  ANNUAL
}

enum PrizeCompetenceStatus {
  PLANNED
  OPEN
  FILLING
  IN_VALIDATION
  PRE_CLOSE
  CLOSED_FOR_CALC
  IN_CALCULATION
  IN_REVIEW
  IN_APPROVAL
  APPROVED
  SENT_TO_PAYROLL
  PAYSLIPS_PUBLISHED
  CLOSED
}

enum PrizeAnnexStatus {
  DRAFT
  IN_ELABORATION
  IN_VALIDATION
  IN_APPROVAL
  APPROVED
  EFFECTIVE
  SUPERSEDED
  ARCHIVED
}

enum PrizeApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  RETURNED
}

enum PrizeIndicatorKind {
  COLLECTIVE
  INDIVIDUAL
  BEHAVIORAL_COLLECTIVE
  BEHAVIORAL_INDIVIDUAL
}

enum PrizeIndicatorDirection {
  HIGHER_BETTER
  LOWER_BETTER
  TARGET
}

enum PrizeIndicatorSource {
  MANUAL
  INTERNAL_API
  FILE_IMPORT
  AUTO_CALC
}

enum PrizeRuleIndicatorType {
  FIXED
  VARIABLE
}

enum PrizeRuleValidityKind {
  CALENDAR_YEAR
  CROP_YEAR
}

enum PrizeRuleAliasKind {
  AREA
  POSITION
}

enum PrizeCellResultStatus {
  CALCULATED
  PENDING_INPUT
  BLOCKED
}

model PrizeProgram {
  id                  String             @id @default(uuid())
  companyId           String
  orgNodeId           String?
  code                String
  name                String
  description         String?
  programType         String?
  periodicity         PrizePeriodicity   @default(MONTHLY)
  currency            String             @default("BRL")
  validFrom           DateTime?
  validTo             DateTime?
  status              PrizeProgramStatus @default(DRAFT)
  roundingRule        String?
  closeDay            Int?
  approvalDeadlineDay Int?
  payrollDeadlineDay  Int?
  defaultRubric       String?
  ownerUserId         String?
  approvers           Json?
  eligibility         Json?
  notes               String?
  createdById         String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  deletedAt           DateTime?

  versions    PrizeProgramVersion[]
  competences PrizeCompetence[]
  annexes     PrizeAnnex[]
  indicators  PrizeIndicator[]

  @@unique([companyId, code])
  @@index([companyId])
  @@index([companyId, status])
  @@index([orgNodeId])
}

model PrizeProgramVersion {
  id          String       @id @default(uuid())
  programId   String
  program     PrizeProgram @relation(fields: [programId], references: [id], onDelete: Cascade)
  version     Int
  snapshot    Json
  note        String?
  createdById String?
  createdAt   DateTime     @default(now())

  @@unique([programId, version])
  @@index([programId])
}

model PrizeCompetence {
  id                 String                @id @default(uuid())
  companyId          String
  programId          String
  program            PrizeProgram          @relation(fields: [programId], references: [id], onDelete: Cascade)
  year               Int
  month              Int
  label              String
  startDate          DateTime?
  endDate            DateTime?
  launchDeadline     DateTime?
  validationDeadline DateTime?
  approvalDeadline   DateTime?
  payrollDate        DateTime?
  paymentDate        DateTime?
  status             PrizeCompetenceStatus @default(PLANNED)
  responsibles       Json?
  checklist          Json?
  notes              String?
  closedAt           DateTime?
  closedById         String?
  createdById        String?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  parameters     PrizeIndicatorParameter[]
  actuals        PrizeActualResult[]
  catalogActuals PrizeCatalogActualResult[]
  cellResults    PrizeCellResult[]

  @@unique([programId, year, month])
  @@index([companyId])
  @@index([companyId, status])
  @@index([programId, year, month])
}

model PrizeAnnex {
  id               String       @id @default(uuid())
  companyId        String
  programId        String
  program          PrizeProgram @relation(fields: [programId], references: [id], onDelete: Cascade)
  code             String
  name             String
  orgNodeId        String?
  positionRef      String?
  costCenterRef    String?
  currentVersionId String?
  notes            String?
  createdById      String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  deletedAt        DateTime?

  versions PrizeAnnexVersion[]

  @@unique([companyId, code])
  @@index([companyId])
  @@index([programId])
  @@index([orgNodeId])
}

model PrizeAnnexVersion {
  id                    String           @id @default(uuid())
  annexId               String
  annex                 PrizeAnnex       @relation(fields: [annexId], references: [id], onDelete: Cascade)
  version               Int
  status                PrizeAnnexStatus @default(DRAFT)
  effectiveFrom         DateTime?
  effectiveTo           DateTime?
  salaryPercent         Decimal?         @db.Decimal(9, 4)
  gainPotential         Decimal?         @db.Decimal(14, 2)
  gainChance            Decimal?         @db.Decimal(9, 4)
  formula               Json?
  rules                 Json?
  criteria              Json?
  changeReason          String?
  createdById           String?
  submittedAt           DateTime?
  approvedAt            DateTime?
  supersededAt          DateTime?
  supersededByVersionId String?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  approvals  PrizeAnnexApproval[]
  indicators PrizeIndicator[]
  ruleGroups PrizeRuleGroup[]

  @@unique([annexId, version])
  @@index([annexId])
  @@index([status])
  @@index([annexId, status])
}

model PrizeAnnexApproval {
  id             String              @id @default(uuid())
  annexVersionId String
  annexVersion   PrizeAnnexVersion   @relation(fields: [annexVersionId], references: [id], onDelete: Cascade)
  stepOrder      Int                 @default(1)
  approverUserId String?
  approverRole   String?
  status         PrizeApprovalStatus @default(PENDING)
  comment        String?
  decidedById    String?
  decidedAt      DateTime?
  createdAt      DateTime            @default(now())

  @@index([annexVersionId])
  @@index([status])
}

model PrizeIndicator {
  id                  String                  @id @default(uuid())
  companyId           String
  programId           String
  program             PrizeProgram            @relation(fields: [programId], references: [id], onDelete: Cascade)
  annexVersionId      String?
  annexVersion        PrizeAnnexVersion?      @relation(fields: [annexVersionId], references: [id], onDelete: SetNull)
  code                String
  name                String
  description         String?
  unit                String?
  kind                PrizeIndicatorKind      @default(COLLECTIVE)
  direction           PrizeIndicatorDirection @default(HIGHER_BETTER)
  source              PrizeIndicatorSource    @default(MANUAL)
  // Vinculo com o indicador NATIVO da plataforma (modulo Indicadores/Lancamentos).
  // Quando preenchido, o realizado do premio e sincronizado automaticamente de
  // IndicatorResult (periodRef = label da competencia), eliminando redigitacao
  // e planilhas: lancou na plataforma (ou via API externa /results), flui p/ ca.
  platformIndicatorId String?
  weight              Decimal?                @db.Decimal(9, 4)
  formula             String?
  roundingRule        String?
  orgNodeId           String?
  positionRef         String?
  costCenterRef       String?
  periodicity         PrizePeriodicity        @default(MONTHLY)
  status              String                  @default("ACTIVE")
  createdById         String?
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
  deletedAt           DateTime?

  parameters PrizeIndicatorParameter[]
  ranges     PrizeIndicatorRange[]
  actuals    PrizeActualResult[]

  @@unique([programId, code])
  @@index([companyId])
  @@index([programId])
  @@index([annexVersionId])
  @@index([platformIndicatorId])
}

model PrizeIndicatorParameter {
  id           String           @id @default(uuid())
  indicatorId  String
  indicator    PrizeIndicator   @relation(fields: [indicatorId], references: [id], onDelete: Cascade)
  competenceId String?
  competence   PrizeCompetence? @relation(fields: [competenceId], references: [id], onDelete: SetNull)
  year         Int?
  month        Int?
  week         Int?
  day          Int?
  scopeKey     String?
  target       Decimal?         @db.Decimal(18, 4)
  zero         Decimal?         @db.Decimal(18, 4)
  weight       Decimal?         @db.Decimal(9, 4)
  changeReason String?
  createdById  String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  ranges PrizeIndicatorRange[] @relation("ParamRanges")

  @@index([indicatorId])
  @@index([competenceId])
  @@index([indicatorId, year, month])
}

model PrizeIndicatorRange {
  id                 String                   @id @default(uuid())
  indicatorId        String
  indicator          PrizeIndicator           @relation(fields: [indicatorId], references: [id], onDelete: Cascade)
  parameterId        String?
  parameter          PrizeIndicatorParameter? @relation("ParamRanges", fields: [parameterId], references: [id], onDelete: SetNull)
  orderIndex         Int                      @default(0)
  minLimit           Decimal?                 @db.Decimal(18, 4)
  maxLimit           Decimal?                 @db.Decimal(18, 4)
  achievementPercent Decimal?                 @db.Decimal(9, 4)
  gainPercent        Decimal?                 @db.Decimal(9, 4)
  weight             Decimal?                 @db.Decimal(9, 4)
  behaviorAbove      String?
  behaviorBelow      String?
  cap                Decimal?                 @db.Decimal(9, 4)
  floor              Decimal?                 @db.Decimal(9, 4)
  cumulative         Boolean                  @default(false)
  createdAt          DateTime                 @default(now())

  @@index([indicatorId])
  @@index([parameterId])
}

model PrizeAuditLog {
  id            String   @id @default(uuid())
  companyId     String
  userId        String?
  userEmail     String?
  action        String
  entityType    String
  entityId      String
  competenceId  String?
  before        Json?
  after         Json?
  justification String?
  ip            String?
  createdAt     DateTime @default(now())

  @@index([companyId, entityType, entityId])
  @@index([companyId, createdAt])
  @@index([competenceId])
}

// =====================================================
// Gestao de Premio - Fase 2: Lancamento do Realizado
// =====================================================

enum PrizeActualStatus {
  NOT_STARTED
  IN_FILLING
  PENDING
  IN_VALIDATION
  PRE_CLOSE
  CLOSED
  REOPENED
  CORRECTED
}

model PrizeActualResult {
  id                String               @id @default(uuid())
  companyId         String
  competenceId      String
  competence        PrizeCompetence      @relation(fields: [competenceId], references: [id], onDelete: Cascade)
  indicatorId       String
  indicator         PrizeIndicator       @relation(fields: [indicatorId], references: [id], onDelete: Cascade)
  parameterId       String?
  scopeKey          String               @default("")
  year              Int
  month             Int                  @default(0)
  week              Int                  @default(0)
  day               Int                  @default(0)
  realized          Decimal?             @db.Decimal(18, 4)
  accumulated       Decimal?             @db.Decimal(18, 4)
  source            PrizeIndicatorSource @default(MANUAL)
  status            PrizeActualStatus    @default(IN_FILLING)
  comment           String?
  justification     String?
  responsibleUserId String?
  createdById       String?
  closedAt          DateTime?
  closedById        String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  evidences PrizeActualEvidence[]

  @@unique([competenceId, indicatorId, scopeKey, week, day])
  @@index([companyId])
  @@index([competenceId])
  @@index([indicatorId])
  @@index([competenceId, status])
}

model PrizeActualEvidence {
  id             String            @id @default(uuid())
  actualResultId String
  actualResult   PrizeActualResult @relation(fields: [actualResultId], references: [id], onDelete: Cascade)
  fileName       String
  fileUrl        String?
  note           String?
  uploadedById   String?
  createdAt      DateTime          @default(now())

  @@index([actualResultId])
}

// =====================================================
// Gestao de Premio v2 - Regras em Matriz + Apuracao do Setor
// Modelo aditivo: catalogo unico, combinacoes area x cargo, parametros/faixas
// mensais, realizado por catalogo, regua coletiva e nao-casados bloqueantes.
// =====================================================

model PrizeIndicatorCatalog {
  id                  String                  @id @default(uuid())
  companyId           String
  code                String
  name                String
  description         String?
  unit                String?
  direction           PrizeIndicatorDirection @default(HIGHER_BETTER)
  source              PrizeIndicatorSource    @default(MANUAL)
  platformIndicatorId String?
  active              Boolean                 @default(true)
  createdById         String?
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
  deletedAt           DateTime?

  ruleIndicators PrizeRuleIndicator[]
  actuals        PrizeCatalogActualResult[]

  @@unique([companyId, code])
  @@index([companyId])
  @@index([companyId, active])
  @@index([platformIndicatorId])
}

model PrizeRuleGroup {
  id                     String            @id @default(uuid())
  companyId              String
  annexVersionId         String
  annexVersion           PrizeAnnexVersion @relation(fields: [annexVersionId], references: [id], onDelete: Cascade)
  name                   String
  areaRefs               String[]          @default([])
  positionRefs           String[]          @default([])
  normalizedAreaKeys     String[]          @default([])
  normalizedPositionKeys String[]          @default([])
  // IDs do catalogo (PrizeOrgRef / PrizeCargoRef). Quando preenchidos, o
  // matching da apuracao usa ID (deterministico) em vez do nome normalizado.
  areaRefIds             String[]          @default([])
  cargoRefIds            String[]          @default([])
  salaryPercent          Decimal           @db.Decimal(9, 4)
  notes                  String?
  active                 Boolean           @default(true)
  createdById            String?
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt
  deletedAt              DateTime?

  indicators  PrizeRuleIndicator[]
  cellResults PrizeCellResult[]

  @@index([companyId])
  @@index([annexVersionId])
  @@index([companyId, active])
}

model PrizeRuleIndicator {
  id           String                 @id @default(uuid())
  companyId    String
  groupId      String
  group        PrizeRuleGroup         @relation(fields: [groupId], references: [id], onDelete: Cascade)
  catalogId    String
  catalog      PrizeIndicatorCatalog  @relation(fields: [catalogId], references: [id], onDelete: Restrict)
  weight       Decimal                @db.Decimal(9, 4)
  kind         PrizeIndicatorKind     @default(COLLECTIVE)
  type         PrizeRuleIndicatorType @default(VARIABLE)
  validityKind PrizeRuleValidityKind  @default(CALENDAR_YEAR)
  startMonth   Int                    @default(1)
  monthsCount  Int                    @default(12)
  sortOrder    Int                    @default(0)
  active       Boolean                @default(true)
  createdById  String?
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  deletedAt    DateTime?

  parameters PrizeRuleParameter[]

  @@index([companyId])
  @@index([groupId])
  @@index([catalogId])
  @@index([companyId, active])
}

model PrizeRuleParameter {
  id              String             @id @default(uuid())
  companyId       String
  ruleIndicatorId String
  ruleIndicator   PrizeRuleIndicator @relation(fields: [ruleIndicatorId], references: [id], onDelete: Cascade)
  year            Int
  month           Int
  zero            Decimal?           @db.Decimal(18, 4)
  target          Decimal?           @db.Decimal(18, 4)
  changeReason    String?
  createdById     String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  bands PrizeRuleBand[]

  @@unique([ruleIndicatorId, year, month])
  @@index([companyId])
  @@index([ruleIndicatorId])
  @@index([year, month])
}

model PrizeRuleBand {
  id                 String             @id @default(uuid())
  companyId          String
  parameterId        String
  parameter          PrizeRuleParameter @relation(fields: [parameterId], references: [id], onDelete: Cascade)
  orderIndex         Int                @default(0)
  minLimit           Decimal?           @db.Decimal(18, 4)
  maxLimit           Decimal?           @db.Decimal(18, 4)
  achievementPercent Decimal?           @db.Decimal(9, 4)
  gainPercent        Decimal?           @db.Decimal(9, 4)
  createdAt          DateTime           @default(now())

  @@index([companyId])
  @@index([parameterId])
}

model PrizeRuleAlias {
  id            String             @id @default(uuid())
  companyId     String
  kind          PrizeRuleAliasKind
  sourceValue   String
  normalizedKey String
  canonicalRef  String?
  canonicalName String?
  notes         String?
  active        Boolean            @default(true)
  createdById   String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@unique([companyId, kind, normalizedKey])
  @@index([companyId])
  @@index([companyId, kind, active])
}

enum PrizeOrgRefKind {
  AREA
  SECTOR
}

/// Catalogo canonico de areas/setores (departamentos) com ID estavel (`code`).
/// Auto-derivado do import de elegiveis e/ou importado. Combinacoes e snapshots
/// referenciam o `id`, tornando o matching da apuracao deterministico.
model PrizeOrgRef {
  id            String          @id @default(uuid())
  companyId     String
  code          Int
  name          String
  normalizedKey String
  kind          PrizeOrgRefKind @default(AREA)
  source        String          @default("IMPORT")
  active        Boolean         @default(true)
  createdById   String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  deletedAt     DateTime?

  @@unique([companyId, normalizedKey])
  @@unique([companyId, code])
  @@index([companyId])
  @@index([companyId, active])
}

/// Catalogo canonico de cargos com ID estavel (`code`). Mesma logica do
/// PrizeOrgRef, para o eixo de cargo das combinacoes.
model PrizeCargoRef {
  id            String   @id @default(uuid())
  companyId     String
  code          Int
  name          String
  normalizedKey String
  source        String   @default("IMPORT")
  active        Boolean  @default(true)
  createdById   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?

  @@unique([companyId, normalizedKey])
  @@unique([companyId, code])
  @@index([companyId])
  @@index([companyId, active])
}

model PrizeCatalogActualResult {
  id                String                @id @default(uuid())
  companyId         String
  competenceId      String
  competence        PrizeCompetence       @relation(fields: [competenceId], references: [id], onDelete: Cascade)
  catalogId         String
  catalog           PrizeIndicatorCatalog @relation(fields: [catalogId], references: [id], onDelete: Cascade)
  year              Int
  month             Int
  realized          Decimal?              @db.Decimal(18, 4)
  accumulated       Decimal?              @db.Decimal(18, 4)
  source            PrizeIndicatorSource  @default(MANUAL)
  status            PrizeActualStatus     @default(IN_FILLING)
  comment           String?
  justification     String?
  responsibleUserId String?
  closedAt          DateTime?
  closedById        String?
  createdById       String?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  @@unique([competenceId, catalogId])
  @@index([companyId])
  @@index([competenceId])
  @@index([catalogId])
  @@index([competenceId, status])
}

model PrizeCellResult {
  id                    String                @id @default(uuid())
  companyId             String
  runId                 String
  run                   PrizeCalculationRun   @relation(fields: [runId], references: [id], onDelete: Cascade)
  competenceId          String
  competence            PrizeCompetence       @relation(fields: [competenceId], references: [id], onDelete: Cascade)
  groupId               String
  group                 PrizeRuleGroup        @relation(fields: [groupId], references: [id], onDelete: Cascade)
  annexVersionId        String
  areaRef               String
  positionRef           String
  normalizedAreaKey     String
  normalizedPositionKey String
  possibleSalaryPercent Decimal               @db.Decimal(9, 4)
  achievedSalaryPercent Decimal               @db.Decimal(9, 4)
  weightedGainPercent   Decimal?              @db.Decimal(9, 4)
  status                PrizeCellResultStatus @default(CALCULATED)
  details               Json?
  createdAt             DateTime              @default(now())

  @@unique([runId, areaRef, positionRef, groupId])
  @@index([companyId])
  @@index([runId])
  @@index([competenceId])
  @@index([normalizedAreaKey, normalizedPositionKey])
}

model PrizeUnmatchedEmployee {
  id                    String              @id @default(uuid())
  companyId             String
  runId                 String
  run                   PrizeCalculationRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  competenceId          String
  registration          String
  name                  String
  areaRef               String?
  positionRef           String?
  normalizedAreaKey     String?
  normalizedPositionKey String?
  reason                String
  createdAt             DateTime            @default(now())

  @@unique([runId, registration])
  @@index([companyId])
  @@index([runId])
  @@index([competenceId])
}

// =====================================================
// Gestao de Premio - Fase 3: Base Elegivel + Conectores (Apdata)
// Conectores desacoplados (API/arquivo/manual). Snapshot imutavel por
// competencia (lotVersion). Segredos por referencia (env/cofre), nunca em claro.
// =====================================================

enum PrizeConnectorType {
  API
  FILE_CSV
  FILE_XLSX
  DB_BRIDGE
  MANUAL
}

enum PrizeJobStatus {
  PENDING
  RUNNING
  SUCCESS
  ERROR
  PARTIAL
}

model PrizeIntegrationConfig {
  id             String             @id @default(uuid())
  companyId      String
  kind           String // APDATA_ELIGIBLE | APDATA_EVENTS | PAYROLL
  name           String
  type           PrizeConnectorType @default(MANUAL)
  active         Boolean            @default(true)
  config         Json? // endpoint, mapeamentos (NAO armazenar segredos aqui)
  secretRef      String? // nome da variavel de ambiente / cofre (NUNCA o segredo)
  schedule       String?
  lastRunAt      DateTime?
  nextRunAt      DateTime?
  lastStatus     String?
  processedTotal Int                @default(0)
  notes          String?
  createdById    String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  jobs PrizeIntegrationJob[]

  @@unique([companyId, kind, name])
  @@index([companyId])
  @@index([companyId, kind])
}

model PrizeIntegrationJob {
  id           String                  @id @default(uuid())
  companyId    String
  configId     String?
  config       PrizeIntegrationConfig? @relation(fields: [configId], references: [id], onDelete: SetNull)
  kind         String
  competenceId String?
  type         PrizeConnectorType      @default(MANUAL)
  status       PrizeJobStatus          @default(PENDING)
  processed    Int                     @default(0)
  errorsCount  Int                     @default(0)
  retries      Int                     @default(0)
  lotVersion   Int                     @default(1)
  startedAt    DateTime?
  finishedAt   DateTime?
  log          String?
  summary      Json?
  createdById  String?
  createdAt    DateTime                @default(now())

  @@index([companyId])
  @@index([companyId, kind])
  @@index([competenceId])
}

model PrizeEmployeeSnapshot {
  id              String             @id @default(uuid())
  companyId       String
  competenceId    String
  batchId         String
  lotVersion      Int                @default(1)
  current         Boolean            @default(true)
  registration    String
  name            String
  cpfMasked       String?
  bond            String?
  branchRef       String?
  unitRef         String?
  positionRef     String?
  functionRef     String?
  areaRef         String?
  sectorRef       String?
  costCenterRef   String?
  // Linkagem deterministica ao catalogo (resolvidos no import a partir dos nomes
  // acima). O matching da apuracao prefere os IDs e cai p/ nome quando ausentes.
  areaRefId       String?
  sectorRefId     String?
  cargoRefId      String?
  baseSalary      Decimal?           @db.Decimal(14, 2)
  admissionDate   DateTime?
  terminationDate DateTime?
  situation       String             @default("ACTIVE")
  workedDays      Int?
  eligible        Boolean            @default(true)
  blocked         Boolean            @default(false)
  source          PrizeConnectorType @default(MANUAL)
  raw             Json?
  importedAt      DateTime           @default(now())
  createdById     String?

  events PrizeEmployeeEvent[]

  @@unique([competenceId, registration, lotVersion])
  @@index([companyId])
  @@index([competenceId])
  @@index([competenceId, current])
  @@index([companyId, cargoRefId])
  @@index([companyId, areaRefId])
}

model PrizeEmployeeEvent {
  id           String                 @id @default(uuid())
  companyId    String
  competenceId String
  snapshotId   String?
  snapshot     PrizeEmployeeSnapshot? @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  registration String
  type         String // FALTA | ATESTADO | MEDIDA_DISCIPLINAR | SUSPENSAO | ACIDENTE | TREINAMENTO | AFASTAMENTO | GRATIFICACAO | MOVIMENTACAO
  date         DateTime?
  days         Int?
  value        Decimal?               @db.Decimal(14, 2)
  description  String?
  source       PrizeConnectorType     @default(MANUAL)
  raw          Json?
  batchId      String?
  createdAt    DateTime               @default(now())

  @@index([companyId])
  @@index([competenceId])
  @@index([snapshotId])
  @@index([competenceId, registration])
}

// =====================================================
// Gestao de Premio - Fase 4: Motor de Calculo + suportes
// Regras parametrizaveis (nada de percentual fixo de empresa no codigo).
// Memoria de calculo auditavel (PrizeCalculationLine). Reprocesso versionado.
// =====================================================

enum PrizeCalcRunStatus {
  PENDING
  RUNNING
  SUCCESS
  PARTIAL
  ERROR
  SUPERSEDED
}

enum PrizeAdjustmentStatus {
  DRAFT
  REQUESTED
  IN_ANALYSIS
  APPROVED
  REJECTED
  APPLIED
  CANCELLED
}

enum PrizeExceptionType {
  IMPOSSIBILITY
  TRAINING
  TERMINATION
  OTHER
}

enum PrizeExceptionStatus {
  DRAFT
  REQUESTED
  APPROVED
  REJECTED
  APPLIED
}

model PrizeModeratorRule {
  id               String    @id @default(uuid())
  companyId        String
  programId        String?
  name             String
  eventType        String // FALTA | ATESTADO | MEDIDA_DISCIPLINAR | SUSPENSAO | ACIDENTE | ...
  criterion        String? // PER_OCCURRENCE | PER_DAY | ANY
  reductionPercent Decimal?  @db.Decimal(9, 4) // % de reducao sobre o premio
  reductionValue   Decimal?  @db.Decimal(14, 2) // reducao em valor fixo
  cap              Decimal?  @db.Decimal(9, 4) // teto de reducao acumulada (%)
  cumulative       Boolean   @default(true)
  priority         Int       @default(0)
  requiresApproval Boolean   @default(false)
  active           Boolean   @default(true)
  validFrom        DateTime?
  validTo          DateTime?
  notes            String?
  createdById      String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([companyId])
  @@index([companyId, programId])
  @@index([companyId, eventType])
}

model PrizeManualAdjustment {
  id            String                @id @default(uuid())
  companyId     String
  competenceId  String
  registration  String
  field         String // AREA | POSITION | SALARY | DAYS | ELIGIBILITY | POTENTIAL | FINAL_VALUE
  previousValue String?
  newValue      String?
  amount        Decimal?              @db.Decimal(14, 2)
  reason        String
  evidenceRef   String?
  status        PrizeAdjustmentStatus @default(REQUESTED)
  requestedById String?
  decidedById   String?
  decidedAt     DateTime?
  comment       String?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  @@index([companyId, competenceId])
  @@index([competenceId, registration])
  @@index([status])
}

model PrizeException {
  id                 String               @id @default(uuid())
  companyId          String
  competenceId       String
  registration       String?
  type               PrizeExceptionType
  scope              String? // ALL | indicatorId | area
  avgMonths          Int?                 @default(6)
  gratificationValue Decimal?             @db.Decimal(14, 2)
  reason             String
  evidenceRef        String?
  status             PrizeExceptionStatus @default(REQUESTED)
  requestedById      String?
  decidedById        String?
  decidedAt          DateTime?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  @@index([companyId, competenceId])
  @@index([competenceId, registration])
