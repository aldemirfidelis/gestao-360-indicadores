  status                SecurityRoundStatus @default(PLANNED)
  visitedCheckpointIds  String[]            @default([])
  missedCheckpointIds   String[]            @default([])
  checklistSubmissionId String?
  evidence              Json?
  offlineSyncId         String?
  notes                 String?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  deletedAt             DateTime?

  @@index([companyId])
  @@index([companyId, status])
  @@index([routeId])
  @@index([postId])
  @@index([scheduledAt])
}

model SecurityShiftHandover {
  id                    String                      @id @default(uuid())
  companyId             String
  unitId                String?
  gateId                String?
  postId                String?
  outgoingUserId        String?
  incomingUserId        String?
  shiftName             String?
  startedAt             DateTime                    @default(now())
  finishedAt            DateTime?
  status                SecurityShiftHandoverStatus @default(NOT_STARTED)
  summary               String?
  pendingItems          Json?
  checklistSubmissionId String?
  evidence              Json?
  acceptedAt            DateTime?
  acceptedById          String?
  notes                 String?
  createdAt             DateTime                    @default(now())
  updatedAt             DateTime                    @updatedAt
  deletedAt             DateTime?

  @@index([companyId])
  @@index([companyId, status])
  @@index([gateId])
  @@index([postId])
  @@index([startedAt])
}

model SecurityLogBookEntry {
  id                String               @id @default(uuid())
  companyId         String
  unitId            String?
  gateId            String?
  postId            String?
  occurredAt        DateTime             @default(now())
  title             String
  entryType         String
  description       String?
  attachments       Json?
  acknowledgedByIds String[]             @default([])
  status            SecurityRecordStatus @default(ACTIVE)
  createdById       String?
  updatedById       String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  deletedAt         DateTime?

  @@index([companyId])
  @@index([companyId, status])
  @@index([gateId])
  @@index([postId])
  @@index([occurredAt])
}

model SecurityQrCode {
  id         String           @id @default(uuid())
  companyId  String
  token      String           @unique
  entityType String
  entityId   String
  purpose    String
  status     SecurityQrStatus @default(ACTIVE)
  expiresAt  DateTime?
  usedAt     DateTime?
  issuedById String?
  metadata   Json?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  deletedAt  DateTime?

  @@index([companyId])
  @@index([companyId, entityType, entityId])
  @@index([status])
  @@index([expiresAt])
}

model SecurityOfflineSync {
  id             String                    @id @default(uuid())
  companyId      String
  localId        String
  entityType     String
  entityId       String?
  operation      String
  payload        Json
  status         SecurityOfflineSyncStatus @default(PENDING)
  conflictReason String?
  errorMessage   String?
  localCreatedAt DateTime?
  syncedAt       DateTime?
  deviceId       String?
  deviceInfo     Json?
  createdById    String?
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt

  @@unique([companyId, localId])
  @@index([companyId])
  @@index([companyId, status])
  @@index([entityType, entityId])
}

model SecurityAuditLog {
  id            String               @id @default(uuid())
  companyId     String
  unitId        String?
  gateId        String?
  postId        String?
  userId        String?
  userRole      String?
  action        String
  entity        String
  entityId      String?
  recordLabel   String?
  beforeValue   Json?
  afterValue    Json?
  reason        String?
  justification String?
  approverId    String?
  evidence      Json?
  origin        SecurityRecordOrigin @default(WEB)
  ip            String?
  deviceInfo    Json?
  offline       Boolean              @default(false)
  syncedAt      DateTime?
  createdAt     DateTime             @default(now())

  @@index([companyId, createdAt])
  @@index([userId, createdAt])
  @@index([entity, entityId])
  @@index([gateId])
  @@index([postId])
}
