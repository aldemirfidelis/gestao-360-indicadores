// =====================================================
// Gestao 360 Indicadores - Prisma Schema
// =====================================================

generator client {
  provider      = "prisma-client-js"
  // native: para dev local (macOS/Windows/Linux glibc)
  // linux-musl-openssl-3.0.x: para imagens Alpine usadas no Docker/DigitalOcean
  // debian-openssl-3.0.x: para buildpacks DO (caso opte por buildpack)
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // directUrl e usado por prisma migrate e introspeccao, para evitar pgbouncer
  // quando DATABASE_URL aponta para um pooler. Em prod o banco e o Postgres
  // local da droplet (sem pooler); o dev ainda usa o Neon legado.
  directUrl = env("DIRECT_URL")
}

