enum ConversationKind {
  DIRECT
  GROUP
}

enum ConversationRole {
  OWNER
  MEMBER
}

enum PresenceStatus {
  ONLINE
  AWAY
  BUSY
  DND
  OFFLINE
}

model Conversation {
  id                 String           @id @default(uuid())
  companyId          String
  company            Company          @relation(fields: [companyId], references: [id])
  kind               ConversationKind @default(DIRECT)
  title              String?
  // Par ordenado "minUserId:maxUserId" para conversas DIRECT.
  // Unique => impede criar duas conversas individuais entre as mesmas pessoas.
  dmKey              String?          @unique
  createdById        String
  createdBy          User             @relation("ConversationCreatedBy", fields: [createdById], references: [id])
  lastMessageAt      DateTime?
  lastMessagePreview String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  participants ConversationParticipant[]
  messages     Message[]

  @@index([companyId])
  @@index([lastMessageAt])
}

model ConversationParticipant {
  conversationId String
  conversation   Conversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           ConversationRole @default(MEMBER)
  joinedAt       DateTime         @default(now())
  lastReadAt     DateTime?
  muted          Boolean          @default(false)
  pinnedAt       DateTime?
  leftAt         DateTime?

  @@id([conversationId, userId])
  @@index([userId])
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation("MessageSender", fields: [senderId], references: [id])
  body           String
  replyToId      String?
  replyTo        Message?     @relation("MessageReply", fields: [replyToId], references: [id])
  replies        Message[]    @relation("MessageReply")
  editedAt       DateTime?
  deletedAt      DateTime? // exclusão lógica
  createdAt      DateTime     @default(now())

  attachments MessageAttachment[]
  reactions   MessageReaction[]

  @@index([conversationId, createdAt])
  @@index([senderId])
}

model MessageAttachment {
  id           String    @id @default(uuid())
  messageId    String
  message      Message   @relation(fields: [messageId], references: [id], onDelete: Cascade)
  uploadedById String?
  uploadedBy   User?     @relation("MessageAttachmentUploadedBy", fields: [uploadedById], references: [id], onDelete: SetNull)
  fileName     String
  fileUrl      String?
  mimeType     String?
  sizeBytes    Int?
  data         Bytes?
  createdAt    DateTime  @default(now())
  deletedAt    DateTime?

  @@index([messageId])
  @@index([uploadedById])
}

model MessageReaction {
  messageId String
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  emoji     String
  createdAt DateTime @default(now())

  @@id([messageId, userId, emoji])
  @@index([messageId])
}

model UserPresence {
  userId       String          @id
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  status       PresenceStatus  @default(OFFLINE)
  manualStatus PresenceStatus?
  lastSeenAt   DateTime?
  updatedAt    DateTime        @updatedAt

  @@index([status])
}

model HelpCategory {
  id          String        @id @default(uuid())
  slug        String        @unique
  title       String
  description String?
  icon        String?
  position    Int           @default(0)
  published   Boolean       @default(true)
