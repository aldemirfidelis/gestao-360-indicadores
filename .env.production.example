# =====================================================
# .env de PRODUCAO - Gestao 360 Indicadores
# =====================================================
# Use este arquivo como referencia ao configurar variaveis
# no painel da DigitalOcean (App Platform) ou em qualquer
# outro PaaS. NAO commitar valores reais.
# =====================================================

NODE_ENV=production

# -------- Neon Postgres --------
# Pegue as duas URLs no painel do Neon (Connection Details -> Pooled / Direct).
#
# DATABASE_URL: SEMPRE a URL do POOLER (-pooler no host). Necessario para
# servidores Node serverless-friendly. Sufixos importantes:
#   ?sslmode=require       SSL obrigatorio
#   &pgbouncer=true        sinaliza ao Prisma que esta atras de pgbouncer
#   &connect_timeout=15    evita boot lento na primeira conexao
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxxx-pooler.us-east-2.aws.neon.tech/g360?sslmode=require&pgbouncer=true&connect_timeout=15"

# DIRECT_URL: URL SEM pooler. Usada por prisma migrate / introspect.
# Diferenca: hostname SEM o '-pooler'.
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxxx.us-east-2.aws.neon.tech/g360?sslmode=require"

# -------- API --------
# DO injeta PORT automaticamente; este valor e fallback local
PORT=3333
API_PREFIX=api
# Em DO mesmo app: aceita qualquer origem do proprio dominio (mesmo host).
# Para dominio customizado, troque por https://app.seudominio.com
API_CORS_ORIGIN=${APP_URL}

# -------- Auth (gere com: openssl rand -base64 48) --------
JWT_ACCESS_SECRET=GERAR_SECRET_FORTE_AQUI_MIN_32_CHARS
JWT_REFRESH_SECRET=OUTRO_SECRET_FORTE_AQUI_MIN_32_CHARS
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
BCRYPT_ROUNDS=10

# -------- Web (Next.js) --------
# Quando API e Web rodam no MESMO app DO, use rota relativa.
# Se Web e API estiverem em dominios diferentes, use URL absoluta:
#   NEXT_PUBLIC_API_URL=https://api.seudominio.com/api
NEXT_PUBLIC_API_URL=/api
NEXT_PUBLIC_APP_NAME="Gestao 360 Indicadores"

# -------- Opcional: skip migrate no boot --------
# Se rodar migrate via job dedicado pre-deploy, evite migrar no start:
# SKIP_MIGRATE=1
