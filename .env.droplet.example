# =====================================================
# .env para Droplet DigitalOcean (PRODUCAO)
# =====================================================
# 1. Copie este arquivo para /opt/gestao-360-indicadores/.env na droplet
# 2. Substitua os valores marcados com TROCAR_*
# 3. Salve e rode: ./scripts/deploy.sh
#
# NAO commitar este arquivo com valores reais!
# =====================================================

NODE_ENV=production

# -------- Banco Neon Postgres --------
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxxx-pooler.region.aws.neon.tech/DB?sslmode=require&pgbouncer=true&connect_timeout=15
DIRECT_URL=postgresql://USER:PASSWORD@ep-xxxxx.region.aws.neon.tech/DB?sslmode=require&channel_binding=require

# -------- API --------
PORT=3333
API_PREFIX=api
# Acesso via Caddy: o frontend chama /api (mesma origem). Em IP-only:
API_CORS_ORIGIN=*
# Quando tiver dominio: troque para https://seu-dominio.com

# -------- Auth (TROQUE os secrets na droplet!) --------
JWT_ACCESS_SECRET=TROCAR_GERE_COM_openssl_rand_base64_48
JWT_REFRESH_SECRET=TROCAR_GERE_OUTRO_DIFERENTE_DO_ACCESS
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
BCRYPT_ROUNDS=10

# -------- Web (build-time vars ja estao no docker-compose) --------
# NEXT_PUBLIC_API_URL=/api  (definido no compose como build arg)
# NEXT_PUBLIC_APP_NAME="..."

# -------- Flags --------
# Para pular migrate no boot (ex.: rodar manualmente em janela controlada):
# SKIP_MIGRATE=1

# -------- E-mail / Convites de reuniao --------
# Sem SMTP configurado, o sistema registra o convite como PENDING e gera ICS.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Gestão 360 <nao-responder@seudominio.com>"

# -------- Editor DOCX online (Collabora Online / WOPI) --------
# Provedor: 'manual' mantem download/upload.
# Troque para 'collabora' somente depois de configurar DNS, Caddyfile e profile docker.
DOCUMENT_EDITOR_PROVIDER=manual
# URL publica do Collabora (subdominio servido pelo Caddy).
# Requer DNS: collabora.SEU-DOMINIO -> IP do droplet.
DOCUMENT_EDITOR_URL=https://collabora.seu-dominio.com
# Base publica da API que o Collabora usa para ler/salvar (host WOPI). Inclua /api.
DOCUMENT_EDITOR_WOPI_BASE=https://seu-dominio.com/api
# Segredo para assinar o access_token WOPI (gere com: openssl rand -base64 48).
DOCUMENT_EDITOR_JWT_SECRET=TROCAR_GERE_COM_openssl_rand_base64_48
# Console admin do Collabora (opcional).
COLLABORA_ADMIN_USER=admin
COLLABORA_ADMIN_PASSWORD=TROCAR_SENHA_FORTE

# -------- Armazenamento de documentos (GED) --------
# DOCX binario do editor online vive so em disco -> o volume g360_storage
# (docker-compose.droplet.yml) e obrigatorio para persistir entre deploys.
DOCUMENT_STORAGE_PROVIDER=LOCAL
DOCUMENT_STORAGE_PATH=storage/documents

# -------- Portal Admin Global (login SEPARADO do super admin) --------
# Portal interno em /platform-admin com login/tabela/tokens proprios. No primeiro
# boot apos a migration, a API cria um PLATFORM_OWNER se nenhum usuario interno
# existir. Sem senha definida, uma senha forte e gerada e impressa no log uma vez.
PLATFORM_ADMIN_BOOTSTRAP_EMAIL=platform@seu-dominio.com
PLATFORM_ADMIN_BOOTSTRAP_PASSWORD=TROCAR_SENHA_FORTE
PLATFORM_ADMIN_BOOTSTRAP_NAME=Platform Owner
