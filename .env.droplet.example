# =====================================================
# .env para Droplet DigitalOcean (PRODUCAO)
# =====================================================
# 1. Copie este arquivo para /opt/gestao-360-indicadores/.env na droplet
# 2. Substitua os valores marcados com TROCAR_*
# 3. Salve e rode: ./scripts/deploy.sh
#
# NAO commitar este arquivo com valores reais!
# =====================================================

NODE_ENV=production

# -------- Banco Postgres LOCAL (na propria droplet) --------
# O Postgres roda como container no mesmo host (servico `postgres` no compose),
# eliminando a latencia de rede ate a Neon. Host = nome do servico: `postgres`.
#
# 1) Defina uma senha forte (gere com: openssl rand -base64 24):
POSTGRES_USER=g360
POSTGRES_PASSWORD=TROCAR_SENHA_FORTE_DO_BANCO
POSTGRES_DB=g360
#
# 2) As URLs do Prisma apontam para o banco local. Sem pooler/SSL (rede interna).
#    DIRECT_URL = DATABASE_URL (nao ha pgbouncer local).
DATABASE_URL=postgresql://g360:TROCAR_SENHA_FORTE_DO_BANCO@postgres:5432/g360?schema=public&connection_limit=20
DIRECT_URL=postgresql://g360:TROCAR_SENHA_FORTE_DO_BANCO@postgres:5432/g360?schema=public
#
# 3) MIGRACAO (uma vez): para copiar os dados da Neon para o banco local, informe
#    aqui a URL DIRECT (sem -pooler) da Neon e rode scripts/migrate-neon-to-droplet.sh.
#    Pode comentar/remover depois da migracao concluida.
# NEON_SOURCE_URL=postgresql://USER:PASSWORD@ep-xxxxx.region.aws.neon.tech/DB?sslmode=require

# -------- Backup off-site (opcional, recomendado) --------
# scripts/backup-db.sh gera o dump local diario (cron). Para copiar tambem para
# fora da droplet (DigitalOcean Spaces / S3), habilite abaixo (requer aws-cli):
# OFFSITE_BACKUP=1
# S3_ENDPOINT=https://nyc3.digitaloceanspaces.com
# S3_BUCKET=meu-space/g360
# AWS_ACCESS_KEY_ID=CHAVE_DO_SPACES
# AWS_SECRET_ACCESS_KEY=SEGREDO_DO_SPACES

# -------- API --------
PORT=3333
API_PREFIX=api
# Acesso via Caddy: o frontend chama /api (mesma origem).
# Em producao, prefira origem explicita em vez de coringa.
API_CORS_ORIGIN=https://gestao360.org
# Para outro dominio: troque para https://seu-dominio.com

# Dominio raiz da plataforma (multi-tenant por subdominio: empresa.gestao360.org).
# Usado para extrair o slug do tenant a partir do host. Default no codigo: gestao360.org.
PLATFORM_ROOT_DOMAIN=gestao360.org

# -------- Auth (TROQUE os secrets na droplet!) --------
JWT_ACCESS_SECRET=TROCAR_GERE_COM_openssl_rand_base64_48
JWT_REFRESH_SECRET=TROCAR_GERE_OUTRO_DIFERENTE_DO_ACCESS
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
BCRYPT_ROUNDS=10

# -------- Web (build-time vars ja estao no docker-compose) --------
# NEXT_PUBLIC_API_URL=/api  (definido no compose como build arg)
# NEXT_PUBLIC_APP_NAME="..."
NEXT_PUBLIC_SITE_URL=https://gestao360.org
NEXT_PUBLIC_WHATSAPP_NUMBER=5564981009108
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_GTM_ID=

# -------- SEO / IndexNow --------
# Gere uma chave publica com: openssl rand -hex 32
# Depois valide https://gestao360.org/indexnow-key.txt e rode pnpm indexnow:submit
INDEXNOW_ENABLED=0
INDEXNOW_KEY=
INDEXNOW_ENDPOINT=https://api.indexnow.org/indexnow

# -------- Flags --------
# Para pular migrate no boot (ex.: rodar manualmente em janela controlada):
# SKIP_MIGRATE=1

# -------- E-mail / Convites de reuniao --------
# Sem SMTP configurado, o sistema registra o convite como PENDING e gera ICS.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Gestão 360 <nao-responder@seudominio.com>"
# Destinatários dos formulários públicos (o navegador nunca escolhe o destinatário).
PUBLIC_SUPPORT_EMAIL=suporte@gestao360.org
PUBLIC_CONTACT_EMAIL=contato@gestao360.org

# -------- Editor DOCX online (Collabora Online / WOPI) --------
# Provedor: 'manual' mantem download/upload.
# Troque para 'collabora' somente depois de configurar DNS, Caddyfile e profile docker.
DOCUMENT_EDITOR_PROVIDER=manual
# URL publica do Collabora (subdominio servido pelo Caddy).
# Requer DNS: collabora.SEU-DOMINIO -> IP do droplet.
DOCUMENT_EDITOR_URL=https://collabora.seu-dominio.com
# Base publica da API que o Collabora usa para ler/salvar (host WOPI). Inclua /api.
DOCUMENT_EDITOR_WOPI_BASE=https://seu-dominio.com/api
# Segredo para assinar o access_token WOPI (gere com: openssl rand -base64 48).
DOCUMENT_EDITOR_JWT_SECRET=TROCAR_GERE_COM_openssl_rand_base64_48
# Console admin do Collabora (opcional).
COLLABORA_ADMIN_USER=admin
COLLABORA_ADMIN_PASSWORD=TROCAR_SENHA_FORTE

# -------- Armazenamento de documentos (GED) --------
# DOCX binario do editor online vive so em disco -> o volume g360_storage
# (docker-compose.droplet.yml) e obrigatorio para persistir entre deploys.
DOCUMENT_STORAGE_PROVIDER=LOCAL
DOCUMENT_STORAGE_PATH=storage/documents

# -------- Notificacoes Push (PWA / Web Push) --------
# Push para Android e iPhone (iOS 16.4+ instalado como app via "Adicionar a Tela de Inicio").
# Gere as chaves uma vez: docker exec g360-api node -e "console.log(require('web-push').generateVAPIDKeys())"
# Sem as chaves o push fica inerte; o restante da app continua normal.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:contato@gestao360.org

# -------- Portal Admin Global (login SEPARADO do super admin) --------
# Portal interno em /platform-admin com login/tabela/tokens proprios. No primeiro
# boot apos a migration, a API cria um PLATFORM_OWNER se nenhum usuario interno
# existir. Sem senha definida, uma senha forte e gerada e impressa no log uma vez.
PLATFORM_ADMIN_BOOTSTRAP_EMAIL=platform@seu-dominio.com
PLATFORM_ADMIN_BOOTSTRAP_PASSWORD=TROCAR_SENHA_FORTE
PLATFORM_ADMIN_BOOTSTRAP_NAME=Platform Owner
