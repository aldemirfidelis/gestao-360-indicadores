# ========== Compartilhado ==========
NODE_ENV=development

# ========== Banco ==========
DATABASE_URL="postgresql://g360:g360@localhost:5432/g360?schema=public"

# ========== Redis ==========
REDIS_HOST=localhost
REDIS_PORT=6379

# ========== API ==========
API_PORT=3333
API_PREFIX=api
API_CORS_ORIGIN=http://localhost:3000

# ========== Auth ==========
JWT_ACCESS_SECRET=change-me-in-production-access-secret-32chars-min
JWT_REFRESH_SECRET=change-me-in-production-refresh-secret-32chars-min
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
BCRYPT_ROUNDS=10

# ========== Web ==========
NEXT_PUBLIC_API_URL=http://localhost:3333/api
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_WHATSAPP_NUMBER=5564981009108
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_GTM_ID=
INDEXNOW_ENABLED=0
INDEXNOW_KEY=
INDEXNOW_ENDPOINT=https://api.indexnow.org/indexnow
NEXT_PUBLIC_APP_NAME="Gestão 360"

# ========== E-mail / Convites ==========
# Sem SMTP configurado, os convites ficam registrados como PENDING.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Gestão 360 <nao-responder@gestao360.local>"
PUBLIC_SUPPORT_EMAIL=suporte@gestao360.org
PUBLIC_CONTACT_EMAIL=contato@gestao360.org

# ========== IA - Google Gemini ==========
# Chave obtida em https://aistudio.google.com/apikey
# Se vazia, os insights e sugestoes voltam para regras deterministicas (fallback).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ========== GED - Documentos / Editor DOCX online ==========
# Armazenamento dos arquivos controlados (DOCX/PDF).
DOCUMENT_STORAGE_PROVIDER=LOCAL
DOCUMENT_STORAGE_PATH=storage/documents
# Editor online (Collabora/WOPI). 'manual' (padrao) usa download/upload.
# Para ativar, defina PROVIDER=collabora e as 3 URLs/segredo abaixo.
# Detalhes e passo a passo do servidor: docs/GED_DOCUMENTOS.md
DOCUMENT_EDITOR_PROVIDER=manual
DOCUMENT_EDITOR_URL=
DOCUMENT_EDITOR_WOPI_BASE=
DOCUMENT_EDITOR_JWT_SECRET=

# ========== Portal Admin Global (login separado do super admin) ==========
# Portal interno em /platform-admin. No 1o boot cria um PLATFORM_OWNER se nao
# houver nenhum. Em dev o seed ja cria platform@demo.com / admin123.
PLATFORM_ADMIN_BOOTSTRAP_EMAIL=platform@demo.com
PLATFORM_ADMIN_BOOTSTRAP_PASSWORD=admin123
PLATFORM_ADMIN_BOOTSTRAP_NAME=Platform Owner

# ========== Jobs assincronos (BullMQ) — item 14 ==========
# Workers ficam DESLIGADOS por padrao (boot nao abre conexao Redis). Ative em
# producao com Redis disponivel (REDIS_HOST/REDIS_PORT acima).
WORKERS_ENABLED=false
# Cron do job de notificacoes (indicador vermelho, acao atrasada). Default: */15 * * * *
NOTIFICATIONS_CRON=*/15 * * * *
# Sync de realizado do premio em background (opt-in; vazio = NAO agenda). Ex.: 0 4 * * *
PRIZE_SYNC_CRON=

# ========== Storage de anexos S3/Spaces — item 15 ==========
# Inerte ate configurar. Separado do off-site de backup (S3_* do backup-db.sh).
STORAGE_ENDPOINT=
STORAGE_BUCKET=
STORAGE_REGION=us-east-1
STORAGE_PREFIX=
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_FORCE_PATH_STYLE=false

# ========== Metricas de produto via logs — item 20 ==========
# Limite (ms) para logar uma rota como lenta (warn). 5xx sempre vira erro no log.
METRICS_SLOW_MS=1000
# true = loga TODAS as requests (uso por rota); default so loga lentas e 5xx.
METRICS_VERBOSE=false
