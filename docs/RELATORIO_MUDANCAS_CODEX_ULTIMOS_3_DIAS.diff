+  @Post('auth/login')
+  login(@Body(new ZodValidationPipe(loginDto)) body: z.infer<typeof loginDto>, @Req() req: Request) {
+    return this.auth.login(body.email, body.password, {
+      ip: req.ip,
+      userAgent: req.headers['user-agent'],
+    });
+  }
