+function jsonOrUndefined(value: unknown) {
+  if (value === undefined || value === null) return undefined;
+  try {
+    return JSON.parse(JSON.stringify(value)) as Prisma.InputJsonValue;
+  } catch {
+    return { value: String(value) };
+  }
