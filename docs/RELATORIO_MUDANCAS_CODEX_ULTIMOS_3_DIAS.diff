+  plannedDate      DateTime?
+  plannedStartAt   DateTime?
+  plannedEndAt     DateTime?
+  executedAt       DateTime?
+  startedAt        DateTime?
+  completedAt      DateTime?
+  closedAt         DateTime?
+  estimatedHours   Float?
+  actualHours      Float?
+  locations        Json?
+  agenda           Json?
+  team             Json?
+  auditees         Json?
+  approvers        Json?
+  observers        Json?
+  standards        Json?
+  requirements     Json?
+  documents        Json?
+  risks            Json?
+  meetingUrl       String?
+  version          Int           @default(1)
+  score            Float?
+  result           String?
+  opinion          String?
+  summary          String? // relatorio / conclusao
+  followUpPlan     String?
+  confidentiality  String        @default("INTERNAL")
+  cancelledReason  String?
+  rescheduleReason String?
+  createdAt        DateTime      @default(now())
+  updatedAt        DateTime      @updatedAt
+  deletedAt        DateTime?
+
+  findings            AuditFinding[]
+  checklistExecutions AuditChecklistExecution[]
+  evidence            AuditEvidence[]
+  reports             AuditReport[]
+  approvals           AuditApproval[]
+  followUps           AuditFollowUp[]
+  timelineEvents      AuditTimelineEvent[]
+  externalAccesses    AuditExternalAccess[]
+  aiSuggestions       AuditAiSuggestion[]
