{
  "name": "gestao-360",
  "version": "0.1.0",
  "private": true,
  "description": "Plataforma SaaS de Gestão Estratégica, OKR, KPI, planos de ação e melhoria contínua",
  "scripts": {
    "dev": "pnpm shared:build && pnpm -r --parallel --filter \"./apps/*\" dev",
    "dev:api": "pnpm shared:build && pnpm --filter @g360/api dev",
    "dev:web": "pnpm shared:build && pnpm --filter @g360/web dev",
    "shared:build": "pnpm --filter @g360/shared build",
    "shared:dev": "pnpm --filter @g360/shared dev",
    "build": "pnpm shared:build && pnpm --filter @g360/api build && pnpm --filter @g360/web build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "test:e2e": "playwright test",
    "e2e": "playwright test",
    "e2e:install": "playwright install chromium",
    "e2e:ui": "playwright test --ui",
    "db:up": "docker compose up -d postgres redis",
    "db:down": "docker compose down",
    "db:migrate": "pnpm --filter @g360/api prisma:migrate",
    "db:seed": "pnpm --filter @g360/api prisma:seed",
    "db:reset": "pnpm --filter @g360/api prisma:reset",
    "deploy:migrate": "pnpm --filter @g360/api deploy:migrate",
    "deploy:seed": "pnpm --filter @g360/api deploy:seed",
    "indexnow:submit": "node scripts/indexnow-submit.mjs",
    "setup": "pnpm install && pnpm shared:build && pnpm db:up && pnpm db:migrate && pnpm db:seed",
    "docker:api": "docker build -f apps/api/Dockerfile -t g360-api .",
    "docker:web": "docker build -f apps/web/Dockerfile -t g360-web ."
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "prettier": "^3.3.3",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.7.0"
}
